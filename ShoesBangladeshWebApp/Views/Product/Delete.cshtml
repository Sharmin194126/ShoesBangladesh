@model ShoesBangladesh.API.ViewModels.ProductViewModel
@{
    ViewData["Title"] = "Delete Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var baseUrl = "http://localhost:5190";
    var imageUrl = !string.IsNullOrEmpty(Model.ImageUrl) 
        ? (Model.ImageUrl.StartsWith("http") ? Model.ImageUrl : $"{baseUrl}{Model.ImageUrl}") 
        : "/images/placeholder.png";
}

<style>
    .delete-card { background: #fff; border-radius: 16px; border: 1px solid #FFCDD2; box-shadow: 0 4px 16px rgba(198,40,40,0.08); padding: 2rem; max-width: 600px; margin: 2rem auto; text-align: center; }
    .warning-icon { font-size: 3rem; color: #C62828; margin-bottom: 1rem; }
    .warning-title { font-size: 1.5rem; font-weight: 800; color: #1F1F1F; margin-bottom: 0.5rem; }
    .warning-text { font-size: 0.95rem; color: #616161; margin-bottom: 1.5rem; }
    
    .product-preview { background: #FAFAFA; border: 1px solid #ECECEC; border-radius: 12px; padding: 1.5rem; display: flex; align-items: center; justify-content: flex-start; margin-bottom: 2rem; text-align: left; }
    .product-img { width: 80px; height: 80px; object-fit: contain; border-radius: 8px; margin-right: 1.5rem; background: #fff; border: 1px solid #ECECEC; padding: 5px; }
    
    .product-name { font-size: 1.2rem; font-weight: 800; color: #1F1F1F; margin-bottom: 0.25rem; }
    .product-cat { font-size: 0.85rem; color: #9E9E9E; margin-bottom: 0.5rem; }
    .product-price { font-size: 1.1rem; color: #C40000; font-weight: 700; }
    
    .btn-delete { background: linear-gradient(135deg, #ff2d2d 0%, #C40000 100%); color: white; border: none; padding: 0.75rem 2.5rem; border-radius: 8px; font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: all 0.2s; box-shadow: 0 3px 12px rgba(196,0,0,0.25); }
    .btn-delete:hover { background: linear-gradient(135deg, #C40000 0%, #8B0000 100%); transform: translateY(-1px); color: white; }
    
    .btn-cancel { background: #F5F5F5; color: #2B2B2B; border: 1px solid #ECECEC; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; font-size: 0.95rem; text-decoration: none; transition: 0.2s; }
    .btn-cancel:hover { background: #ECECEC; color: #1F1F1F; }
</style>

<div class="delete-card">
    <i class="bi bi-exclamation-triangle-fill warning-icon"></i>
    <h1 class="warning-title">Delete Product?</h1>
    <p class="warning-text">Are you sure you want to delete this product? This action cannot be undone and all associated data will be permanently removed.</p>
    
    <div class="product-preview">
        <img src="@imageUrl" class="product-img" alt="@Model.Name" />
        <div>
            <div class="product-name">@Model.Name</div>
            <div class="product-cat">@Model.CategoryName</div>
            <div class="product-price">৳@Model.Price</div>
        </div>
    </div>
    
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex align-items-center justify-content-center gap-3">
            <a asp-action="Index" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-delete"><i class="bi bi-trash-fill me-2"></i>Yes, Delete Product</button>
        </div>
    </form>
</div>
