@model IEnumerable<ShoesBangladesh.API.ViewModels.ProductViewModel>

@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #ECECEC;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .theme-back-btn {
        background: #F5F5F5;
        color: #2B2B2B;
        border: 1px solid #ECECEC;
        padding: 0.5rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
        transition: 0.2s;
    }
    .theme-back-btn:hover { background: #ECECEC; color: #1F1F1F; }

    .btn-custom-primary {
        background: linear-gradient(135deg, #ff2d2d 0%, #C40000 100%);
        color: white;
        border: none;
        padding: 0.5rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s;
        box-shadow: 0 3px 10px rgba(196,0,0,0.2);
        text-decoration: none;
    }
    .btn-custom-primary:hover {
        background: linear-gradient(135deg, #C40000 0%, #8B0000 100%);
        color: white;
        transform: translateY(-1px);
        text-decoration: none;
    }

    .table-custom {
        width: 100%;
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0;
    }
    .table-custom thead th { background: #1F1F1F !important; color: #FFFFFF !important; font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; border: none; padding: 1.1rem 1rem; white-space: nowrap; }
    .table-custom thead th:first-child { border-top-left-radius: 12px; }
    .table-custom thead th:last-child { border-top-right-radius: 12px; }
    
    .table-custom tbody td {
        padding: 1rem;
        vertical-align: middle;
        font-size: 0.85rem;
        color: #424242;
        border-bottom: 1px solid #ECECEC;
        border-right: 1px solid #ECECEC;
    }
    .table-custom tbody td:first-child { border-left: 1px solid #ECECEC; }
    .table-custom tbody tr:last-child td:first-child { border-bottom-left-radius: 12px; }
    .table-custom tbody tr:last-child td:last-child { border-bottom-right-radius: 12px; }
    
    .table-custom tbody tr:hover td {
        background-color: #FAFAFA;
    }

    .badge-stock-low { background: #FFEBEE; color: #C62828; padding: 0.35rem 0.65rem; border-radius: 6px; font-weight: 700; font-size: 0.75rem; }
    .badge-stock-ok { background: #E8F5E9; color: #2E7D32; padding: 0.35rem 0.65rem; border-radius: 6px; font-weight: 700; font-size: 0.75rem; }

    .badge-status-active { background: #E3F2FD; color: #1565C0; padding: 0.35rem 0.65rem; border-radius: 6px; font-weight: 700; font-size: 0.75rem; }
    .badge-status-inactive { background: #FFF3E0; color: #E65100; padding: 0.35rem 0.65rem; border-radius: 6px; font-weight: 700; font-size: 0.75rem; }

    .img-thumbnail-custom {
        width: 60px;
        height: 60px;
        object-fit: contain;
        border-radius: 8px;
        border: 1px solid #ECECEC;
        background: #FAFAFA;
        padding: 4px;
    }

    .action-btn {
        padding: 0.4rem 0.75rem;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-right: 4px;
        display: inline-block;
        text-decoration: none;
        transition: 0.2s;
    }
    .action-btn-details { background: #F5F5F5; color: #424242; border: 1px solid #E0E0E0; }
    .action-btn-details:hover { background: #E0E0E0; color: #212121; }
    
    .action-btn-edit { background: #E8F5E9; color: #2E7D32; border: 1px solid #C8E6C9; }
    .action-btn-edit:hover { background: #C8E6C9; color: #1B5E20; }

    .action-btn-delete { background: #FFEBEE; color: #C62828; border: 1px solid #FFCDD2; }
    .action-btn-delete:hover { background: #FFCDD2; color: #B71C1C; }

    .filter-input {
        border: 1.5px solid #ECECEC;
        border-radius: 8px;
        padding: 0.55rem 1rem;
        font-size: 0.85rem;
        color: #1F1F1F;
        background: #FAFAFA;
        width: 100%;
        outline: none;
    }
    .filter-input:focus { border-color: #C40000; background: #fff; }
    .badge-count { background: #FFEBEE; color: #C40000; padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 700; margin-left: 10px; vertical-align: middle; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 style="font-size: 1.5rem; font-weight: 800; color: #1F1F1F; margin: 0;"><i class="bi bi-box-seam me-2 text-danger"></i>Products</h1>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Manage your entire product inventory.</p>
    </div>
    <a href="javascript:history.back()" class="theme-back-btn"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0 fw-bold" style="color: #1F1F1F;">All Products <span class="badge-count">@Model.Count() Items</span></h5>
        <a asp-action="Create" class="btn-custom-primary">
            <i class="bi bi-plus-circle me-1"></i> Add New Product
        </a>
    </div>

    <!-- Filter Form Placeholder (Currently just UI, logic can be added later) -->
    <form method="get" asp-action="Index" class="row g-3 mb-4">
        <div class="col-md-3">
            <select class="filter-input" name="categoryId">
                <option value="">All Categories</option>
                <!-- Populate with ViewBag.Categories if available -->
            </select>
        </div>
        <div class="col-md-3">
            <select class="filter-input" name="productTypeId">
                <option value="">All Types</option>
                <option value="Regular">Regular</option>
                <option value="New Arrival">New Arrival</option>
                <option value="Best Seller">Best Seller</option>
                <option value="Clearance">Clearance</option>
            </select>
        </div>
        <div class="col-md-3">
            <input type="text" name="query" class="filter-input" placeholder="Search product name..." />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn-custom-primary flex-grow-1" style="box-shadow: none;">Filter</button>
            <a asp-action="Index" class="theme-back-btn flex-grow-1 text-center" style="padding-top: 0.55rem; text-decoration: none;">Clear Filter</a>
        </div>
    </form>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success d-flex align-items-center mb-4" style="border-radius: 10px; font-size: 0.9rem;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center mb-4" style="border-radius: 10px; font-size: 0.9rem;">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th style="width:60px; text-align: center;">SL No</th>
                    <th style="width:80px; text-align: center;">Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Type</th>
                    <th>Price</th>
                    <th>Offer %</th>
                    <th>Offer Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th>Approval</th>
                    <th style="width: 220px; text-align: center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ var sl = 1; }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-2 d-block mb-2 text-light"></i>
                            No products found.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        var imageUrl = !string.IsNullOrEmpty(item.ImageUrl) 
                            ? (item.ImageUrl.StartsWith("http") ? item.ImageUrl : $"http://localhost:5190{item.ImageUrl}") 
                            : "/images/placeholder.png";

                        <tr>
                            <td class="text-center fw-bold text-muted">@(sl++)</td>
                            <td class="text-center">
                                <img src="@imageUrl" class="img-thumbnail-custom" alt="Product" />
                            </td>
                            <td class="fw-bold" style="color: #2B2B2B;">@item.Name</td>
                            <td class="text-muted">@(string.IsNullOrEmpty(item.CategoryName) ? $"ID: {item.CategoryId}" : item.CategoryName)</td>
                            <td><span class="badge bg-light text-dark border">@item.ProductTypeName</span></td>
                            <td>
                                @if (item.OfferPercentage > 0)
                                {
                                    <del class="text-muted" style="font-size: 0.75rem;">৳@item.Price.ToString("#,##0.00")</del>
                                }
                                else
                                {
                                    <span class="fw-bold text-dark">৳@item.Price.ToString("#,##0.00")</span>
                                }
                            </td>
                            <td>
                                @if (item.OfferPercentage > 0)
                                {
                                    <span class="text-success fw-bold">@item.OfferPercentage%</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.OfferPercentage > 0)
                                {
                                    <span class="fw-bold text-danger">৳@item.DiscountPrice?.ToString("#,##0.00")</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <span class="badge @(item.StockQuantity <= 10 ? "badge-stock-low" : "badge-stock-ok")">
                                    @item.StockQuantity Units
                                </span>
                            </td>
                            <td>
                                <span class="badge @(item.Status == "Active" ? "badge-status-active" : "badge-status-inactive")">
                                    @item.Status
                                </span>
                            </td>
                            <td>
                                @if (item.IsApproved)
                                {
                                    <span class="badge bg-success" style="font-size:0.7rem;"><i class="bi bi-check-circle me-1"></i> Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark" style="font-size:0.7rem;"><i class="bi bi-clock me-1"></i> Pending</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-btn-details" title="Details"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn action-btn-delete" title="Delete"><i class="bi bi-trash3"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
