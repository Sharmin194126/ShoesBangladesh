@model IEnumerable<ShoesBangladesh.API.ViewModels.ProductViewModel>

@{
    ViewData["Title"] = "Inventory Management";
    Layout = "_AdminLayout";
}

<style>
    .product-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
    }

    .product-image-wrapper {
        position: relative;
        height: 200px;
        background: #f8fafc;
        overflow: hidden;
    }

    .product-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover .product-image {
        transform: scale(1.08);
    }

    .badge-premium {
        position: absolute;
        top: 12px;
        right: 12px;
        padding: 0.5rem 0.75rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.7rem;
        text-transform: uppercase;
        backdrop-filter: blur(8px);
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .price-tag {
        font-size: 1.1rem;
        font-weight: 800;
        color: #1e293b;
    }

    .price-old {
        font-size: 0.85rem;
        color: #94a3b8;
        text-decoration: line-through;
    }

    .action-overlay {
        position: absolute;
        bottom: -50px;
        left: 0;
        right: 0;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(4px);
        padding: 0.75rem;
        display: flex;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .product-card:hover .action-overlay {
        bottom: 0;
    }

    .btn-action-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        color: #1e293b;
        border: none;
        transition: all 0.2s;
    }

    .btn-action-icon:hover {
        background: var(--accent-color);
        color: white;
    }

    .empty-state {
        background: white;
        border-radius: 30px;
        padding: 5rem 2rem;
        text-align: center;
        border: 2px dashed #e2e8f0;
    }
</style>

<div class="row align-items-end mb-5">
    <div class="col-md-6">
        <h3 class="fw-bold mb-1">Product Inventory</h3>
        <p class="text-muted mb-0">You have <span class="text-primary fw-bold">@Model.Count()</span> items in your collection.</p>
    </div>
    <div class="col-md-6 text-md-end mt-3 mt-md-0">
        <div class="d-inline-flex gap-2">
            <div class="search-box d-md-block d-none" style="display:block !important;">
                <input type="text" class="form-control rounded-pill px-4" placeholder="Filter products..." style="background: white; border: 1px solid #e2e8f0;">
            </div>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="bi bi-plus-lg me-2"></i> New Product
            </a>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="mb-4">
            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
            </div>
        </div>
        <h4 class="fw-bold">Your inventory is empty</h4>
        <p class="text-muted mb-4">Start adding your beautiful collection of shoes to the platform.</p>
        <a asp-action="Create" class="btn btn-primary px-5 py-3 rounded-pill fw-bold">
            Create First Product
        </a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="product-card">
                    <div class="product-image-wrapper">
                        <img src="http://localhost:5190@(product.ImageUrl)"
                             alt="@product.Name"
                             class="product-image"
                             onerror="this.src='https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=1000&auto=format&fit=crop'" />
                        
                        @if (product.IsEidOffer)
                        {
                            <span class="badge-premium bg-warning text-dark">
                                <i class="bi bi-stars me-1"></i> Eid Offer
                            </span>
                        }
                        
                        <div class="action-overlay">
                            <a asp-action="Edit" asp-route-id="@product.Id" class="btn-action-icon" title="Edit Product">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@product.Id" class="btn-action-icon" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@product.Id" 
                               class="btn-action-icon ms-auto text-danger" 
                               title="Delete Product">
                                <i class="bi bi-trash3"></i>
                            </a>
                        </div>
                    </div>
                    
                    <div class="p-4 flex-grow-1 d-flex flex-column">
                        <div class="mb-2">
                            <h6 class="fw-bold text-truncate mb-1" style="font-size: 1rem;">@product.Name</h6>
                            <div class="d-flex align-items-center gap-2">
                                @if (product.IsFeatured)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary small" style="font-size: 0.65rem;">Featured</span>
                                }
                                <span class="badge bg-light text-muted small" style="font-size: 0.65rem;">Stock: In Stock</span>
                            </div>
                        </div>
                        
                        <p class="text-muted small mb-3 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @product.Description
                        </p>
                        
                        <div class="d-flex align-items-center justify-content-between mt-auto pt-3 border-top">
                            <div class="price-container">
                                @if (product.DiscountPrice.HasValue && product.DiscountPrice > 0)
                                {
                                    <span class="price-tag">৳@product.DiscountPrice</span>
                                    <span class="price-old ms-2">৳@product.Price</span>
                                }
                                else
                                {
                                    <span class="price-tag">৳@product.Price</span>
                                }
                            </div>
                            <div class="text-muted small">
                                <i class="bi bi-tag-fill me-1"></i> Shoes
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
