@model IEnumerable<ShoesBangladesh.API.ViewModels.ProductDTO>

@{
    ViewData["Title"] = "Manage Products";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted small mb-0">Total Products: <strong>@Model.Count()</strong></p>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-semibold">
        <i class="bi bi-plus-lg me-2"></i> Add New Product
    </a>
</div>

@if (!Model.Any())
{
    <div class="card-admin text-center py-5">
        <i class="bi bi-box-seam fs-1 text-muted mb-3 d-block"></i>
        <h5 class="text-muted">No products yet</h5>
        <p class="text-muted small">Add your first product to get started.</p>
        <a asp-action="Create" class="btn btn-primary mt-2 rounded-pill px-4">Add Product</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 rounded-4 shadow-sm h-100 overflow-hidden">
                    <div style="height: 180px; overflow: hidden; background: #f8f9fa;">
                        <img src="http://localhost:5190@product.ImageUrl"
                             alt="@product.Name"
                             style="width: 100%; height: 100%; object-fit: cover;"
                             onerror="this.src='https://placehold.co/300x180?text=No+Image'" />
                    </div>
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="fw-bold mb-0" style="font-size:0.9rem;">@product.Name</h6>
                            @if (product.IsEidOffer)
                            {
                                <span class="badge bg-warning text-dark" style="font-size:0.65rem;">Eid</span>
                            }
                        </div>
                        <p class="text-muted small mb-2" style="font-size:0.75rem; line-height:1.3;">
                            @(product.Description?.Length > 60 ? product.Description.Substring(0, 60) + "..." : product.Description)
                        </p>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            @if (product.DiscountPrice.HasValue && product.DiscountPrice > 0)
                            {
                                <span class="fw-bold text-dark">৳@product.DiscountPrice</span>
                                <span class="text-muted text-decoration-line-through small">৳@product.Price</span>
                            }
                            else
                            {
                                <span class="fw-bold text-dark">৳@product.Price</span>
                            }
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@product.Id"
                               class="btn btn-sm btn-outline-dark flex-fill rounded-3">
                                <i class="bi bi-pencil me-1"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@product.Id"
                               class="btn btn-sm btn-outline-danger rounded-3"
                               onclick="return confirm('Delete this product?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
