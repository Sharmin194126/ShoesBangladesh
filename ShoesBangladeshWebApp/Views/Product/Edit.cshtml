@model ShoesBangladesh.API.ViewModels.ProductViewModel
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <div class="d-flex align-items-center gap-3">
        <h1 style="font-size: 1.4rem; font-weight: 800; color: #1F1F1F; margin: 0;"><i class="bi bi-pencil-square me-2 text-warning"></i>Edit Product</h1>
        <span class="badge bg-light text-dark border">ID: @Model.Id</span>
    </div>
    <nav aria-label="breadcrumb" class="mt-1">
        <ol class="breadcrumb mb-0" style="font-size: 0.78rem;">
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index" style="color:#C40000; text-decoration:none;">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" style="color:#C40000; text-decoration:none;">Products</a></li>
            <li class="breadcrumb-item active" style="color:#9E9E9E;">Edit</li>
        </ol>
    </nav>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center" style="border-radius: 10px;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger d-flex align-items-center" style="border-radius: 10px;">
        <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
    </div>
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" id="productForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <partial name="_ProductForm" model="Model" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            let selectedSizes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AvailableSizes ?? new List<string>()));
            let sizeQuantities = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SizeQuantities ?? new Dictionary<string, int>()));

            // Render existing custom badges if any are not in standard set
            const standardSizes = ["S", "M", "L", "XL", "XXL", "3XL"];
            selectedSizes.forEach(sz => {
                if(!standardSizes.includes(sz)) {
                    let badge = `<div class="size-badge active" data-size="${sz}">${sz} <i class="bi bi-x-circle-fill remove-size"></i></div>`;
                    $(badge).insertBefore('#sizeContainer .input-group');
                }
            });

            function renderSizes() {
                $('#sizeQuantityContainer').empty();
                
                if(selectedSizes.length === 0) {
                    $('#noSizesMsg').show();
                    $('#totalStock').val(0);
                    return;
                }
                
                $('#noSizesMsg').hide();
                let total = 0;

                selectedSizes.forEach(size => {
                    let qty = sizeQuantities[size] || 0;
                    total += parseInt(qty);
                    
                    let row = `
                        <div class="qty-box">
                            <label>Size ${size}</label>
                            <input type="number" min="0" class="size-qty-input" data-size="${size}" value="${qty}" />
                        </div>
                    `;
                    $('#sizeQuantityContainer').append(row);
                });
                
                $('#totalStock').val(total);
                
                // Update hidden JSON fields
                $('#hiddenAvailableSizesJson').val(JSON.stringify(selectedSizes));
                $('#hiddenSizeQuantitiesJson').val(JSON.stringify(sizeQuantities));
            }

            // Click on existing/custom size badge
            $(document).on('click', '.size-badge', function(e) {
                if($(e.target).hasClass('remove-size')) return; // handled separately
                
                let size = $(this).data('size').toString();
                if($(this).hasClass('active')) {
                    $(this).removeClass('active');
                    selectedSizes = selectedSizes.filter(s => s !== size);
                    delete sizeQuantities[size];
                } else {
                    $(this).addClass('active');
                    if(!selectedSizes.includes(size)) {
                        selectedSizes.push(size);
                        sizeQuantities[size] = 0;
                    }
                }
                renderSizes();
            });

            // Remove custom size
            $(document).on('click', '.remove-size', function(e) {
                e.stopPropagation();
                let badge = $(this).closest('.size-badge');
                let size = badge.data('size').toString();
                selectedSizes = selectedSizes.filter(s => s !== size);
                delete sizeQuantities[size];
                badge.remove();
                renderSizes();
            });

            // Add custom size
            $('#btnAddSize').click(function() {
                let newSize = $('#customSizeInput').val().trim();
                if(!newSize) return;
                
                // Check if already exists in badges
                let exists = false;
                $('.size-badge').each(function() {
                    if($(this).data('size').toString().toLowerCase() === newSize.toLowerCase()) exists = true;
                });
                
                if(exists) {
                    Swal.fire({ icon: 'warning', title: 'Already Exists', text: 'This size is already in the list.', confirmButtonColor: '#C40000' });
                    return;
                }
                
                // Create badge and activate it
                let badge = `<div class="size-badge active" data-size="${newSize}">${newSize} <i class="bi bi-x-circle-fill remove-size"></i></div>`;
                $(badge).insertBefore('#sizeContainer .input-group');
                
                selectedSizes.push(newSize);
                sizeQuantities[newSize] = 0;
                
                $('#customSizeInput').val('');
                renderSizes();
            });

            // Enter key on custom size input
            $('#customSizeInput').keypress(function(e) {
                if(e.which === 13) {
                    e.preventDefault();
                    $('#btnAddSize').click();
                }
            });

            // Quantity change
            $(document).on('input', '.size-qty-input', function() {
                let size = $(this).data('size').toString();
                let val = parseInt($(this).val()) || 0;
                if(val < 0) { val = 0; $(this).val(0); }
                sizeQuantities[size] = val;
                
                // Recalculate total
                let total = 0;
                for(let key in sizeQuantities) {
                    total += sizeQuantities[key];
                }
                $('#totalStock').val(total);
                $('#hiddenSizeQuantitiesJson').val(JSON.stringify(sizeQuantities));
            });

            // Auto calculate offer price
            function calcOffer() {
                let price = parseFloat($('#regPrice').val()) || 0;
                let pct = parseFloat($('#offerPct').val()) || 0;
                if(pct > 0 && pct <= 100) {
                    let offPrice = price - (price * pct / 100);
                    $('#offerPrice').val(offPrice.toFixed(2));
                    $('#hiddenDiscountPrice').val(offPrice.toFixed(2));
                } else {
                    $('#offerPrice').val(price.toFixed(2));
                    $('#hiddenDiscountPrice').val(price.toFixed(2));
                }
            }
            $('#regPrice, #offerPct').on('input', calcOffer);

            // Initial render
            renderSizes();
        });

        function previewMainImage(input) {
            const preview = document.getElementById('imagePreview');
            const icon = document.getElementById('imagePreviewIcon');
            if (input.files && input.files[0]) {
                if (input.files[0].size > 300 * 1024) {
                    Swal.fire({
                        icon: 'error',
                        title: 'File Too Large',
                        text: 'Image storage size must be 200-300 kb.',
                        confirmButtonColor: '#C40000'
                    });
                    input.value = '';
                    return;
                }
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    if(icon) icon.style.display = 'none';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function previewAdditionalImages(input) {
            const container = document.getElementById('additionalImagesPreview');
            // Remove previously selected new previews (keep existing db images)
            const oldPreviews = container.querySelectorAll('.new-preview-img');
            oldPreviews.forEach(el => el.remove());
            
            if (input.files) {
                Array.from(input.files).forEach(file => {
                    if (file.size > 300 * 1024) {
                        Swal.fire({
                            icon: 'error',
                            title: 'File Too Large',
                            text: `File "${file.name}" exceeds 300KB.`,
                            confirmButtonColor: '#C40000'
                        });
                        return;
                    }
                    
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const div = document.createElement('div');
                        div.className = 'position-relative new-preview-img';
                        div.style.width = '80px';
                        div.style.height = '80px';
                        div.style.border = '1px solid #eee';
                        div.style.borderRadius = '8px';
                        div.style.overflow = 'hidden';
                        
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.style.width = '100%';
                        img.style.height = '100%';
                        img.style.objectFit = 'cover';
                        
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'btn btn-sm btn-danger position-absolute top-0 end-0 m-1 p-0 d-flex align-items-center justify-content-center';
                        btn.style.width = '20px';
                        btn.style.height = '20px';
                        btn.style.borderRadius = '50%';
                        btn.style.opacity = '0.8';
                        btn.innerHTML = '<i class="bi bi-x" style="font-size: 14px; font-weight: bold;"></i>';
                        btn.onclick = function() {
                            div.remove();
                            const dt = new DataTransfer();
                            Array.from(input.files).forEach(f => {
                                if(f !== file) dt.items.add(f);
                            });
                            input.files = dt.files;
                        };
                        
                        div.appendChild(img);
                        div.appendChild(btn);
                        container.appendChild(div);
                    }
                    reader.readAsDataURL(file);
                });
            }
        }
    </script>
}
