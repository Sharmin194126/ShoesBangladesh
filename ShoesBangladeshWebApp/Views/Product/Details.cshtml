@model ShoesBangladesh.API.ViewModels.ProductViewModel
@{
    ViewData["Title"] = "Product Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var baseUrl = "http://localhost:5190";
    var imageUrl = !string.IsNullOrEmpty(Model.ImageUrl) 
        ? (Model.ImageUrl.StartsWith("http") ? Model.ImageUrl : $"{baseUrl}{Model.ImageUrl}") 
        : "/images/placeholder.png";
}

<style>
    .details-card { background: #fff; border-radius: 16px; border: 1px solid #ECECEC; box-shadow: 0 2px 12px rgba(0,0,0,0.07); padding: 2rem; max-width: 1000px; margin: 0 auto; }
    .product-img-container { width: 100%; height: 350px; border-radius: 12px; background: #FAFAFA; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 1px solid #ECECEC; margin-bottom: 1rem; }
    .product-img { max-width: 100%; max-height: 100%; object-fit: contain; }
    
    .info-label { font-size: 0.8rem; color: #9E9E9E; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; margin-bottom: 4px; }
    .info-value { font-size: 1rem; color: #1F1F1F; font-weight: 600; margin-bottom: 1.25rem; }
    
    .badge-status { padding: 0.4rem 0.8rem; border-radius: 6px; font-weight: 700; font-size: 0.75rem; }
    .badge-active { background: #E8F5E9; color: #2E7D32; }
    .badge-inactive { background: #FFEBEE; color: #C62828; }
    
    .badge-approved { background: #E3F2FD; color: #1565C0; padding: 0.4rem 0.8rem; border-radius: 6px; font-weight: 700; font-size: 0.75rem; }
    .badge-pending { background: #FFF3E0; color: #E65100; padding: 0.4rem 0.8rem; border-radius: 6px; font-weight: 700; font-size: 0.75rem; }
    
    .price-lg { font-size: 1.5rem; color: #C40000; font-weight: 800; }
    .price-strike { font-size: 1rem; color: #9E9E9E; text-decoration: line-through; margin-left: 10px; }

    .theme-back-btn { background: #F5F5F5; color: #2B2B2B; border: 1px solid #ECECEC; padding: 0.65rem 1.5rem; border-radius: 8px; font-weight: 600; font-size: 0.85rem; text-decoration: none; transition: 0.2s; }
    .theme-back-btn:hover { background: #ECECEC; color: #1F1F1F; }

    .btn-success-custom { background: #2E7D32; color: white; border: none; padding: 0.65rem 1.5rem; border-radius: 8px; font-weight: 700; font-size: 0.85rem; text-decoration: none; }
    .btn-success-custom:hover { background: #1B5E20; color: white; }

    .table-inventory th { background: #1F1F1F; color: white; font-size: 0.8rem; text-transform: uppercase; }
    .table-inventory td { font-size: 0.9rem; font-weight: 600; vertical-align: middle; }
</style>

<div class="mb-4">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h1 style="font-size: 1.4rem; font-weight: 800; color: #1F1F1F; margin: 0;"><i class="bi bi-info-circle me-2 text-primary"></i>Product Details</h1>
            <nav aria-label="breadcrumb" class="mt-1">
                <ol class="breadcrumb mb-0" style="font-size: 0.78rem;">
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index" style="color:#C40000; text-decoration:none;">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" style="color:#C40000; text-decoration:none;">Products</a></li>
                    <li class="breadcrumb-item active" style="color:#9E9E9E;">Details</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="details-card">
    <div class="row gx-5">
        <!-- Image Section -->
        <div class="col-md-4">
            <div class="product-img-container">
                <img src="@imageUrl" class="product-img" alt="@Model.Name" />
            </div>
            
            <div class="d-flex gap-2 flex-wrap mb-4">
                <span class="badge-status @(Model.Status == "Active" ? "badge-active" : "badge-inactive")">@Model.Status</span>
                <span class="@(Model.IsApproved ? "badge-approved" : "badge-pending")">@(Model.IsApproved ? "Approved" : "Pending Approval")</span>
            </div>
        </div>

        <!-- Info Section -->
        <div class="col-md-8">
            <div class="row">
                <div class="col-sm-4 info-label">Name</div>
                <div class="col-sm-8 info-value">@Model.Name</div>

                <div class="col-sm-4 info-label">Category</div>
                <div class="col-sm-8 info-value">@Model.CategoryName</div>

                <div class="col-sm-4 info-label">Product Type</div>
                <div class="col-sm-8 info-value">@Model.ProductTypeName</div>

                <div class="col-sm-4 info-label">Price</div>
                <div class="col-sm-8 info-value">
                    @if(Model.OfferPercentage > 0) {
                        <span class="price-lg">৳@Model.DiscountPrice</span>
                        <span class="price-strike">৳@Model.Price</span>
                        <span class="badge bg-danger ms-2" style="border-radius: 4px;">-@Model.OfferPercentage%</span>
                    } else {
                        <span class="price-lg">৳@Model.Price</span>
                    }
                </div>

                <div class="col-sm-4 info-label">Total Stock</div>
                <div class="col-sm-8 info-value">@Model.StockQuantity units</div>
            </div>

            <div class="mt-4">
                <h5 class="fw-bold mb-3" style="font-size: 1rem;"><i class="bi bi-box-seam me-2"></i>Stock Inventory by Size</h5>
                @if (Model.SizeQuantities != null && Model.SizeQuantities.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-inventory">
                            <thead>
                                <tr>
                                    <th style="width: 30%">Size</th>
                                    <th style="width: 40%">Stock Qty</th>
                                    <th style="width: 30%">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sq in Model.SizeQuantities)
                                {
                                    <tr>
                                        <td><span class="badge bg-primary px-3">@sq.Key</span></td>
                                        <td>@sq.Value</td>
                                        <td>
                                            @if (sq.Value > 0)
                                            {
                                                <span class="text-success small fw-bold"><i class="bi bi-check-circle-fill me-1"></i> In Stock</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger small fw-bold"><i class="bi bi-x-circle-fill me-1"></i> Out of Stock</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-light border small py-2"><i class="bi bi-info-circle me-2"></i>No size-specific stock defined.</div>
                }
            </div>

            <div class="row mt-4">
                <div class="col-sm-4 info-label">Description</div>
                <div class="col-sm-8 info-value" style="white-space: pre-wrap;">@Model.Description</div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex justify-content-between border-top pt-4">
        <a asp-action="Index" class="theme-back-btn">Back to List</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-success-custom">Edit</a>
    </div>
</div>
