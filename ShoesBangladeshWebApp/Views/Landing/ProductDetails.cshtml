@model ProductDTO

@{
    ViewData["Title"] = Model.Name + " | Shoes Bangladesh";
    Layout = "_Layout";
}

<style>
    /* Luxury Placeholder Style */
    .image-placeholder {
        background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
        border: 2px dashed rgba(0, 0, 0, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(0, 0, 0, 0.2);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.8rem;
    }

    .details-page {
        padding-top: 4rem;
        background: white;
    }

    .gallery-container {
        position: sticky;
        top: 120px;
    }

    .main-img-box {
        background: #f8fafc;
        border-radius: 40px;
        height: 500px;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

    .thumb-strip {
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    .thumb-item {
        width: 80px;
        height: 80px;
        border-radius: 16px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.3s;
    }

    .thumb-item.active {
        border-color: #6366f1;
    }

    .product-details-content {
        padding-left: 2rem;
    }

    .product-title-large {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }

    .price-now {
        font-size: 2.5rem;
        font-weight: 800;
        color: #0f172a;
    }

    .btn-buy-primary {
        background: #0f172a;
        color: white;
        padding: 1.25rem 2rem;
        border-radius: 100px;
        font-weight: 700;
        border: none;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        width: 100%;
    }

    .btn-buy-primary:hover {
        background: #6366f1;
        transform: translateY(-2px);
    }

    @@media (max-width: 991px) {
        .product-details-content { padding-left: 0; margin-top: 3rem; }
        .product-title-large { font-size: 2.5rem; }
    }
</style>

<div class="details-page">
    <div class="container">
        <div class="row">
            <!-- Left: Gallery Placeholder -->
            <div class="col-lg-7">
                <div class="gallery-container">
                    <nav class="breadcrumb-custom mb-4">
                        <a asp-action="Index" class="text-muted text-decoration-none">Collection</a>
                        <span class="mx-2">/</span>
                        <span class="text-dark">@Model.Name</span>
                    </nav>

                    <div class="main-img-box image-placeholder">
                        Main Product Image Placeholder
                    </div>

                    <div class="thumb-strip">
                        <div class="thumb-item active image-placeholder">P1</div>
                        <div class="thumb-item image-placeholder">P2</div>
                        <div class="thumb-item image-placeholder">P3</div>
                    </div>
                </div>
            </div>

            <!-- Right: Details -->
            <div class="col-lg-5">
                <div class="product-details-content">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-bold">NEW ARRIVAL</span>
                    </div>

                    <h1 class="product-title-large">@Model.Name</h1>
                    
                    <div class="price-display mb-4">
                        <span class="price-now">৳@(Model.DiscountPrice ?? Model.Price)</span>
                    </div>

                    <p class="text-muted mb-5 leading-relaxed">@Model.Description</p>

                    <div class="d-grid gap-3">
                        <button class="btn-buy-primary btn-lg">
                            <i class="bi bi-bag-plus-fill"></i> ADD TO SHOPPING BAG
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
