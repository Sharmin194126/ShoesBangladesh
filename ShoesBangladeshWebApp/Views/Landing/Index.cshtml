@model ShoesBangladesh.API.ViewModels.LandingPageResponse

@{
    ViewData["Title"] = "Premium Footwear Collection";
    Layout = "_Layout";
}

<style>
    /* Hero Section */
    .hero-v2 {
        position: relative;
        min-height: 90vh;
        background: #0f172a;
        overflow: hidden;
        display: flex;
        align-items: center;
        color: white;
    }

    .hero-v2::after {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 50%;
        height: 100%;
        background: linear-gradient(to right, #0f172a, transparent), url('https://images.unsplash.com/photo-1549298916-b41d501d3772?q=80&w=2012&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        opacity: 0.6;
    }

    .hero-content {
        position: relative;
        z-index: 10;
        max-width: 700px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(99, 102, 241, 0.1);
        border: 1px solid rgba(99, 102, 241, 0.2);
        padding: 8px 20px;
        border-radius: 100px;
        color: #818cf8;
        font-weight: 700;
        font-size: 0.85rem;
        margin-bottom: 2rem;
    }

    .hero-title {
        font-size: 5rem;
        font-weight: 900;
        line-height: 0.95;
        letter-spacing: -0.04em;
        margin-bottom: 1.5rem;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        color: #94a3b8;
        margin-bottom: 2.5rem;
        line-height: 1.6;
    }

    /* Product Grid */
    .section-padding {
        padding: 8rem 0;
    }

    .section-title {
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
    }

    .item-card {
        background: #f8fafc;
        border-radius: 32px;
        padding: 1.5rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
        border: 1px solid transparent;
        position: relative;
    }

    .item-card:hover {
        background: white;
        border-color: #e2e8f0;
        box-shadow: 0 30px 60px -12px rgba(0,0,0,0.08);
        transform: translateY(-10px);
    }

    .item-img-container {
        height: 300px;
        border-radius: 24px;
        overflow: hidden;
        background: white;
        margin-bottom: 1.5rem;
        position: relative;
    }

    .item-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transition: transform 0.6s ease;
        padding: 2rem;
    }

    .item-card:hover .item-img {
        transform: scale(1.1) rotate(-5deg);
    }

    .item-tag {
        position: absolute;
        top: 20px;
        left: 20px;
        background: #0f172a;
        color: white;
        padding: 6px 16px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 0.75rem;
    }

    .price-large {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
    }

    .price-strike {
        text-decoration: line-through;
        color: #94a3b8;
        font-size: 0.95rem;
        margin-left: 10px;
    }

    .btn-buy {
        width: 45px;
        height: 45px;
        background: #0f172a;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        text-decoration: none;
    }

    .btn-buy:hover {
        background: #6366f1;
        color: white;
    }

    /* Countdown */
    .timer-container {
        background: #6366f1;
        border-radius: 24px;
        padding: 3rem;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: -5rem;
        position: relative;
        z-index: 20;
        box-shadow: 0 20px 40px rgba(99, 102, 241, 0.3);
    }

    .time-unit {
        text-align: center;
    }

    .time-val {
        font-size: 3.5rem;
        font-weight: 900;
        display: block;
        line-height: 1;
    }

    .time-lbl {
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        opacity: 0.8;
    }

    /* Responsive */
    @media (max-width: 991px) {
        .hero-title { font-size: 3.5rem; }
        .hero-v2::after { display: none; }
        .timer-container { flex-direction: column; gap: 2rem; text-align: center; }
    }
</style>

<div class="landing-v2">
    <!-- Hero -->
    <section class="hero-v2">
        <div class="container">
            <div class="hero-content">
                <div class="hero-badge">
                    <i class="bi bi-patch-check-fill"></i>
                    <span>Official Eid Collection @(Model.Settings.DiscountPercentage)% Discount</span>
                </div>
                <h1 class="hero-title">@Model.Settings.EidOfferTitle</h1>
                <p class="hero-subtitle">@Model.Settings.EidOfferSubtitle</p>
                
                <div class="d-flex gap-3">
                    <a href="#collection" class="btn btn-primary px-5 py-3 rounded-pill fw-bold">Explore Now</a>
                    <a href="#" class="btn btn-outline-light px-5 py-3 rounded-pill fw-bold">Watch Film</a>
                </div>

                <div class="mt-5 d-flex gap-4 align-items-center opacity-75">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-truck fs-4"></i>
                        <span class="small fw-600">Free Express Delivery</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-arrow-repeat fs-4"></i>
                        <span class="small fw-600">30-Day Returns</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <!-- Countdown -->
        <div class="timer-container">
            <div>
                <h4 class="fw-800 mb-1">Limited Time Eid Offer</h4>
                <p class="mb-0 opacity-75">Hurry up! The campaign is ending soon.</p>
            </div>
            <div class="d-flex gap-4" id="countdown" data-endtime="@Model.Settings.EidOfferEndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                <div class="time-unit">
                    <span class="time-val" id="days">00</span>
                    <span class="time-lbl">Days</span>
                </div>
                <div class="time-unit">
                    <span class="time-val" id="hours">00</span>
                    <span class="time-lbl">Hours</span>
                </div>
                <div class="time-unit">
                    <span class="time-val" id="minutes">00</span>
                    <span class="time-lbl">Mins</span>
                </div>
                <div class="time-unit">
                    <span class="time-val" id="seconds">00</span>
                    <span class="time-lbl">Secs</span>
                </div>
            </div>
            <a href="#collection" class="btn btn-white bg-white text-primary px-5 py-3 rounded-pill fw-bold shadow-sm">Claim Now</a>
        </div>

        <!-- Collection -->
        <section class="section-padding" id="collection">
            <div class="row align-items-end mb-5">
                <div class="col-lg-6">
                    <h2 class="section-title">New Arrivals</h2>
                    <p class="text-muted">@Model.Settings.ProductSectionDescription</p>
                </div>
                <div class="col-lg-6 text-lg-end">
                    <div class="d-inline-flex gap-2 p-1 bg-light rounded-pill">
                        <button class="btn btn-primary rounded-pill px-4">All</button>
                        <button class="btn btn-light rounded-pill px-4">Formal</button>
                        <button class="btn btn-light rounded-pill px-4">Casual</button>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                @foreach (var product in Model.Products)
                {
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <div class="item-card">
                            @if (product.IsEidOffer)
                            {
                                <div class="item-tag">Eid Special</div>
                            }
                            <div class="item-img-container">
                                <a asp-action="ProductDetails" asp-route-id="@product.Id">
                                    <img src="http://localhost:5190@product.ImageUrl" 
                                         alt="@product.Name" 
                                         class="item-img"
                                         onerror="this.src='https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?q=80&w=1000&auto=format&fit=crop'">
                                </a>
                            </div>
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="fw-bold mb-1">@product.Name</h6>
                                    <p class="small text-muted mb-3">Premium Lifestyle Shoe</p>
                                    <div class="d-flex align-items-center">
                                        <span class="price-large">৳@(product.DiscountPrice ?? product.Price)</span>
                                        @if (product.DiscountPrice.HasValue)
                                        {
                                            <span class="price-strike">৳@product.Price</span>
                                        }
                                    </div>
                                </div>
                                <a asp-action="ProductDetails" asp-route-id="@product.Id" class="btn-buy">
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        const countdownEl = document.getElementById('countdown');
        if (countdownEl) {
            const endTimeStr = countdownEl.getAttribute('data-endtime');
            const endTime = new Date(endTimeStr).getTime();

            const updateCountdown = () => {
                const now = new Date().getTime();
                const distance = endTime - now;

                if (distance < 0) {
                    countdownEl.innerHTML = "<h4 class='mb-0'>Offer Expired</h4>";
                    return;
                }

                const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                document.getElementById('days').innerText = days.toString().padStart(2, '0');
                document.getElementById('hours').innerText = hours.toString().padStart(2, '0');
                document.getElementById('minutes').innerText = minutes.toString().padStart(2, '0');
                document.getElementById('seconds').innerText = seconds.toString().padStart(2, '0');
            };

            setInterval(updateCountdown, 1000);
            updateCountdown();
        }
    </script>
}
