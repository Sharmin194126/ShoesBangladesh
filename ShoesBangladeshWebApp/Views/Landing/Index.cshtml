@model LandingPageResponse

@{
    ViewData["Title"] = Model.Settings.EidOfferTitle;
    Layout = "_LandingLayout";
    string apiBase = "http://localhost:5190";
    
    string ResolveUrl(string url) {
        if (string.IsNullOrEmpty(url)) return "";
        if (url.StartsWith("http")) return url;
        return apiBase + (url.StartsWith("/") ? "" : "/") + url;
    }
}

<style>
    /* Typography */
    .font-luxury { font-family: 'Playfair Display', serif; }
    
    /* Hero Section */
    .hero-luxury {
        position: relative;
        min-height: 85vh;
        display: flex;
        align-items: center;
        background-color: #0a0a0a;
        background-image: linear-gradient(135deg, rgba(74, 0, 0, 0.7) 0%, rgba(10, 10, 10, 0.8) 100%), url('@ResolveUrl(Model.Settings.HeroBgImageUrl)');
        background-size: 100% 100%; /* Ensuring full image shows without side bars, stretching to fill */
        background-repeat: no-repeat;
        background-position: center;
        overflow: hidden;
    }

    .hero-container {
        position: relative;
        z-index: 10;
        width: 100%;
        padding: 4rem;
    }

    .landing-logo {
        position: absolute;
        top: 2rem;
        left: 4rem;
        height: 60px;
        z-index: 100;
    }

    .hero-tagline {
        color: var(--gold-accent);
        font-weight: 800;
        letter-spacing: 5px;
        text-transform: uppercase;
        margin-bottom: 1rem;
        display: block;
        animation: fadeInDown 1s ease;
    }

    .hero-headline {
        font-size: 2.8rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        background: linear-gradient(to right, #fff, #d4af37);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: fadeInLeft 1.2s ease;
    }

    .discount-text {
        font-size: 2.2rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 2rem;
        text-shadow: 0 10px 20px rgba(0,0,0,0.3);
    }

    .hero-shoe-image {
        position: absolute;
        right: 8%;
        top: 50%;
        transform: translateY(-50%);
        width: 35%;
        max-height: 400px;
        object-fit: contain;
        z-index: 15;
        animation: float 4s ease-in-out infinite;
        filter: drop-shadow(0 20px 50px rgba(0,0,0,0.5));
    }

    /* Countdown Timer */
    .countdown-wrapper {
        display: flex;
        gap: 1rem;
        margin-bottom: 3rem;
    }

    .timer-box {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(212, 175, 55, 0.3);
        padding: 1rem;
        border-radius: 15px;
        min-width: 80px;
        text-align: center;
        transition: var(--transition);
    }

    .timer-val {
        font-size: 1.8rem;
        font-weight: 900;
        display: block;
        color: var(--gold-accent);
    }
    .timer-label { font-size: 0.7rem; text-transform: uppercase; color: rgba(255,255,255,0.6); letter-spacing: 1px; }

    /* Banner Section (Classic Red) */
    .banner-grid {
        padding: 6rem 4rem;
        background: #0a0a0a;
    }

    .sale-card {
        position: relative;
        height: 450px;
        border-radius: 30px;
        overflow: hidden;
        background: #151515;
        border: 1px solid rgba(255,255,255,0.05);
        transition: var(--transition);
    }

    .banner-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .sale-content {
        position: absolute;
        bottom: 0;
        left: 0;
        padding: 3rem;
        width: 100%;
        background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
        color: #fff;
    }

    .offer-card-luxury {
        background: var(--premium-red);
        height: 100%;
        border-radius: 30px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 3rem;
        text-align: center;
        color: #fff;
        border: 1px solid var(--gold-accent);
    }

    /* Product Section */
    .product-section {
        background: #0f0f0f;
        padding: 6rem 4rem;
    }

    .luxury-card {
        background: #1a1a1a;
        border-radius: 30px;
        padding: 1.5rem;
        border: 1px solid rgba(255,255,255,0.05);
        transition: var(--transition);
        height: 100%;
        color: #fff;
        display: flex;
        flex-direction: column;
    }
    .luxury-card:hover {
        border-color: var(--gold-accent);
        transform: translateY(-10px);
    }

    .product-img-wrapper {
        width: 100%;
        height: 220px;
        border-radius: 20px;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }
    .product-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .rating-stars { color: #ffc107; font-size: 0.85rem; margin-bottom: 0.8rem; }

    .btn-shop-mini {
        width: 100%;
        padding: 0.8rem;
        border-radius: 15px;
        background: var(--premium-red);
        color: white;
        border: none;
        font-weight: 700;
        transition: var(--transition);
        text-decoration: none;
        display: block;
        text-align: center;
        margin-top: auto;
        animation: bounceUpDown 2s infinite ease-in-out;
    }

    /* Footer */
    .premium-footer {
        background: #050505; /* Reverting to original dark charcoal/black */
        color: #fff;
        padding: 5rem 4rem 2rem;
        border-top: 1px solid rgba(212, 175, 55, 0.1);
    }
    .footer-logo { height: 50px; margin-bottom: 1.5rem; }
    .footer-link { color: rgba(255,255,255,0.6); text-decoration: none; transition: 0.3s; margin-bottom: 0.8rem; display: block; }
    .footer-link:hover { color: var(--gold-accent); padding-left: 5px; }
    .footer-title { color: #fff; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1.5rem; font-size: 1rem; }

    /* Shop Now Button */
    .btn-luxury-shop {
        background: linear-gradient(135deg, var(--premium-red), #800000);
        color: #fff;
        padding: 1.25rem 3.5rem;
        border-radius: 100px;
        font-weight: 800;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        border: 2px solid var(--gold-accent);
        box-shadow: 0 0 30px rgba(208, 0, 0, 0.4);
        position: relative;
        transition: var(--transition);
        display: inline-block;
        text-decoration: none;
        animation: bounceUpDown 2s infinite ease-in-out;
    }

    /* Animations */
    @@keyframes float {
        0%, 100% { transform: translateY(-50%) translateX(0); }
        50% { transform: translateY(-55%) translateX(-15px); }
    }

    @@keyframes bounceUpDown {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    @@media (max-width: 1200px) {
        .hero-headline { font-size: 2.2rem; }
        .hero-shoe-image { display: none; }
        .hero-luxury { background-size: cover; padding: 6rem 0; }
        .hero-container, .landing-logo { padding-left: 2rem; padding-right: 2rem; left: 0; }
        .banner-grid, .product-section, .premium-footer { padding: 4rem 2rem; }
    }
</style>

<div class="landing-v3">
    <!-- Header Logo -->
    @if (!string.IsNullOrEmpty(Model.Settings.LogoUrl))
    {
        <img src="@ResolveUrl(Model.Settings.LogoUrl)" class="landing-logo" alt="Company Logo">
    }

    <!-- Hero Section -->
    <section class="hero-luxury">
        <div class="hero-container">
            <span class="hero-tagline">Exclusively for @Model.Settings.CompanyName</span>
            <h1 class="hero-headline font-luxury">@Model.Settings.EidOfferTitle</h1>
            <div class="discount-text">UP TO @Model.Settings.DiscountPercentage% OFF</div>
            
            @if (Model.Settings.IsOfferActive)
            {
                <div class="countdown-wrapper" id="eid-countdown" data-endtime="@Model.Settings.EidOfferEndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                    <div class="timer-box">
                        <span class="timer-val" id="c-days">00</span>
                        <span class="timer-label">Days</span>
                    </div>
                    <div class="timer-box">
                        <span class="timer-val" id="c-hours">00</span>
                        <span class="timer-label">Hours</span>
                    </div>
                    <div class="timer-box">
                        <span class="timer-val" id="c-minutes">00</span>
                        <span class="timer-label">Mins</span>
                    </div>
                    <div class="timer-box">
                        <span class="timer-val" id="c-seconds">00</span>
                        <span class="timer-label">Secs</span>
                    </div>
                </div>
            }

            <p class="mb-4 text-white-50 fw-bold" style="max-width: 600px;">@Model.Settings.EidOfferSubtitle</p>

            <a href="#featured" class="btn-luxury-shop">Shop Now</a>
        </div>

        <img src="@ResolveUrl(Model.Settings.HeroImageUrl)" class="hero-shoe-image" alt="Hero Product">
    </section>

    <!-- Banner Section (Classic Series) -->
    <section class="banner-grid">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="sale-card">
                    <img src="@ResolveUrl(Model.Settings.BannerImageUrl)" class="banner-img" alt="Classic Series">
                    <div class="sale-content">
                        <span class="badge bg-gold-accent mb-2" style="background: var(--gold-accent); color: #000; font-weight: 800;">LIMITED EDITION</span>
                        <h2 class="font-luxury fs-1">@Model.Settings.BannerTitle</h2>
                        <p>@Model.Settings.BannerDescription</p>
                        <a href="#featured" class="btn btn-outline-light rounded-pill px-4">Discover</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="offer-card-luxury">
                    <h1 class="display-2 fw-900 mb-0">@Model.Settings.OfferCardTitle</h1>
                    <p class="fs-4 fw-bold mb-4">@Model.Settings.OfferCardSubtitle</p>
                    <div class="border-top border-white border-opacity-50 pt-4 w-100">
                        <p class="mb-0 small opacity-75">PROMO CODE</p>
                        <h4 class="fw-bold">@Model.Settings.OfferCardCouponCode</h4>
                    </div>
                    <a href="#featured" class="btn btn-dark rounded-pill mt-4 px-5">Claim Now</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Products -->
    <section class="product-section" id="featured">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="font-luxury display-5 text-white">Exclusive Collection</h2>
                <p class="text-white-50">@Model.Settings.ProductSectionDescription</p>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="luxury-card">
                        <div class="product-img-wrapper">
                            <img src="@ResolveUrl(product.ImageUrl)" alt="@product.Name">
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-white-50 small">@product.CategoryName</span>
                            <span class="badge bg-danger">TRENDING</span>
                        </div>
                        
                        <h5 class="fw-bold mb-2">@product.Name</h5>

                        <div class="rating-stars">
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-half"></i>
                            <span class="text-white-50 ms-1 small">(4.8)</span>
                        </div>
                        
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <span class="fs-4 fw-bold text-white">৳@(product.DiscountPrice ?? product.Price)</span>
                            @if (product.DiscountPrice.HasValue)
                            {
                                <span class="text-white-50 text-decoration-line-through">৳@product.Price</span>
                            }
                        </div>

                        <a asp-action="ProductDetails" asp-route-id="@product.Id" class="btn-shop-mini">Order Now</a>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Premium Footer -->
    <footer class="premium-footer">
        <div class="row g-4">
            <div class="col-lg-4">
                @if (!string.IsNullOrEmpty(Model.Settings.LogoUrl))
                {
                    <img src="@ResolveUrl(Model.Settings.LogoUrl)" class="footer-logo" alt="Logo">
                }
                <p class="text-white-50 pe-lg-5">@Model.Settings.CompanyDescription</p>
                <div class="d-flex gap-3 mt-4">
                    <a href="@Model.Settings.FacebookPageLink" class="btn btn-outline-light btn-sm rounded-circle"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle"><i class="bi bi-whatsapp"></i></a>
                </div>
            </div>
            <div class="col-lg-2">
                <h6 class="footer-title">Quick Links</h6>
                <a href="#" class="footer-link">New Arrivals</a>
                <a href="#" class="footer-link">Special Offers</a>
                <a href="#" class="footer-link">Order Tracking</a>
                <a href="#" class="footer-link">Contact Us</a>
            </div>
            <div class="col-lg-2">
                <h6 class="footer-title">Policy</h6>
                <a href="#" class="footer-link">Privacy Policy</a>
                <a href="#" class="footer-link">Return Policy</a>
                <a href="#" class="footer-link">Terms & Conditions</a>
                <a href="#" class="footer-link">Shipping Guide</a>
            </div>
            <div class="col-lg-4">
                <h6 class="footer-title">Contact Support</h6>
                <p class="text-white-50 mb-1"><i class="bi bi-geo-alt-fill text-danger me-2"></i> Dhaka, Bangladesh</p>
                <p class="text-white-50 mb-1"><i class="bi bi-envelope-fill text-danger me-2"></i> @Model.Settings.ContactEmail</p>
                <p class="text-white-50 mb-1"><i class="bi bi-telephone-fill text-danger me-2"></i> @Model.Settings.Phone</p>
            </div>
        </div>
        <div class="text-center mt-5 pt-4 border-top border-white border-opacity-10 text-white-50 small">
            &copy; @DateTime.Now.Year @Model.Settings.CompanyName. All Rights Reserved. Designed for Premium Experience.
        </div>
    </footer>
</div>

@section Scripts {
    <script>
        function updateEidTimer() {
            const timerEl = document.getElementById('eid-countdown');
            if (!timerEl) return;

            const endTime = new Date(timerEl.getAttribute('data-endtime')).getTime();
            const now = new Date().getTime();
            const diff = endTime - now;

            if (diff < 0) {
                timerEl.innerHTML = "<h3 class='text-gold-accent'>OFFER EXPIRED</h3>";
                return;
            }

            const d = Math.floor(diff / (1000 * 60 * 60 * 24));
            const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((diff % (1000 * 60)) / 1000);

            document.getElementById('c-days').innerText = d.toString().padStart(2, '0');
            document.getElementById('c-hours').innerText = h.toString().padStart(2, '0');
            document.getElementById('c-minutes').innerText = m.toString().padStart(2, '0');
            document.getElementById('c-seconds').innerText = s.toString().padStart(2, '0');
        }

        setInterval(updateEidTimer, 1000);
        updateEidTimer();
    </script>
}
