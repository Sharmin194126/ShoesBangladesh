@model LandingPageResponse

@{
    ViewData["Title"] = Model.Settings.EidOfferTitle;
    Layout = "_LandingLayout";
}

<style>
    :root {
        --premium-red: #C40000;
        --gold-accent: #D4AF37;
        --deep-black: #0A0A0A;
        --charcoal: #1F1F1F;
    }

    /* Typography */
    .font-luxury { font-family: 'Playfair Display', serif; }
    
    /* Hero Section */
    .hero-luxury {
        position: relative;
        height: 100vh;
        display: flex;
        align-items: center;
        background-image: url('@Model.Settings.HeroBgImageUrl');
        background-size: cover;
        background-position: center;
        overflow: hidden;
    }
    .hero-luxury::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.4) 100%);
        z-index: 1;
    }

    .hero-container {
        position: relative;
        z-index: 10;
        width: 100%;
        padding: 0 4rem;
    }

    .hero-tagline {
        color: var(--gold-accent);
        font-weight: 800;
        letter-spacing: 5px;
        text-transform: uppercase;
        margin-bottom: 1rem;
        display: block;
    }

    .hero-headline {
        font-size: 5rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: #fff;
    }

    .discount-text {
        font-size: 3rem;
        font-weight: 800;
        color: var(--gold-accent);
        margin-bottom: 2rem;
    }

    .hero-shoe-image {
        position: absolute;
        right: 5%;
        top: 50%;
        transform: translateY(-50%);
        width: 45%;
        max-height: 600px;
        object-fit: contain;
        z-index: 15;
        filter: drop-shadow(0 20px 50px rgba(0,0,0,0.5));
        animation: float 4s ease-in-out infinite;
    }

    /* Countdown Timer */
    .countdown-wrapper {
        display: flex;
        gap: 1rem;
        margin-bottom: 3rem;
    }

    .timer-box {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(212, 175, 55, 0.3);
        padding: 1rem;
        border-radius: 15px;
        min-width: 90px;
        text-align: center;
    }

    .timer-val {
        font-size: 2rem;
        font-weight: 900;
        display: block;
        color: #fff;
    }
    .timer-label { font-size: 0.7rem; text-transform: uppercase; color: var(--gold-accent); font-weight: 700; }

    .btn-luxury-shop {
        background: var(--premium-red);
        color: #fff;
        padding: 1.25rem 3.5rem;
        border-radius: 100px;
        font-weight: 800;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 10px 30px rgba(196, 0, 0, 0.4);
        display: inline-block;
        text-decoration: none;
        transition: all 0.3s;
    }
    .btn-luxury-shop:hover { transform: scale(1.05); color: #fff; box-shadow: 0 15px 40px rgba(196, 0, 0, 0.6); }

    /* Product Grid */
    .product-section { background: #0a0a0a; padding: 6rem 4rem; }
    .luxury-card {
        background: #151515;
        border-radius: 25px;
        padding: 1.25rem;
        border: 1px solid rgba(255,255,255,0.05);
        transition: all 0.3s;
        height: 100%;
        color: #fff;
    }
    .luxury-card:hover { transform: translateY(-10px); border-color: var(--gold-accent); }
    .product-img-wrapper {
        width: 100%;
        height: 250px;
        border-radius: 20px;
        margin-bottom: 1.25rem;
        overflow: hidden;
        background: #000;
    }
    .product-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }

    .btn-shop-mini {
        width: 100%;
        padding: 0.75rem;
        border-radius: 12px;
        background: var(--premium-red);
        color: white;
        border: none;
        font-weight: 700;
        text-decoration: none;
        display: block;
        text-align: center;
        margin-top: 1.25rem;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(-50%) rotate(0deg); }
        50% { transform: translateY(-55%) rotate(-5deg); }
    }

    @@media (max-width: 992px) {
        .hero-headline { font-size: 3rem; }
        .hero-shoe-image { display: none; }
        .hero-container { padding: 0 2rem; }
    }
</style>

<div class="landing-page">
    <!-- Hero Section -->
    <section class="hero-luxury">
        <div class="hero-container">
            <span class="hero-tagline">Exclusively for @Model.Settings.CompanyName</span>
            <h1 class="hero-headline font-luxury">@Model.Settings.EidOfferTitle</h1>
            <div class="discount-text">UP TO @Model.Settings.DiscountPercentage% OFF</div>
            
            @if (Model.Settings.IsOfferActive)
            {
                <div class="countdown-wrapper" id="eid-countdown" data-endtime="@Model.Settings.EidOfferEndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                    <div class="timer-box">
                        <span class="timer-val" id="c-hours">00</span>
                        <span class="timer-label">Hours</span>
                    </div>
                    <div class="timer-box">
                        <span class="timer-val" id="c-minutes">00</span>
                        <span class="timer-label">Mins</span>
                    </div>
                    <div class="timer-box">
                        <span class="timer-val" id="c-seconds">00</span>
                        <span class="timer-label">Secs</span>
                    </div>
                </div>
            }

            <p class="text-white-50 mb-5 max-w-500">@Model.Settings.EidOfferSubtitle</p>

            <a href="#featured" class="btn-luxury-shop">Claim Your Offer</a>
        </div>

        <img src="@Model.Settings.HeroImageUrl" class="hero-shoe-image" alt="Featured Product">
    </section>

    <!-- Product Grid -->
    <section class="product-section" id="featured">
        <div class="text-center mb-5">
            <h2 class="font-luxury display-4 text-white">Exclusive Collection</h2>
            <div class="mx-auto" style="width: 60px; height: 3px; background: var(--gold-accent); margin: 1.5rem auto;"></div>
            <p class="text-white-50">@Model.Settings.ProductSectionDescription</p>
        </div>

        <div class="row g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="luxury-card">
                        <div class="product-img-wrapper">
                            <img src="@product.ImageUrl" alt="@product.Name">
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-white-50 small">@product.CategoryName</span>
                            <span class="badge bg-danger" style="font-size: 0.6rem;">HOT</span>
                        </div>
                        <h5 class="fw-bold mb-3">@product.Name</h5>
                        <div class="d-flex align-items-center gap-3">
                            <span class="fs-4 fw-bold text-white">৳@(product.DiscountPrice ?? product.Price)</span>
                            @if (product.DiscountPrice.HasValue)
                            {
                                <span class="text-white-50 text-decoration-line-through small">৳@product.Price</span>
                            }
                        </div>
                        <a asp-action="ProductDetails" asp-route-id="@product.Id" class="btn-shop-mini">Order Now</a>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-black text-white py-5 px-4 border-top border-dark">
        <div class="container text-center">
            <h3 class="font-luxury mb-4">@Model.Settings.CompanyName</h3>
            <p class="text-white-50 mb-4 mx-auto" style="max-width: 600px;">@Model.Settings.CompanyDescription</p>
            <div class="d-flex justify-content-center gap-4 mb-4">
                <a href="@Model.Settings.FacebookPageLink" class="text-white fs-4"><i class="bi bi-facebook"></i></a>
                <a href="#" class="text-white fs-4"><i class="bi bi-instagram"></i></a>
                <a href="#" class="text-white fs-4"><i class="bi bi-whatsapp"></i></a>
            </div>
            <p class="small text-muted">&copy; @DateTime.Now.Year @Model.Settings.CompanyName. All rights reserved.</p>
        </div>
    </footer>
</div>

@section Scripts {
    <script>
        function updateEidTimer() {
            const timerEl = document.getElementById('eid-countdown');
            if (!timerEl) return;

            const endTime = new Date(timerEl.getAttribute('data-endtime')).getTime();
            const now = new Date().getTime();
            const diff = endTime - now;

            if (diff < 0) {
                timerEl.innerHTML = "<h3 class='text-gold-accent'>OFFER EXPIRED</h3>";
                return;
            }

            const h = Math.floor(diff / (1000 * 60 * 60));
            const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((diff % (1000 * 60)) / 1000);

            document.getElementById('c-hours').innerText = h.toString().padStart(2, '0');
            document.getElementById('c-minutes').innerText = m.toString().padStart(2, '0');
            document.getElementById('c-seconds').innerText = s.toString().padStart(2, '0');
        }
        setInterval(updateEidTimer, 1000);
        updateEidTimer();
    </script>
}
>
}
