@model LandingPageResponse

@{
    ViewData["Title"] = Model.Settings.EidOfferTitle;
    Layout = "_LandingLayout";
    string apiBase = "http://localhost:5190";
    
    string ResolveUrl(string url) {
        if (string.IsNullOrEmpty(url)) return "";
        if (url.StartsWith("http")) return url;
        return apiBase + (url.StartsWith("/") ? "" : "/") + url;
    }
}

<style>
    /* Typography */
    .font-luxury { font-family: 'Playfair Display', serif; }
    
    /* Hero Section */
    .hero-luxury {
        position: relative;
        height: 100vh;
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, rgba(74, 0, 0, 0.9) 0%, rgba(10, 10, 10, 0.9) 100%), url('@ResolveUrl(Model.Settings.HeroBgImageUrl)');
        background-size: cover;
        background-position: center;
        overflow: hidden;
    }

    .hero-container {
        position: relative;
        z-index: 10;
        width: 100%;
        padding: 0 4rem;
    }

    .hero-tagline {
        color: var(--gold-accent);
        font-weight: 800;
        letter-spacing: 5px;
        text-transform: uppercase;
        margin-bottom: 1rem;
        display: block;
        animation: fadeInDown 1s ease;
    }

    .hero-headline {
        font-size: 5rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        background: linear-gradient(to right, #fff, #d4af37);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: fadeInLeft 1.2s ease;
    }

    .discount-text {
        font-size: 3rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 2rem;
        text-shadow: 0 10px 20px rgba(0,0,0,0.3);
    }

    .hero-shoe-image {
        position: absolute;
        right: 5%;
        top: 50%;
        transform: translateY(-50%);
        width: 45%;
        max-height: 500px;
        object-fit: contain;
        z-index: 15;
        animation: float 4s ease-in-out infinite;
        filter: drop-shadow(0 20px 50px rgba(0,0,0,0.5));
    }

    /* Countdown Timer */
    .countdown-wrapper {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .timer-box {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(212, 175, 55, 0.3);
        padding: 1.25rem;
        border-radius: 20px;
        min-width: 90px;
        text-align: center;
        transition: var(--transition);
    }

    .timer-val {
        font-size: 2rem;
        font-weight: 900;
        display: block;
        color: var(--gold-accent);
    }

    /* Banner Section (Classic Red) */
    .banner-grid {
        padding: 6rem 4rem;
        background: #0a0a0a;
    }

    .sale-card {
        position: relative;
        height: 450px;
        border-radius: 30px;
        overflow: hidden;
        background: #151515;
        border: 1px solid rgba(255,255,255,0.05);
        transition: var(--transition);
    }

    .banner-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .sale-content {
        position: absolute;
        bottom: 0;
        left: 0;
        padding: 3rem;
        width: 100%;
        background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
        color: #fff;
    }

    .offer-card-luxury {
        background: var(--premium-red);
        height: 100%;
        border-radius: 30px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 3rem;
        text-align: center;
        color: #fff;
        border: 1px solid var(--gold-accent);
    }

    /* Shop Now Button */
    .btn-luxury-shop {
        background: linear-gradient(135deg, var(--premium-red), #800000);
        color: #fff;
        padding: 1.25rem 3.5rem;
        border-radius: 100px;
        font-weight: 800;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        border: 2px solid var(--gold-accent);
        box-shadow: 0 0 30px rgba(208, 0, 0, 0.4);
        position: relative;
        transition: var(--transition);
        display: inline-block;
        text-decoration: none;
    }

    /* Product Section */
    .product-section {
        background: #0f0f0f;
        padding: 6rem 4rem;
    }

    .luxury-card {
        background: #1a1a1a;
        border-radius: 30px;
        padding: 1.25rem;
        border: 1px solid rgba(255,255,255,0.05);
        transition: var(--transition);
        height: 100%;
        color: #fff;
    }
    .luxury-card:hover {
        border-color: var(--gold-accent);
        transform: translateY(-10px);
    }

    .product-img-wrapper {
        width: 100%;
        height: 250px;
        border-radius: 20px;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }
    .product-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .btn-shop-mini {
        width: 100%;
        padding: 0.8rem;
        border-radius: 15px;
        background: var(--premium-red);
        color: white;
        border: none;
        font-weight: 700;
        transition: var(--transition);
        text-decoration: none;
        display: block;
        text-align: center;
        margin-top: 1rem;
    }

    /* Animations */
    @@keyframes float {
        0%, 100% { transform: translateY(-50%) translateX(0); }
        50% { transform: translateY(-55%) translateX(-15px); }
    }

    @@media (max-width: 1200px) {
        .hero-headline { font-size: 3.5rem; }
        .hero-shoe-image { display: none; }
        .banner-grid { padding: 4rem 2rem; }
    }
</style>

<div class="landing-v3">
    <!-- Hero Section -->
    <section class="hero-luxury">
        <div class="hero-container">
            <span class="hero-tagline">Exclusively for @Model.Settings.CompanyName</span>
            <h1 class="hero-headline font-luxury">@Model.Settings.EidOfferTitle</h1>
            <div class="discount-text">UP TO @Model.Settings.DiscountPercentage% OFF</div>
            
            @if (Model.Settings.IsOfferActive)
            {
                <div class="countdown-wrapper" id="eid-countdown" data-endtime="@Model.Settings.EidOfferEndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                    <div class="timer-box">
                        <span class="timer-val" id="c-hours">00</span>
                        <span class="timer-label">Hours</span>
                    </div>
                    <div class="timer-box">
                        <span class="timer-val" id="c-minutes">00</span>
                        <span class="timer-label">Minutes</span>
                    </div>
                    <div class="timer-box">
                        <span class="timer-val" id="c-seconds">00</span>
                        <span class="timer-label">Seconds</span>
                    </div>
                </div>
            }

            <p class="mb-4 text-white-50 fw-bold">@Model.Settings.EidOfferSubtitle</p>

            <a href="#featured" class="btn-luxury-shop">Shop Now</a>
        </div>

        <img src="@ResolveUrl(Model.Settings.HeroImageUrl)" class="hero-shoe-image" alt="Hero Product">
    </section>

    <!-- Banner Section (Classic Series) -->
    <section class="banner-grid">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="sale-card">
                    <img src="@ResolveUrl(Model.Settings.BannerImageUrl)" class="banner-img" alt="Classic Series">
                    <div class="sale-content">
                        <span class="badge bg-gold-accent mb-2" style="background: var(--gold-accent); color: #000; font-weight: 800;">LIMITED EDITION</span>
                        <h2 class="font-luxury fs-1">@Model.Settings.BannerTitle</h2>
                        <p>@Model.Settings.BannerDescription</p>
                        <a href="#featured" class="btn btn-outline-light rounded-pill px-4">Discover</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="offer-card-luxury">
                    <h1 class="display-2 fw-900 mb-0">@Model.Settings.OfferCardTitle</h1>
                    <p class="fs-4 fw-bold mb-4">@Model.Settings.OfferCardSubtitle</p>
                    <div class="border-top border-white border-opacity-50 pt-4 w-100">
                        <p class="mb-0 small opacity-75">PROMO CODE</p>
                        <h4 class="fw-bold">@Model.Settings.OfferCardCouponCode</h4>
                    </div>
                    <a href="#featured" class="btn btn-dark rounded-pill mt-4 px-5">Claim Now</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Products -->
    <section class="product-section" id="featured">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="font-luxury display-5 text-white">Exclusive Collection</h2>
                <p class="text-white-50">@Model.Settings.ProductSectionDescription</p>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="luxury-card">
                        <div class="product-img-wrapper">
                            <img src="@ResolveUrl(product.ImageUrl)" alt="@product.Name">
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-white-50 small">@product.CategoryName</span>
                            <span class="badge bg-danger">HOT</span>
                        </div>
                        
                        <h5 class="fw-bold mb-3">@product.Name</h5>
                        
                        <div class="d-flex align-items-center gap-3">
                            <span class="fs-4 fw-bold text-white">৳@(product.DiscountPrice ?? product.Price)</span>
                            @if (product.DiscountPrice.HasValue)
                            {
                                <span class="text-white-50 text-decoration-line-through">৳@product.Price</span>
                            }
                        </div>

                        <a asp-action="ProductDetails" asp-route-id="@product.Id" class="btn-shop-mini">Order Now</a>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-black py-5 text-center text-white border-top border-white border-opacity-10">
        <div class="container">
            <h3 class="font-luxury mb-4">@Model.Settings.CompanyName</h3>
            <p class="text-white-50 mb-4 mx-auto" style="max-width: 600px;">@Model.Settings.CompanyDescription</p>
            <div class="d-flex justify-content-center gap-4 mb-4">
                <a href="@Model.Settings.FacebookPageLink" class="text-white fs-4"><i class="bi bi-facebook"></i></a>
                <a href="#" class="text-white fs-4"><i class="bi bi-instagram"></i></a>
                <a href="#" class="text-white fs-4"><i class="bi bi-whatsapp"></i></a>
            </div>
            <div class="text-white-50 small">
                &copy; @DateTime.Now.Year @Model.Settings.CompanyName. Crafted for Perfection.
            </div>
        </div>
    </footer>
</div>

@section Scripts {
    <script>
        function updateEidTimer() {
            const timerEl = document.getElementById('eid-countdown');
            if (!timerEl) return;

            const endTime = new Date(timerEl.getAttribute('data-endtime')).getTime();
            const now = new Date().getTime();
            const diff = endTime - now;

            if (diff < 0) {
                timerEl.innerHTML = "<h3 class='text-gold-accent'>OFFER EXPIRED</h3>";
                return;
            }

            const h = Math.floor(diff / (1000 * 60 * 60));
            const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((diff % (1000 * 60)) / 1000);

            document.getElementById('c-hours').innerText = h.toString().padStart(2, '0');
            document.getElementById('c-minutes').innerText = m.toString().padStart(2, '0');
            document.getElementById('c-seconds').innerText = s.toString().padStart(2, '0');
        }

        setInterval(updateEidTimer, 1000);
        updateEidTimer();
    </script>
}
