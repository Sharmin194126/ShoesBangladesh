@model List<ShoesBangladeshWebApp.Controllers.CategoryViewModel>
@{
    ViewData["Title"] = "Category Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-header { margin-bottom: 1.75rem; }
    .page-title { font-size: 1.5rem; font-weight: 800; color: #1F1F1F; margin: 0; }
    .page-subtitle { font-size: 0.82rem; color: #9E9E9E; margin: 3px 0 0; }
    .breadcrumb-item a { color: #C40000; text-decoration: none; }
    .breadcrumb-item.active { color: #9E9E9E; }

    .table-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #ECECEC;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        overflow: hidden;
    }

    .table-card-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #ECECEC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .search-input-box {
        position: relative;
        max-width: 280px;
        width: 100%;
    }
    .search-input-box i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #C40000; font-size: 0.85rem; }
    .search-input-box input {
        width: 100%;
        padding: 0.5rem 1rem 0.5rem 2.2rem;
        border-radius: 8px;
        border: 1.5px solid #FECACA;
        background: #FFEBEE;
        font-size: 0.82rem;
        font-family: 'Inter', sans-serif;
        outline: none;
        transition: 0.2s;
    }
    .search-input-box input:focus { border-color: #C40000; background: #FFF5F5; }
    .search-input-box input::placeholder { color: #E57373; }

    .btn-create {
        background: linear-gradient(135deg, #ff2d2d 0%, #C40000 100%);
        color: white;
        border: none;
        padding: 0.55rem 1.25rem;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.82rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: all 0.2s;
        box-shadow: 0 3px 12px rgba(196,0,0,0.25);
    }
    .btn-create:hover { background: linear-gradient(135deg, #C40000 0%, #8B0000 100%); color: white; transform: translateY(-1px); text-decoration: none; }

    .btn-back {
        background: #F5F5F5;
        color: #616161;
        border: 1px solid #E0E0E0;
        padding: 0.55rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.82rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: 0.2s;
    }
    .btn-back:hover { background: #EEEEEE; color: #1F1F1F; text-decoration: none; }

    .category-table { width: 100%; border-collapse: collapse; }
    .category-table thead th {
        background: #1F1F1F !important;
        color: #fff !important;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 1.1rem 1rem;
        border: none;
        white-space: nowrap;
    }
    .category-table tbody td {
        padding: 12px 16px;
        border-bottom: 1px solid #F5F5F5;
        font-size: 0.82rem;
        color: #2B2B2B;
        vertical-align: middle;
    }
    .category-table tbody tr:hover td { background: #FFEBEE; }
    .category-table tbody tr:last-child td { border-bottom: none; }

    .cat-icon {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #FFEBEE, #FECACA);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #C40000;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .badge-active { background: #E8F5E9; color: #2E7D32; padding: 4px 12px; border-radius: 20px; font-size: 0.68rem; font-weight: 700; }
    .badge-count  { background: #FFEBEE; color: #C40000; padding: 4px 10px; border-radius: 20px; font-size: 0.68rem; font-weight: 700; }

    .btn-action {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.15s;
    }
    .btn-view   { background: #E3F2FD; color: #1565C0; }
    .btn-edit   { background: #FFF8E1; color: #F57F17; }
    .btn-del    { background: #FFEBEE; color: #C40000; }
    .btn-view:hover { background: #1565C0; color: white; }
    .btn-edit:hover { background: #F57F17; color: white; }
    .btn-del:hover  { background: #C40000; color: white; }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }
    .empty-state-icon {
        width: 80px;
        height: 80px;
        background: #FFEBEE;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 2rem;
        color: #C40000;
    }

    .alert-success-custom {
        background: #E8F5E9;
        color: #2E7D32;
        border: 1px solid #A5D6A7;
        border-radius: 10px;
        padding: 0.75rem 1.25rem;
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1.25rem;
    }
    .alert-error-custom {
        background: #FFEBEE;
        color: #C62828;
        border: 1px solid #FFCDD2;
        border-radius: 10px;
        padding: 0.75rem 1.25rem;
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1.25rem;
    }
</style>

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h1 class="page-title"><i class="bi bi-tags me-2 text-danger"></i>Category Management</h1>
            <nav aria-label="breadcrumb" class="mt-1">
                <ol class="breadcrumb mb-0" style="font-size: 0.78rem;">
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Categories</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success-custom"><i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error-custom"><i class="bi bi-exclamation-circle-fill"></i> @TempData["ErrorMessage"]</div>
}

<div class="table-card">
    <div class="table-card-header">
        <div class="d-flex align-items-center gap-3">
            <div class="search-input-box">
                <i class="bi bi-search"></i>
                <input type="text" id="searchInput" placeholder="Search categories...">
            </div>
            <span class="text-muted small fw-bold" id="totalCount">@Model.Count Total</span>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Admin" asp-action="Index" class="btn-back"><i class="bi bi-arrow-left"></i> Back</a>
            <a asp-action="Create" class="btn-create"><i class="bi bi-plus-lg"></i> Create New Category</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="category-table" id="categoryTable">
            <thead>
                <tr>
                    <th style="width: 50px;">#</th>
                    <th style="width: 60px;">Icon</th>
                    <th>Category Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th style="width: 120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <div class="empty-state-icon"><i class="bi bi-tags"></i></div>
                                <h5 class="fw-bold" style="color: #1F1F1F;">No Categories Found</h5>
                                <p class="text-muted small">Start by creating your first category.</p>
                                <a asp-action="Create" class="btn-create mt-2"><i class="bi bi-plus-lg"></i> Create Category</a>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td><span class="fw-bold text-muted">@i</span></td>
                            <td>
                                @if(!string.IsNullOrEmpty(cat.ImageUrl))
                                {
                                    <img src="@cat.ImageUrl" alt="@cat.Name" style="width: 44px; height: 44px; border-radius: 10px; object-fit: cover; border: 1px solid #ECECEC;">
                                }
                                else
                                {
                                    <div class="cat-icon"><i class="bi bi-tag-fill"></i></div>
                                }
                            </td>
                            <td>
                                <span class="fw-700" style="font-weight: 700; color: #1F1F1F;">@cat.Name</span>
                            </td>
                            <td>
                                <span class="text-muted" style="font-size: 0.8rem;">
                                    @(cat.Description.Length > 60 ? cat.Description.Substring(0, 60) + "..." : cat.Description)
                                </span>
                            </td>
                            <td>
                                @if (cat.Status == "Active")
                                {
                                    <span class="badge-active"><i class="bi bi-check-circle-fill me-1" style="font-size: 0.6rem;"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge-count" style="background:#FFEBEE;color:#C62828;"><i class="bi bi-x-circle-fill me-1" style="font-size: 0.6rem;"></i>Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@cat.Id" class="btn-action btn-view" title="View"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@cat.Id" class="btn-action btn-edit" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <button class="btn-action btn-del" title="Delete" onclick="confirmDelete(@cat.Id, '@cat.Name')"><i class="bi bi-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Delete Form (hidden) -->
<form id="deleteForm" method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Search
        document.getElementById('searchInput').addEventListener('keyup', function () {
            const val = this.value.toLowerCase();
            let visibleCount = 0;
            const rows = document.querySelectorAll('#categoryTable tbody tr');
            
            rows.forEach(row => {
                if (row.cells.length > 1) { // Skip empty state row
                    const name = row.cells[2].textContent.toLowerCase();
                    const desc = row.cells[3].textContent.toLowerCase();
                    if (name.includes(val) || desc.includes(val)) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                }
            });
            document.getElementById('totalCount').textContent = visibleCount + ' Total';
        });

        // Delete confirmation
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Delete Category?',
                html: `Are you sure you want to delete <strong>${name}</strong>?<br><span style="font-size:0.8rem;color:#9E9E9E;">This action cannot be undone.</span>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#C40000',
                cancelButtonColor: '#9E9E9E',
                confirmButtonText: '<i class="bi bi-trash me-1"></i> Yes, Delete',
                cancelButtonText: 'Cancel',
                borderRadius: '12px'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm');
                    form.action = `/Category/Delete/${id}`;
                    form.submit();
                }
            });
        }
    </script>
}
