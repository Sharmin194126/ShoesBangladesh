                    <h4>Free Delivery</h4>
                    <p>On all orders over ৳2000</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-item">
                    <i class="bi bi-shield-check"></i>
                    <h4>Premium Quality</h4>
                    <p>Authentic products guaranteed</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-item">
                    <i class="bi bi-arrow-repeat"></i>
                    <h4>Easy Returns</h4>
                    <p>7-day hassle-free replacement</p>
                </div>
