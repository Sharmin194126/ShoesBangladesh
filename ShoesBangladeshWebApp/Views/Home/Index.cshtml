                                        </div>

                                        <a href="/Home/Details/@pId" class="shop-now-card-btn text-center text-decoration-none">Buy Now</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    }
    else
    {
        <div class="text-center py-5">
            <h4 class="text-muted">No homepage sections active.</h4>
            <p>Please enable sections in Admin -> Homepage Sections.</p>
        </div>
