@using System.Text.Json
@{
    ViewData["Title"] = "Home";
    var banners = ViewBag.Banners as List<JsonElement>;
    var allProducts = ViewBag.AllProducts as List<JsonElement>;
    var sections = ViewBag.Sections as List<JsonElement>;
    var hpSettings = ViewBag.HpSettings as JsonElement?;
    var categories = ViewBag.Categories as List<JsonElement>;
    
    string apiBase = "http://localhost:5190";

    // Extract dynamic settings
    string marqueeText = hpSettings?.TryGetProperty("marqueeText", out var mt) == true ? mt.GetString() ?? "" : "🚚 Cash on Delivery available all over Bangladesh! ⚡ Fast Delivery, Secure Shopping! 👟 Best Shoe Collection! ✨ Order Now for Exclusive Offers!";
    string heroHeadline = hpSettings?.TryGetProperty("heroHeadline", out var hh) == true ? hh.GetString() ?? "" : "Best Shoe Collection in Bangladesh";
    string heroSubtitle = hpSettings?.TryGetProperty("heroSubtitle", out var hs) == true ? hs.GetString() ?? "" : "Premium Quality, Best Price";
    string heroBtnText = hpSettings?.TryGetProperty("heroBtnText", out var hbt) == true ? hbt.GetString() ?? "" : "Shop Now";
    string heroBtnLink = hpSettings?.TryGetProperty("heroBtnLink", out var hbl) == true ? hbl.GetString() ?? "#" : "#";
}

<style>
    :root {
        --premium-red: #D00000;
        --premium-dark: #121212;
        --premium-gold: #D4AF37;
        --premium-gray: #f8f9fa;
        --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    /* Hero Slider */
    .hero-slider-section {
        position: relative;
        overflow: hidden;
        margin-top: -20px;
    }

    .carousel-item {
        height: 65vh;
        min-height: 400px;
        background-color: #000;
    }

    .carousel-image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.1) 100%);
        z-index: 1;
    }

    .carousel-caption-custom {
        position: absolute;
        top: 50%;
        left: 8%;
        transform: translateY(-50%);
        z-index: 2;
        max-width: 700px;
        color: white;
        text-align: left;
    }

    .carousel-caption-custom h1 {
        font-size: 4rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: -1px;
        animation: fadeInUp 0.8s ease;
    }

    .carousel-caption-custom p {
        font-size: 1.2rem;
        margin-bottom: 2rem;
        color: rgba(255,255,255,0.9);
        animation: fadeInUp 1s ease;
    }

    .carousel-btn-group {
        display: flex;
        gap: 15px;
        animation: fadeInUp 1.2s ease;
    }

    .btn-premium-red {
        background: var(--premium-red);
        color: white;
        padding: 0.8rem 2.2rem;
        border-radius: 8px;
        font-weight: 700;
        text-decoration: none;
        transition: var(--transition);
        border: 2px solid var(--premium-red);
    }

    .btn-premium-red:hover {
        background: transparent;
        color: var(--premium-red);
    }

    /* SIDE NAV (Slim Circle Icons) */
    .side-nav {
        position: fixed;
        left: 25px;
        top: 75vh;
        width: 50px;
        background: transparent;
        z-index: 1000;
        display: none;
        overflow: visible;
    }

    @@media (min-width: 1200px) {
        .side-nav { display: block; }
    }

    .side-nav a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: var(--premium-red); /* Using theme color */
        color: white;
        border-radius: 50%;
        margin-bottom: 12px;
        text-decoration: none;
        font-size: 1.1rem;
        transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 4px 15px rgba(208,0,0,0.3);
        position: relative;
    }

    .side-nav a .nav-text {
        position: absolute;
        left: 55px;
        background: var(--premium-dark);
        color: white;
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        transition: 0.3s;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        pointer-events: none;
    }

    .side-nav a:hover .nav-text {
        opacity: 1;
        visibility: visible;
        left: 50px;
    }

    .side-nav a:hover {
        transform: scale(1.15);
        background: var(--premium-dark);
        box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    }

    /* Product Section */
    .section-header-premium {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2.5rem;
        border-bottom: 2px solid #eee;
        padding-bottom: 1rem;
    }

    .section-header-premium {
        margin-bottom: 3.5rem;
        position: relative;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .section-title-premium {
        font-size: 1.8rem;
        font-weight: 900;
        text-transform: uppercase;
        position: relative;
        color: var(--premium-dark);
        margin-bottom: 2rem;
    }

    .section-title-premium::after {
        content: '';
        position: absolute;
        bottom: -0.8rem;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 4px;
        background: var(--premium-red);
    }

    /* Premium Sneaker Product Card */
    .product-card-luxury {
        background: #fff;
        border-radius: 15px; /* Smaller radius */
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: 2px solid transparent;
        height: auto; /* Shorter length */
        display: flex;
        flex-direction: column;
        position: relative;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        max-width: 280px; /* Constrain width */
        margin: 0 auto;
    }

    .product-card-luxury:hover {
        transform: translateY(-10px);
        border-color: var(--premium-red);
        box-shadow: 0 15px 45px rgba(208,0,0,0.1);
    }

    .luxury-img-box {
        position: relative;
        height: 180px; /* Shortened image height */
        overflow: hidden;
        background: #f8f8f8;
    }

    .luxury-img-box img {
        width: 100%;
        height: 100%;
        object-fit: contain; /* Prevents stretching */
        padding: 10px;
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .product-card-luxury:hover .luxury-img-box img {
        transform: scale(1.1) rotate(-5deg);
    }

    .discount-badge-red {
        position: absolute;
        top: 15px;
        right: 15px;
        background: var(--premium-red);
        color: white;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 800;
        z-index: 10;
        box-shadow: 0 4px 10px rgba(208,0,0,0.3);
    }

    .luxury-info {
        padding: 1.5rem;
        text-align: left;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .luxury-info h6 {
        font-weight: 800;
        margin-bottom: 0.15rem;
        color: #1a1a1a;
        font-size: 1.05rem; /* Smaller title */
        line-height: 1.2;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 2.6rem;
    }

    .rating-box {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 0.75rem;
        color: #ffc107;
        font-size: 0.85rem;
    }

    .review-count {
        color: #adb5bd;
        font-size: 0.75rem;
        margin-left: 5px;
    }

    .price-box {
        display: flex;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 1rem;
    }

    .price-current {
        color: #1a1a1a;
        font-weight: 900;
        font-size: 1.2rem; /* Smaller price */
    }

    .price-old {
        color: var(--premium-red); /* Red for regular price */
        text-decoration: line-through;
        text-decoration-thickness: 3px; /* Extra thick "cross" line */
        font-size: 1.1rem; /* Increased from 0.75rem */
        margin-left: 10px;
        font-weight: 800;
        opacity: 0.9;
    }

    .size-selector {
        display: flex;
        gap: 8px;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .size-btn {
        width: 35px;
        height: 35px;
        border: 1.5px solid #e9ecef;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        color: #495057;
        transition: 0.2s;
        cursor: pointer;
        background: white;
    }

    .size-btn:hover {
        border-color: var(--premium-red);
        color: var(--premium-red);
    }

    .shop-now-card-btn {
        background: var(--premium-red);
        color: white;
        border: none;
        padding: 0.6rem; /* Smaller padding */
        border-radius: 10px;
        font-weight: 700;
        width: 100%;
        transition: 0.3s;
        text-transform: uppercase;
        font-size: 0.75rem; /* Smaller font */
        letter-spacing: 1px;
        box-shadow: 0 4px 15px rgba(208,0,0,0.2);
        animation: widthPulse 2s infinite ease-in-out;
    }

    @@keyframes widthPulse {
        0% { transform: scaleX(1); box-shadow: 0 4px 10px rgba(208,0,0,0.2); }
        25% { transform: scaleX(0.85); box-shadow: 0 2px 5px rgba(208,0,0,0.1); }
        50% { transform: scaleX(1.05); box-shadow: 0 6px 15px rgba(208,0,0,0.3); }
        75% { transform: scaleX(0.9); box-shadow: 0 2px 5px rgba(208,0,0,0.1); }
        100% { transform: scaleX(1); box-shadow: 0 4px 10px rgba(208,0,0,0.2); }
    }

    .product-card-luxury:hover .shop-now-card-btn {
        background: var(--premium-dark);
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
em;
    }

    .luxury-price {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--premium-red);
        margin-bottom: 1rem;
    }

    .btn-buy-luxury {
        display: block;
        width: 100%;
        padding: 0.6rem;
        background: var(--premium-dark);
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.9rem;
        transition: 0.3s;
    }

    .btn-buy-luxury:hover {
        background: var(--premium-red);
        color: white;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Features Section */
    .features-grid {
        background: white;
        padding: 3rem 0;
        border-bottom: 1px solid #eee;
    }

    .feature-item {
        text-align: center;
        padding: 1.5rem;
        transition: var(--transition);
    }

    .feature-item i {
        font-size: 3.5rem;
        color: var(--premium-red);
        display: block;
        margin-bottom: 1.5rem;
        line-height: 1;
    }

    .feature-item h4 {
        font-weight: 800;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
        color: var(--premium-dark);
    }

    .feature-item p {
        color: #777;
        font-size: 0.9rem;
        margin-bottom: 0;
    }

    .feature-item:hover {
        transform: translateY(-5px);
    }
</style>

<!-- Update Layout Marquee Text Dynamically if possible, otherwise it will use default -->
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const marqueeEl = document.getElementById("marqueeTextContent");
        if (marqueeEl) {
            marqueeEl.innerText = "@marqueeText";
            // Also update the duplicate for seamless loop
            const track = document.querySelector(".marquee-track");
            if (track) {
                track.innerHTML = `<span style="font-size: 0.9rem; font-weight: 600; letter-spacing: 0.3px; padding: 0 60px;">@marqueeText</span>
                                  <span style="font-size: 0.9rem; font-weight: 600; padding: 0 60px;">@marqueeText</span>`;
            }
        }
    });
</script>

<div class="side-nav">
    @if (sections != null)
    {
        foreach (var dispSection in sections)
        {
            string name = "Section";
            if (dispSection.TryGetProperty("title", out var t)) name = t.GetString() ?? "Section";
            else if (dispSection.TryGetProperty("Title", out var t2)) name = t2.GetString() ?? "Section";

            var sectionId = name.Replace(" ", "").ToLower();
            <a href="#@sectionId">
                @if (name.Contains("Categor", StringComparison.OrdinalIgnoreCase)) { <text>🗂️</text> }
                else if (name.Contains("Featured", StringComparison.OrdinalIgnoreCase)) { <text>⭐</text> }
                else if (name.Contains("Exclusive", StringComparison.OrdinalIgnoreCase)) { <text>💎</text> }
                else if (name.Contains("Offer", StringComparison.OrdinalIgnoreCase)) { <text>🔥</text> }
                else if (name.Contains("You", StringComparison.OrdinalIgnoreCase)) { <text>❤️</text> }
                else if (name.Contains("Restock", StringComparison.OrdinalIgnoreCase)) { <text>🔁</text> }
                else { <text>📦</text> }
                <span class="nav-text">@name</span>
            </a>
        }
    }
</div>

<div class="page-wrapper-custom">
    <div class="hero-slider-section">
    <div id="homeHeroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="3000">
        <div class="carousel-inner">
            @if (banners != null && banners.Count > 0)
            {
                for (int i = 0; i < banners.Count; i++)
                {
                    var banner = banners[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@(banner.GetProperty("imageUrl").GetString()?.StartsWith("http") == true ? "" : apiBase)@banner.GetProperty("imageUrl").GetString()" class="d-block w-100 h-100" style="object-fit: contain; background: #000;" alt="...">
                        <div class="carousel-image-overlay"></div>
                        <div class="carousel-caption-custom">
                            <h1>@banner.GetProperty("title").GetString()</h1>
                            <p>@banner.GetProperty("subtitle").GetString()</p>
                            <div class="carousel-btn-group">
                                <a href="@banner.GetProperty("linkUrl").GetString()" class="btn-premium-red shadow-lg">Shop Now</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="carousel-item active">
                    <img src="/images/hero-bg.png" class="d-block w-100 h-100" style="object-fit: contain; background: #000;" alt="...">
                    <div class="carousel-image-overlay"></div>
                    <div class="carousel-caption-custom">
                        <h1>@heroHeadline</h1>
                        <p>@heroSubtitle</p>
                        <div class="carousel-btn-group">
                            <a href="@heroBtnLink" class="btn-premium-red">@heroBtnText</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Features Section (Restored) -->
<section class="features-grid">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-item">
                    <i class="bi bi-truck"></i>
                    <h4>Free Delivery</h4>
                    <p>On all orders over ৳2000</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-item">
                    <i class="bi bi-shield-check"></i>
                    <h4>Premium Quality</h4>
                    <p>Authentic products guaranteed</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-item">
                    <i class="bi bi-arrow-repeat"></i>
                    <h4>Easy Returns</h4>
                    <p>7-day hassle-free replacement</p>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container py-5">
    @if (sections != null && sections.Count > 0)
    {
        foreach (var section in sections)
        {
            string sectionName = "Section";
            if (section.TryGetProperty("title", out var t) && t.ValueKind == JsonValueKind.String) sectionName = t.GetString() ?? "Section";
            else if (section.TryGetProperty("Title", out var t2) && t2.ValueKind == JsonValueKind.String) sectionName = t2.GetString() ?? "Section";

            int categoryId = 0;
            if (section.TryGetProperty("categoryId", out var c) && c.ValueKind == JsonValueKind.Number) categoryId = c.GetInt32();
            else if (section.TryGetProperty("CategoryId", out var c2) && c2.ValueKind == JsonValueKind.Number) categoryId = c2.GetInt32();
            
            if (!sectionName.Equals("Featured items", StringComparison.OrdinalIgnoreCase) && categoryId == 0) continue;
            
            // Filter products for this category
            List<JsonElement>? sectionProducts = null;

            if (sectionName.Equals("Featured items", StringComparison.OrdinalIgnoreCase))
            {
                sectionProducts = allProducts?.Where(p => {
                    if (p.TryGetProperty("isFeatured", out var f) && f.ValueKind == JsonValueKind.True) return true;
                    if (p.TryGetProperty("IsFeatured", out var f2) && f2.ValueKind == JsonValueKind.True) return true;
                    return false;
                }).Take(4).ToList();
            }
            else if (categoryId != 0)
            {
                sectionProducts = allProducts?.Where(p => {
                    if (p.TryGetProperty("categoryId", out var pc) && pc.ValueKind == JsonValueKind.Number) return pc.GetInt32() == categoryId;
                    if (p.TryGetProperty("CategoryId", out var pc2) && pc2.ValueKind == JsonValueKind.Number) return pc2.GetInt32() == categoryId;
                    return false;
                }).Take(4).ToList();
            }

            if (sectionProducts != null && sectionProducts.Any())
            {
                var sectionId = sectionName.Replace(" ", "").ToLower();
                <div class="mb-5" id="@sectionId">
                    <div class="section-header-premium">
                        <h2 class="section-title-premium">@sectionName</h2>
                    </div>
                    
                    <div class="row g-4">
                        @foreach (var product in sectionProducts)
                        {
                            string pName = "";
                            if (product.TryGetProperty("name", out var n) && n.ValueKind == JsonValueKind.String) pName = n.GetString() ?? "";
                            else if (product.TryGetProperty("Name", out var n2) && n2.ValueKind == JsonValueKind.String) pName = n2.GetString() ?? "";

                            decimal pPrice = 0;
                            if (product.TryGetProperty("price", out var p) && p.ValueKind == JsonValueKind.Number) pPrice = p.GetDecimal();
                            else if (product.TryGetProperty("Price", out var p2) && p2.ValueKind == JsonValueKind.Number) pPrice = p2.GetDecimal();

                            string pImg = "";
                            if (product.TryGetProperty("imageUrl", out var i) && i.ValueKind == JsonValueKind.String) pImg = i.GetString() ?? "";
                            else if (product.TryGetProperty("ImageUrl", out var i2) && i2.ValueKind == JsonValueKind.String) pImg = i2.GetString() ?? "";

                            decimal pDiscountPrice = 0;
                            if (product.TryGetProperty("discountPrice", out var dp) && dp.ValueKind == JsonValueKind.Number) pDiscountPrice = dp.GetDecimal();
                            else if (product.TryGetProperty("DiscountPrice", out var dp2) && dp2.ValueKind == JsonValueKind.Number) pDiscountPrice = dp2.GetDecimal();

                            decimal pOffer = 0;
                            if (product.TryGetProperty("offerPercentage", out var op) && op.ValueKind == JsonValueKind.Number) pOffer = op.GetDecimal();
                            else if (product.TryGetProperty("OfferPercentage", out var op2) && op2.ValueKind == JsonValueKind.Number) pOffer = op2.GetDecimal();

                            int pId = 0;
                            if (product.TryGetProperty("id", out var pid) && pid.ValueKind == JsonValueKind.Number) pId = pid.GetInt32();
                            else if (product.TryGetProperty("Id", out var pid2) && pid2.ValueKind == JsonValueKind.Number) pId = pid2.GetInt32();

                            <div class="col-6 col-lg-3">
                                <div class="product-card-luxury">
                                    <div class="luxury-img-box">
                                        @if (pOffer > 0)
                                        {
                                            <div class="discount-badge-red">SAVE @pOffer%</div>
                                        }
                                        <a href="/Product/Details/@pId">
                                            <img src="@(pImg.StartsWith("http") == true ? "" : apiBase)@pImg" alt="@pName">
                                        </a>
                                    </div>
                                    <div class="luxury-info">
                                        <h6 class="mb-1">@pName</h6>
                                        <div class="rating-box">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-half"></i>
                                            <span class="review-count">(124)</span>
                                        </div>
                                        <div class="price-box">
                                            @if (pDiscountPrice > 0 && pDiscountPrice < pPrice)
                                            {
                                                <span class="price-current">৳@pDiscountPrice.ToString("#,##0")</span>
                                                <span class="price-old">৳@pPrice.ToString("#,##0")</span>
                                            }
                                            else
                                            {
                                                <span class="price-current">৳@pPrice.ToString("#,##0")</span>
                                            }
                                        </div>
                                        
                                        <div class="size-selector">
                                            <span class="size-btn">40</span>
                                            <span class="size-btn">41</span>
                                            <span class="size-btn">42</span>
                                            <span class="size-btn">43</span>
                                            <span class="size-btn">44</span>
                                        </div>

                                        <a href="/Product/Details/@pId" class="shop-now-card-btn text-center text-decoration-none">Shop Now</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    }
    else
    {
        <div class="text-center py-5">
            <h4 class="text-muted">No homepage sections active.</h4>
            <p>Please enable sections in Admin -> Homepage Sections.</p>
        </div>
    }
</div>

<!-- Extra Promo Section -->
