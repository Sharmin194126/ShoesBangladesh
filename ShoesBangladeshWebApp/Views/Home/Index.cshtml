<section class="lukaz-new-in">
    <div class="container">
        <div class="lukaz-section-header">
            <h2 class="lukaz-section-title">New In</h2>
            <div class="lukaz-tabs">
                <a href="javascript:void(0)" class="lukaz-tab-btn active" data-filter="all">All</a>
                @if (categories != null)
                {
                    foreach (var cat in categories.Take(4)) // Show top 4 categories as tabs
                    {
                        string catName = cat.TryGetProperty("name", out var cn) ? cn.GetString() ?? "" : "";
                        int catId = cat.TryGetProperty("id", out var cid) ? cid.GetInt32() : 0;
                        <a href="javascript:void(0)" class="lukaz-tab-btn" data-filter="@catId">@catName</a>
                    }
                }
            </div>
        </div>
        
        <div class="lukaz-slider-container">
            <div class="lukaz-slider-nav">
                <div class="lukaz-nav-btn" id="prevNewIn"><i class="bi bi-chevron-left"></i></div>
                <div class="lukaz-nav-btn" id="nextNewIn"><i class="bi bi-chevron-right"></i></div>
            </div>
            <div class="lukaz-slider-inner">
                <div class="lukaz-slider-track" id="newInSlider">
                @{
                    var newProducts = allProducts?.OrderByDescending(p => p.TryGetProperty("id", out var id) ? id.GetInt32() : 0).Take(15).ToList();
                }
                @if (newProducts != null)
                {
                    foreach (var product in newProducts)
                    {
                        string pName = product.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "";
                        decimal pPrice = product.TryGetProperty("price", out var p) ? p.GetDecimal() : 0;
                        string pImg = product.TryGetProperty("imageUrl", out var i) ? i.GetString() ?? "" : "";
                        int pId = product.TryGetProperty("id", out var pid) ? pid.GetInt32() : 0;
                        int pCatId = product.TryGetProperty("categoryId", out var cid2) ? cid2.GetInt32() : 0;

                        <div class="lukaz-slider-item" data-catid="@pCatId">
                            <div class="lukaz-product-card">
                                <div class="lukaz-img-wrapper">
                                    <div class="lukaz-badge">New</div>
                                    <a href="/Home/Details/@pId">
                                        <img src="@(pImg.StartsWith("http") ? "" : apiBase)@pImg" alt="@pName">
                                    </a>
                                </div>
                                <div class="lukaz-product-info">
                                    <a href="/Home/Details/@pId" class="lukaz-product-name">@pName</a>
                                    <div class="lukaz-product-price">৳@pPrice.ToString("#,##0")</div>
                                </div>
                            </div>
                        </div>
                    }
                }
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const slider = document.getElementById('newInSlider');
        const prevBtn = document.getElementById('prevNewIn');
        const nextBtn = document.getElementById('nextNewIn');
        let index = 0;
        const items = document.querySelectorAll('.lukaz-slider-item');
        const itemCount = items.length;
        
        function getVisibleCount() {
            if (window.innerWidth > 1200) return 4;
            if (window.innerWidth > 992) return 3;
            if (window.innerWidth > 768) return 2;
            return 1;
        }

        function updateSlider() {
            const visibleCount = getVisibleCount();
            const maxIndex = Math.max(0, itemCount - visibleCount);
            if (index > maxIndex) index = 0;
            if (index < 0) index = maxIndex;
            
            const gap = 30;
            const itemWidth = items[0].offsetWidth;
            const move = index * (itemWidth + gap);
            slider.style.transform = `translateX(-${move}px)`;
        }

        function nextSlide() {
            index++;
            updateSlider();
        }

        function prevSlide() {
            index--;
            updateSlider();
        }

        prevBtn.addEventListener('click', () => {
            prevSlide();
            resetInterval();
        });

        nextBtn.addEventListener('click', () => {
            nextSlide();
            resetInterval();
        });

        let slideInterval = setInterval(nextSlide, 3000);

        function resetInterval() {
            clearInterval(slideInterval);
            slideInterval = setInterval(nextSlide, 3000);
        }

        slider.addEventListener('mouseenter', () => clearInterval(slideInterval));
        slider.addEventListener('mouseleave', () => slideInterval = setInterval(nextSlide, 3000));
        
        window.addEventListener('resize', () => {
            index = 0;
            updateSlider();
        });
    });
</script>

