    }

    .product-grid-5 {
        display: flex;
        flex-wrap: wrap;
        margin-right: -10px;
        margin-left: -10px;
    }
    .product-grid-5 > div {
        padding: 10px;
        width: 100%;
    }
    @@media (min-width: 576px) { .product-grid-5 > div { width: 50%; } }
    @@media (min-width: 768px) { .product-grid-5 > div { width: 33.333%; } }
    @@media (min-width: 992px) { .product-grid-5 > div { width: 25%; } }
    @@media (min-width: 1200px) { .product-grid-5 > div { width: 20%; } }

    /* Premium Sneaker Product Card */
    .product-card-luxury {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: 2px solid transparent;
        height: auto;
        display: flex;
        flex-direction: column;
        position: relative;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        margin: 0 auto;
        padding-bottom: 12px; /* Slightly reduced */
    }

    .product-card-luxury:hover {
        transform: translateY(-10px);
        border-color: var(--premium-red);
        box-shadow: 0 15px 45px rgba(208,0,0,0.1);
    }

    .luxury-img-box {
        position: relative;
        height: 260px; /* Increased from 220px */
        overflow: hidden;
        background: #fff;
    }

    .luxury-img-box img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Changed from contain to cover to fill space */
        border-radius: 15px;
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .product-card-luxury:hover .luxury-img-box img {
        transform: scale(1.1) rotate(-5deg);
    }

    .discount-badge-red {
        position: absolute;
        top: 15px;
        right: 15px;
        background: var(--premium-red);
        color: white;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 800;
        z-index: 10;
        box-shadow: 0 4px 10px rgba(208,0,0,0.3);
    }

    .luxury-info {
        padding: 0.75rem; /* Reduced from 1rem */
        text-align: left;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        line-height: 1.1; /* Tighter line spacing */
    }

    .luxury-info h6 {
        font-weight: 800;
        margin-bottom: 0.1rem; /* Reduced */
        color: #1a1a1a;
        font-size: 0.9rem; /* Slightly smaller to fit better */
        line-height: 1.2;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 2.3rem;
    }

    .rating-box {
        display: flex;
        align-items: center;
        gap: 2px;
        margin-bottom: 0.25rem; /* Reduced margin */
        color: #ffc107;
        font-size: 0.75rem;
        font-weight: 400;
    }

    .review-count {
        color: #adb5bd;
        font-size: 0.75rem;
        margin-left: 5px;
    }

    .price-box {
        display: flex;
        align-items: baseline;
        gap: 6px;
        margin-bottom: 0.4rem; /* Reduced margin */
        font-weight: 400;
    }

    .price-current {
        color: #532374; /* Brand Purple */
        font-weight: 700;
        font-size: 1.1rem;
    }

    .price-old {
        color: #ff0000; /* Red for regular price */
        text-decoration: line-through;
        text-decoration-thickness: 1px;
        font-size: 0.9rem;
        font-weight: 400; /* Unbold */
        opacity: 0.8;
    }

    .size-selector {
        display: flex;
        gap: 8px;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .size-btn {
        width: 35px;
        height: 35px;
        border: 1.5px solid #e9ecef;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        color: #495057;
        transition: 0.2s;
        cursor: pointer;
        background: white;
    }

    .size-btn:hover {
        border-color: var(--premium-red);
        color: var(--premium-red);
    }

    .shop-now-card-btn {
        background: var(--premium-red);
        color: white;
        border: none;
        padding: 0.6rem; /* Smaller padding */
        border-radius: 10px;
        font-weight: 700;
        width: 100%;
        transition: 0.3s;
        text-transform: uppercase;
        font-size: 0.75rem; /* Smaller font */
        letter-spacing: 1px;
        box-shadow: 0 4px 15px rgba(208,0,0,0.2);
        animation: widthPulse 2s infinite ease-in-out;
    }

    @@keyframes widthPulse {
        0% { transform: scaleX(1); box-shadow: 0 4px 10px rgba(208,0,0,0.2); }
        25% { transform: scaleX(0.85); box-shadow: 0 2px 5px rgba(208,0,0,0.1); }
        50% { transform: scaleX(1.05); box-shadow: 0 6px 15px rgba(208,0,0,0.3); }
        75% { transform: scaleX(0.9); box-shadow: 0 2px 5px rgba(208,0,0,0.1); }
        100% { transform: scaleX(1); box-shadow: 0 4px 10px rgba(208,0,0,0.2); }
    }

    .product-card-luxury:hover .shop-now-card-btn {
        background: var(--premium-dark);
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
em;
    }

    .luxury-price {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--premium-red);
        margin-bottom: 1rem;
    }

    .btn-buy-luxury {
        display: block;
        width: 100%;
        padding: 0.6rem;
        background: var(--premium-dark);
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.9rem;
        transition: 0.3s;
    }

    .btn-buy-luxury:hover {
        background: var(--premium-red);
        color: white;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Features Section */
    .features-grid {
        background: white;
        padding: 3rem 0;
        border-bottom: 1px solid #eee;
    }

    .feature-item {
        text-align: center;
        padding: 1.5rem;
        transition: var(--transition);
    }

    .feature-item i {
        font-size: 3.5rem;
        color: var(--premium-red);
        display: block;
        margin-bottom: 1.5rem;
        line-height: 1;
    }

    .feature-item h4 {
        font-weight: 800;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
        color: var(--premium-dark);
    }

    .feature-item p {
        color: #777;
        font-size: 0.9rem;
        margin-bottom: 0;
    }

    .feature-item:hover {
        transform: translateY(-5px);
    }

    /* Welcome Section */
    .welcome-section {
        padding: 60px 0;
        text-align: center;
        background: #fff;
    }
    .welcome-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--premium-red);
        margin-bottom: 15px;
    }
    .welcome-text {
        font-size: 1rem;
        color: #666;
        max-width: 900px;
        margin: 0 auto;
        line-height: 1.5;
    }

    /* Lukaz New In Section Refinement */
    .lukaz-new-in {
        padding: 80px 0;
        background: #fff;
        overflow: hidden;
    }
    .lukaz-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 50px;
        flex-wrap: wrap;
        gap: 20px;
    }
    .lukaz-section-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.8rem;
        font-weight: 400; /* Unbold */
        margin-bottom: 0;
        letter-spacing: -1px;
    }
    .lukaz-tabs {
        display: flex;
        gap: 25px;
    }
    .lukaz-tab-btn {
        padding: 5px 0;
        background: transparent;
        color: #888;
        font-weight: 500;
        text-decoration: none;
        transition: 0.3s;
        font-size: 0.95rem;
        font-family: 'Space Grotesk', sans-serif;
        border-bottom: 2px solid transparent;
        text-transform: capitalize;
    }
    .lukaz-tab-btn.active {
        color: #1A1A1A;
        border-bottom-color: #1A1A1A;
    }
    .lukaz-tab-btn:hover {
        color: #1A1A1A;
    }

    /* Lukaz Card Design (Same to Same) */
    .lukaz-product-card {
        background: transparent;
        transition: 0.4s;
        margin-bottom: 20px;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .lukaz-img-wrapper {
        position: relative;
        background: transparent; /* Removed gray background */
        border-radius: 15px;
        overflow: hidden;
        margin-bottom: 12px; /* Reduced from 20px to remove khali jayga */
        aspect-ratio: 4/5;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 380px;
    }
    .lukaz-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    .lukaz-product-card:hover .lukaz-img-wrapper img {
        transform: scale(1.1);
    }
    .lukaz-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: var(--lukaz-teal);
        color: #fff;
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        z-index: 2;
    }
    .lukaz-product-info {
        text-align: left;
    }
    .lukaz-product-name {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.95rem;
        font-weight: 500;
        color: #1A1A1A;
        margin-bottom: 2px;
        display: block;
        text-decoration: none;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.2;
    }
    .lukaz-product-price {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--lukaz-teal);
        line-height: 1.2;
    }

    /* Auto-playing Slider */
    .lukaz-slider-container {
        position: relative;
        width: 100%;
        overflow: hidden;
    }
    .lukaz-slider-track {
        display: flex;
        transition: transform 0.8s cubic-bezier(0.65, 0, 0.35, 1);
        gap: 30px;
        padding: 10px 0;
    }
    .lukaz-slider-item {
        flex: 0 0 calc(25% - 23px); /* Changed to 4 items on desktop for larger cards */
        min-width: 280px;
    }
    @@media (max-width: 1200px) { .lukaz-slider-item { flex: 0 0 calc(33.33% - 20px); } }
    @@media (max-width: 992px) { .lukaz-slider-item { flex: 0 0 calc(50% - 15px); } }
    @@media (max-width: 480px) { .lukaz-slider-item { flex: 0 0 100%; } }

    /* Slider Buttons Positioned Outside */
    .lukaz-slider-container {
        position: relative;
        width: 100%;
        padding: 0 60px; /* Space for buttons on sides */
    }
    .lukaz-slider-nav {
        position: absolute;
        top: 40%; /* Centered vertically relative to the image part */
        left: 0;
        right: 0;
        display: flex;
        justify-content: space-between;
        pointer-events: none;
        z-index: 10;
        transform: translateY(-50%);
    }
    .lukaz-nav-btn {
        width: 40px;
        height: 40px;
        background: white;
        border: 1px solid #ddd;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        pointer-events: auto;
        transition: 0.3s;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        font-size: 1rem;
        color: #333;
    }
    .lukaz-nav-btn:hover {
        background: #000;
        color: #fff;
        border-color: #000;
    }
    
    .lukaz-slider-inner {
        width: 100%;
        overflow: hidden;
    }

    /* Lukaz Shop by Category */
    .lukaz-categories {
        padding: 80px 0;
        background: linear-gradient(180deg, #fff 0%, #f0f7f4 100%);
    }
    .lukaz-category-card {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        height: 480px; /* Same to same as Lukaz tall cards */
        margin-bottom: 30px;
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
        cursor: pointer;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .lukaz-category-card:hover {
        transform: translateY(-10px);
    }
    .lukaz-category-card:hover img {
        transform: scale(1.1);
    }
    .lukaz-category-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 0.8s ease;
    }
    .lukaz-category-info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 40px 30px;
        background: linear-gradient(0deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0) 100%);
        color: #fff;
        text-align: left;
    }
    .lukaz-category-name {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .lukaz-explore-text {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
        color: rgba(255,255,255,0.8);
        display: flex;
        align-items: center;
        gap: 10px;
        transition: 0.3s;
    }
    .lukaz-category-card:hover .lukaz-explore-text {
        color: #fff;
        gap: 15px;
    }

    /* Premium View More Button */
    .btn-view-more {
        background: linear-gradient(135deg, var(--premium-red) 0%, #7A0000 100%);
        color: white !important;
        padding: 0.9rem 2.8rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        box-shadow: 0 6px 20px rgba(208, 0, 0, 0.25);
        border: 2px solid transparent;
    }
    .btn-view-more:hover {
        background: transparent !important;
