@using System.Text.Json
@{
    ViewData["Title"] = "Home";
    var banners = ViewBag.Banners as List<JsonElement>;
    var allProducts = ViewBag.AllProducts as List<JsonElement>;
    var sections = ViewBag.Sections as List<JsonElement>;
    var hpSettings = ViewBag.HpSettings as JsonElement?;
    var categories = ViewBag.Categories as List<JsonElement>;
    
    string apiBase = "http://localhost:5190";

    // Extract dynamic settings
    string marqueeText = hpSettings?.TryGetProperty("marqueeText", out var mt) == true ? mt.GetString() ?? "" : "🚚 Cash on Delivery available all over Bangladesh! ⚡ Fast Delivery, Secure Shopping! 👟 Best Shoe Collection! ✨ Order Now for Exclusive Offers!";
    string heroHeadline = hpSettings?.TryGetProperty("heroHeadline", out var hh) == true ? hh.GetString() ?? "" : "Best Shoe Collection in Bangladesh";
    string heroSubtitle = hpSettings?.TryGetProperty("heroSubtitle", out var hs) == true ? hs.GetString() ?? "" : "Premium Quality, Best Price";
    string heroBtnText = hpSettings?.TryGetProperty("heroBtnText", out var hbt) == true ? hbt.GetString() ?? "" : "Shop Now";
    string heroBtnLink = hpSettings?.TryGetProperty("heroBtnLink", out var hbl) == true ? hbl.GetString() ?? "#" : "#";
    string qTitle = hpSettings?.TryGetProperty("qualityTitle", out var qt) == true ? qt.GetString() ?? "" : "PREMIUM QUALITY ASSURED";
    string qDesc = hpSettings?.TryGetProperty("qualityDescription", out var qd) == true ? qd.GetString() ?? "" : "Cash on Delivery across Bangladesh with the fastest delivery service. We ensure that every pair of shoes meets our highest standards of comfort, durability, and style.";
}

<style>
    :root {
        --premium-red: #D00000;
        --premium-dark: #121212;
        --premium-gold: #D4AF37;
        --premium-gray: #f8f9fa;
        --lukaz-teal: #3A9E75;
        --lukaz-teal-dark: #2d7d5d;
        --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    @@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

    .lukaz-font {
        font-family: 'Space Grotesk', sans-serif;
    }

    html {
        scroll-behavior: smooth;
    }

    /* Hero Slider */
    .hero-slider-section {
        position: relative;
        overflow: hidden;
        margin-top: -20px;
    }

    .carousel-item {
        height: 65vh;
        min-height: 400px;
        background-color: transparent;
    }

    .carousel-image-overlay {
        display: none; /* Completely removed overlay for full clarity */
    }

    .carousel-caption-custom {
        position: absolute;
        top: 50%;
        left: 8%;
        transform: translateY(-50%);
        z-index: 2;
        max-width: 700px;
        color: white;
        text-align: left;
    }

    .carousel-caption-custom h1 {
        font-size: 2.5rem; /* Reduced from 4rem */
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: -1px;
        animation: fadeInUp 0.8s ease;
    }

    .carousel-caption-custom p {
        font-size: 1.2rem;
        margin-bottom: 2rem;
        color: rgba(255,255,255,0.9);
        animation: fadeInUp 1s ease;
    }

    .carousel-btn-group {
        display: flex;
        gap: 15px;
        animation: fadeInUp 1.2s ease;
    }

    .btn-premium-red {
        background: var(--premium-red);
        color: white;
        padding: 0.8rem 2.2rem;
        border-radius: 8px;
        font-weight: 700;
        text-decoration: none;
        transition: var(--transition);
        border: 2px solid var(--premium-red);
    }

    .btn-premium-red:hover {
        background: transparent;
        color: var(--premium-red);
    }

    /* Carousel Dots (Indicators) */
    .carousel-indicators {
        bottom: 20px;
        z-index: 15;
    }
    
    .carousel-indicators button {
        width: 12px !important;
        height: 12px !important;
        border-radius: 50%;
        background-color: rgba(255, 255, 255, 0.5) !important;
        border: 2px solid transparent !important;
        margin: 0 6px !important;
        transition: all 0.3s ease !important;
    }
    
    .carousel-indicators button.active {
        background-color: var(--premium-red) !important;
        transform: scale(1.3);
        border-color: #fff !important;
        box-shadow: 0 0 10px rgba(196, 0, 0, 0.6);
    }

    /* SIDE NAV (Slim Circle Icons) */
    .side-nav {
        position: fixed;
        left: 25px;
        top: 75vh;
        width: 50px;
        background: transparent;
        z-index: 1000;
        display: none;
        overflow: visible;
    }

    @@media (min-width: 1200px) {
        .side-nav { display: block; }
    }

    .side-nav a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: var(--premium-red); /* Using theme color */
        color: white;
        border-radius: 50%;
        margin-bottom: 12px;
        text-decoration: none;
        font-size: 1.1rem;
        transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 4px 15px rgba(208,0,0,0.3);
        position: relative;
    }

    .side-nav a .nav-text {
        position: absolute;
        left: 55px;
        background: var(--premium-dark);
        color: white;
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        transition: 0.3s;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        pointer-events: none;
    }

    .side-nav a:hover .nav-text {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }

    /* Carousel Indicators as Dots */
    .carousel-indicators [data-bs-target] {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        margin: 0 6px;
        background-color: white;
        opacity: 0.5;
        transition: all 0.3s;
    }

    .carousel-indicators .active {
        opacity: 1;
        background-color: var(--premium-red);
        transform: scale(1.2);
    }

    /* Premium Quality Box */
    .premium-quality-box {
        background: #000;
        color: white;
        text-align: center;
        padding: 3rem 1rem;
        border-radius: 15px;
        margin-top: 3rem;
        border: 2px solid var(--premium-gold);
    }

    .premium-quality-box h2 {
        font-weight: 900;
        font-size: 2rem;
        margin-bottom: 1rem;
        letter-spacing: 2px;
        color: var(--premium-gold);
    }

    .premium-quality-box p {
        font-size: 1.1rem;
        opacity: 0.8;
        max-width: 800px;
        margin: 0 auto;
    }
        visibility: visible;
        left: 50px;
    }

    .side-nav a:hover {
        transform: scale(1.15);
        background: var(--premium-dark);
        box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    }

    /* Product Section */
    .section-header-premium {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2.5rem;
        border-bottom: 2px solid #eee;
        padding-bottom: 1rem;
    }

    .section-header-premium {
        margin-bottom: 3.5rem;
        position: relative;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .section-title-premium {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.8rem;
        font-weight: 400; /* Unbold */
        text-transform: uppercase;
        position: relative;
        color: var(--premium-dark);
        margin-bottom: 2rem;
        letter-spacing: -1px;
    }

    .section-title-premium::after {
        content: '';
        position: absolute;
        bottom: -0.8rem;
        left: 50%;
