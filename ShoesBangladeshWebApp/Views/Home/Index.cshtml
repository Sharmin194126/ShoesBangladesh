@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var myCarouselElement = document.querySelector('#homeHeroCarousel');
            if (myCarouselElement) {
                // Remove any existing instance to avoid conflicts
                var existing = bootstrap.Carousel.getInstance(myCarouselElement);
                if (existing) existing.dispose();

                var carousel = new bootstrap.Carousel(myCarouselElement, {
                    interval: 3000,
                    ride: 'carousel',
                    pause: 'hover',
                    wrap: true
                });
                carousel.cycle();
                
                // Force slide next after 3s to prove it works
                setTimeout(() => {
                    carousel.next();
                }, 3000);
            }
        });
    </script>
}
