@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var myCarouselElement = document.querySelector('#homeHeroCarousel');
            if (myCarouselElement) {
                // Remove any existing instance to avoid conflicts
                var existing = bootstrap.Carousel.getInstance(myCarouselElement);
                if (existing) existing.dispose();

                var carousel = new bootstrap.Carousel(myCarouselElement, {
                    interval: 3000,
                    ride: 'carousel',
                    pause: 'hover',
                    wrap: true
                });
                carousel.cycle();
                
                // Force slide next after 3s to prove it works
                setTimeout(() => {
                    carousel.next();
                }, 3000);
            }

            // Lukaz Category Filtering
            const tabBtns = document.querySelectorAll('.lukaz-tab-btn');
            const sliderItems = document.querySelectorAll('.lukaz-slider-item');

            tabBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    tabBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');

                    const filter = this.getAttribute('data-filter');
                    
                    sliderItems.forEach(item => {
                        if (filter === 'all' || item.getAttribute('data-catid') === filter) {
                            item.style.display = 'block';
                        } else {
                            item.style.display = 'none';
                        }
                    });
                    
                    // Reset slider position
                    const sliderTrack = document.getElementById('newInSlider');
                    if (sliderTrack) {
                        sliderTrack.style.transform = 'translateX(0)';
                    }
                });
            });
        });
    </script>
}
