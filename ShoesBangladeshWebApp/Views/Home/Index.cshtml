    <div class="container py-5 text-center text-white">
        <h2 class="display-5 fw-black mb-3">PREMIUM QUALITY ASSURED</h2>
        <p class="lead mb-4">Cash on Delivery across Bangladesh with the fastest delivery service.</p>
        <a href="#" class="btn btn-warning btn-lg rounded-pill px-5 fw-bold">SHOP ALL COLLECTION</a>
    </div>
</section>
