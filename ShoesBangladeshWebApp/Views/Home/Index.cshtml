    <div class="text-center my-5">
        <a href="/Home/CategoryProducts" class="btn-view-more">
            View More <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </div>

    <!-- Bottom Features & Quality Assurance -->
    <section class="mt-5 pt-5 border-top" id="features">
        <div class="row g-4 mb-5">
