@model ShoesBangladeshWebApp.Request.ChangePasswordRequest
@{
    ViewData["Title"] = "Change Password";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Change Password</h2>
            <p>Secure your account with a new password</p>
        </div>
        <form asp-action="ChangePassword" method="post">
            <div class="form-group">
                <label asp-for="CurrentPassword">Current Password</label> 
                <div class="password-wrapper">
                    <input asp-for="CurrentPassword" type="password" id="currentPass" class="form-control" />
                    <button type="button" class="btn-toggle-password" onclick="togglePassword('currentPass', 'currentIcon')">
                        <i class="bi bi-eye-slash" id="currentIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NewPassword">New Password</label>
                <div class="password-wrapper">
                    <input asp-for="NewPassword" type="password" id="newPass" class="form-control" />
                    <button type="button" class="btn-toggle-password" onclick="togglePassword('newPass', 'newIcon')">
                        <i class="bi bi-eye-slash" id="newIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmNewPassword">Confirm New Password</label>
                <div class="password-wrapper">
                    <input asp-for="ConfirmNewPassword" type="password" id="confirmPass" class="form-control" />
                    <button type="button" class="btn-toggle-password" onclick="togglePassword('confirmPass', 'confirmIcon')">
                        <i class="bi bi-eye-slash" id="confirmIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>
            <button type="submit" class="btn-auth">Update Password</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, iconId) {
            const passwordInput = document.getElementById(inputId);
            const toggleIcon = document.getElementById(iconId);
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('bi-eye-slash');
                toggleIcon.classList.add('bi-eye');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('bi-eye');
                toggleIcon.classList.add('bi-eye-slash');
            }
        }
    </script>
}


<style>
    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
    }
    .auth-card {
        background: white;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        width: 100%;
        max-width: 450px;
    }
    .password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }
    .btn-toggle-password {
        position: absolute;
        right: 15px;
        background: none;
        border: none;
        color: #636e72;
        cursor: pointer;
        font-size: 1.2rem;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
    }
    .btn-toggle-password:hover {
        color: #0984e3;
    }
    .btn-auth {

        width: 100%;
        padding: 12px;
        background: #0984e3;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
    }
</style>
