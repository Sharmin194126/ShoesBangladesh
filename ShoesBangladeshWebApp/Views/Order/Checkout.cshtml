@model ShoesBangladeshWebApp.Models.CartViewModel
@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    int totalItems = Model != null ? Model.Items.Sum(i => i.Quantity) : 0;
}

<style>
    .checkout-container {
        background: #fdfdfd;
        padding: 40px;
        border-radius: 12px;
        box-shadow: none;
        color: #333;
    }
    .form-control, .form-select {
        background-color: #f2efe9 !important;
        color: #212529 !important;
        border: 1px solid #ced4da !important;
    }
    .form-control:focus, .form-select:focus {
        background-color: #f2efe9 !important;
        border-color: #86b7fe !important;
    }
    .form-control::placeholder, .form-select::placeholder {
        color: #999 !important; /* Ash color for placeholder */
        opacity: 1;
    }
    .order-summary {
        background: #f2efe9;
        padding: 20px;
        border-radius: 8px;
    }
    .theme-back-btn { background: #F5F5F5; color: #1F1F1F; border: 1px solid #ECECEC; padding: 0.5rem 1.2rem; border-radius: 8px; font-weight: 600; font-size: 0.82rem; text-decoration: none; transition: 0.2s; }
    .theme-back-btn:hover { background: #ECECEC; color: #000; text-decoration: none; }
    
    /* Radio Button States */
    .custom-radio {
        appearance: none;
        -webkit-appearance: none;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid #aaa;     /* grey border — defines the white circle shape */
        background: #ffffff;        /* plain white inside = unselected */
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.2s, border-color 0.2s;
        margin-top: 2px;
    }
    .custom-radio:checked {
        background: #198754;        /* solid green fill = selected */
        border-color: #198754;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="checkout-container">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0 fw-bold">Checkout</h2>
            <a href="javascript:history.back()" class="theme-back-btn mb-0">Back</a>
        </div>

        <div class="row">
            <!-- Order Summary -->
            <div class="col-md-5 order-md-2 mb-4">
                <div class="order-summary">
                    <h4 class="d-flex justify-content-between align-items-center mb-3">
                        <span style="color: #555;">Your Summary</span>
                        <span class="badge bg-danger rounded-pill">@totalItems</span>
                    </h4>
                    <ul class="list-group mb-3">
                        @if (Model != null && Model.Items.Any())
                        {
                            foreach (var item in Model.Items)
                            {
                                <li class="list-group-item d-flex justify-content-between lh-condensed" style="background: transparent; border-color: #ccc;">
                                    <div>
                                        <h6 class="my-0">@item.ProductName</h6>
                                        <small class="text-muted">Qty: @item.Quantity</small>
                                        @if (!string.IsNullOrEmpty(item.Size))
                                        {
                                            <br/><small class="text-muted">Size: @item.Size</small>
                                        }
                                    </div>
                                    <div class="text-end">
                                        <span style="font-weight: bold; color: #2c3e50; display: block;">৳@item.LineTotal.ToString("#,##0")</span>
                                        @if (item.VatAmount > 0)
                                        {
                                            <small class="text-success" style="font-size: 0.7rem;">(incl. VAT: ৳@((item.VatAmount * item.Quantity).ToString("#,##0")))</small>
                                        }
                                    </div>
                                </li>
                            }
                        }
                        
                        <li class="list-group-item d-flex justify-content-between lh-condensed" style="background: transparent;">
                            <span>Subtotal</span>
                            <span class="fw-bold">৳@(Model?.SubTotal.ToString("#,##0") ?? "0")</span>
                        </li>
                        @if (Model != null && Model.TotalVat > 0)
                        {
                            <li class="list-group-item d-flex justify-content-between lh-condensed" style="background: transparent;">
                                <span>Total VAT</span>
                                <span class="fw-bold">৳@Model.TotalVat.ToString("#,##0")</span>
                            </li>
                        }
                        <li class="list-group-item d-flex justify-content-between" style="background: #ddd;">
                            <span style="font-weight: bold;">Grand Total @(Model != null && Model.TotalVat > 0 ? "(with VAT)" : "")</span>
                            <strong style="color: #d9534f; font-size: 1.2rem;">৳@(Model?.GrandTotal.ToString("#,##0") ?? "0")</strong>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Billing Info Form -->
            <div class="col-md-7 order-md-1">
                <h4 class="mb-3 border-bottom pb-2">Step 1: Shipping Details</h4>
                <form method="post" asp-controller="Order" asp-action="CheckoutConfirmed">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="fullName" class="form-label fw-bold text-danger">Customer Full Name</label>
                            <input type="text" class="form-control fw-bold" id="fullName" name="fullName" value="@User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value" placeholder="Full name" required style="background:#f2efe9 !important;">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-danger">Invoice Email</label>
                            <input type="text" class="form-control fw-bold" value="@User.Identity.Name" disabled style="background:#e9ecef !important; color: #666;">
                            <small class="text-muted">Invoice will be sent to this email.</small>
                        </div>
                    </div>

                    <!-- Contact Box -->
                    <div class="mb-3">
                        <label for="phone" class="form-label fw-bold text-danger">Active Contact Number</label>
                        <input type="text" class="form-control" id="phone" name="phone" 
                               placeholder="e.g. 017xxxxxxxx" 
                               pattern="^(?:\+88|88)?(01[3-9]\d{8})$" 
                               title="Please enter a valid BD phone number (e.g. 017xxxxxxxx)" 
                               required 
                               style="color: #000 !important; font-weight: 500; background:#f2efe9 !important;">
                        <small class="text-muted">Must be a valid Bangladesh phone number</small>
                    </div>

                    <!-- Address Box -->
                    <div class="mb-3">
                        <label for="address" class="form-label fw-bold text-danger">Full Delivery Address</label>
                        <textarea class="form-control" id="address" name="address" rows="3" placeholder="Address (House, Road, Area)" required style="color: #000 !important; font-weight: 500;"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="city" class="form-label fw-bold text-danger">City Name</label>
                            <input type="text" class="form-control" id="city" name="city" placeholder="City" required style="color: #000 !important;">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="zipCode" class="form-label fw-bold text-danger">Zip/Postal Code</label>
                            <input type="text" class="form-control" id="zipCode" name="zipCode" placeholder="Zip Code" required style="color: #000 !important;">
                        </div>
                    </div>

                    <hr class="mb-4">

                    <h4 class="mb-3 border-bottom pb-2">Step 2: Payment Method</h4>

                    <div class="d-block my-3">
                        <!-- COD Option -->
                        <div class="form-check mb-3 p-3 border rounded bg-white box-shadow-sm d-flex align-items-start">
                            <input id="cod" name="paymentMethod" type="radio" class="custom-radio mt-1 me-3" value="COD" required>
                            <div class="flex-grow-1">
                                <label class="form-check-label d-flex align-items-center w-100" style="cursor: pointer;" for="cod">
                                    <span class="fw-bold fs-5 text-dark"><i class="bi bi-cash-stack me-2"></i>Cash on Delivery</span>
                                    <span class="badge bg-secondary text-white p-1 ms-auto">PAY ON RECEIVE</span>
                                </label>
                                <div class="mt-2 text-muted small">
                                    Pay with cash when you receive the parcel at your doorstep.
                                </div>
                            </div>
                        </div>

                        <!-- Online Payment Options -->
                        <h6 class="mt-4 mb-2 fw-bold text-success"><i class="bi bi-wallet2"></i> Online Payment</h6>
                        <div class="online-payments border p-3 rounded bg-white">
                            <div class="text-muted small">Online payment methods are currently being updated by Admin.</div>
                        </div>
                    </div>

                    <hr class="mb-4">
                    <button class="btn btn-success btn-lg w-100 py-3" type="submit" style="font-weight: 800; font-size: 1.2rem;">Confirm Order & Proceed</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Allow radio buttons to be deselected by clicking again (toggle)
    document.addEventListener('DOMContentLoaded', function () {
        let lastChecked = null;
        document.querySelectorAll('input[type="radio"][name="paymentMethod"]').forEach(function (radio) {
            radio.addEventListener('click', function () {
                if (this === lastChecked) {
                    this.checked = false;
                    lastChecked = null;
                } else {
                    lastChecked = this;
                }
            });
        });
    });
</script>
