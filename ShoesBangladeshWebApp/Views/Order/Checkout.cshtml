@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold" style="color: #1F1F1F;">Secure Checkout</h1>
        <p class="text-muted fs-5">Complete your purchase to step into premium comfort.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg rounded-4 p-5">
                <div class="row g-5">
                    <div class="col-md-7 border-end pe-md-5">
                        <h4 class="fw-bold mb-4"><i class="bi bi-geo-alt-fill text-danger me-2"></i>Shipping Details</h4>
                        
                        <form>
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Full Name</label>
                                    <input type="text" class="form-control form-control-lg bg-light border-0" value="@User.Identity.Name" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Phone Number</label>
                                    <input type="text" class="form-control form-control-lg bg-light border-0" placeholder="e.g. 01700000000" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Email</label>
                                    <input type="email" class="form-control form-control-lg bg-light border-0" placeholder="e.g. name@example.com">
                                </div>
                                <div class="col-12">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Delivery Address</label>
                                    <textarea class="form-control form-control-lg bg-light border-0" rows="3" placeholder="Enter your full address in Bangladesh" required></textarea>
                                </div>
                            </div>
                        </form>
                    </div>
                    
                    <div class="col-md-5 ps-md-4">
                        <h4 class="fw-bold mb-4"><i class="bi bi-bag-check-fill text-danger me-2"></i>Order Summary</h4>
                        
                        <div class="bg-light p-4 rounded-3 mb-4">
                            <p class="text-muted small mb-2">You are proceeding to checkout.</p>
                            @if (ViewBag.ProductId != null)
                            {
                                <p class="mb-1 fw-bold">Product ID: @ViewBag.ProductId</p>
                                <p class="mb-1">Size: @ViewBag.Size</p>
                                <p class="mb-1">Quantity: @ViewBag.Qty</p>
                            }
                            else
                            {
                                <p class="fw-bold">Cart Items (Pending DB Connection)</p>
                            }
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal</span>
                            <span class="fw-bold">৳0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                            <span class="text-muted">Delivery Charge</span>
                            <span class="fw-bold">৳0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fs-5 fw-bold text-dark">Total</span>
                            <span class="fs-5 fw-bold" style="color: #D00000;">৳0.00</span>
                        </div>

                        <div class="alert alert-info rounded-3 border-0 small mb-4">
                            <i class="bi bi-info-circle-fill me-2"></i> Cash on Delivery available!
                        </div>

                        <button type="button" class="btn btn-danger w-100 btn-lg rounded-pill fw-bold" style="background: linear-gradient(135deg, #D00000, #8B0000); border: none;" onclick="alert('Order Placement system will be connected to DB soon.')">
                            Place Order
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
