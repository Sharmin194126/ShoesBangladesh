@model ShoesBangladesh.API.ViewModels.DisplaySectionViewModel
@{
    ViewData["Title"] = "Add New Section";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-1">Add New Landing Section</h2>
                    <p class="text-muted mb-0">Create a new section to showcase products on your homepage.</p>
                </div>
                <a asp-action="ManageDisplaySections" class="btn btn-light rounded-3">
                    <i class="bi bi-arrow-left me-2"></i>Back to List
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <form asp-action="CreateDisplaySection" method="post">
                        <div class="row g-4">
                            <div class="col-md-12">
                                <label class="form-label fw-bold small">Section Title</label>
                                <input asp-for="Title" class="form-control rounded-3 py-2" placeholder="e.g. New Arrivals" required />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold small">Subtitle (Optional)</label>
                                <input asp-for="Subtitle" class="form-control rounded-3 py-2" placeholder="e.g. Check out our latest collection" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Section Type</label>
                                <select asp-for="SectionType" class="form-select rounded-3 py-2">
                                    <option value="Grid">Product Grid</option>
                                    <option value="Slider">Product Slider</option>
                                    <option value="Banner">Promo Banner</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Display Order</label>
                                <input asp-for="DisplayOrder" type="number" class="form-control rounded-3 py-2" value="1" min="1" required />
                            </div>
                            <div class="col-md-12">
                                <div class="form-check form-switch p-0 d-flex align-items-center gap-3">
                                    <label class="form-check-label fw-bold small mb-0" for="isActive">Is Active</label>
                                    <input asp-for="IsActive" class="form-check-input ms-0" type="checkbox" id="isActive" checked />
                                </div>
                            </div>
                            <div class="col-md-12 pt-3">
                                <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold">
                                    <i class="bi bi-save me-2"></i>Create Section
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
