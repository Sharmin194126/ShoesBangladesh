@model ShoesBangladesh.API.ViewModels.SystemSettingsDTO

@{
    ViewData["Title"] = "FB Campaign Management";
    Layout = "_AdminLayout";
    string apiBase = "http://localhost:5190";

    string ResolveUrl(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";
        if (url.StartsWith("http")) return url;
        return apiBase + (url.StartsWith("/") ? "" : "/") + url;
    }
}

<style>
    :root {
        --premium-red: #C40000;
        --charcoal: #1F1F1F;
        --gray-bg: #F8F9FA;
        --border-color: #E9ECEF;
        --gold-accent: #D4AF37;
    }

    .settings-wrapper { max-width: 1200px; margin: 0 auto; }

    .premium-page-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        margin-bottom: 2rem;
    }

    .section-title-premium {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }
    .section-title-premium i { color: var(--premium-red); font-size: 1.5rem; }
    .section-title-premium h5 { font-weight: 800; color: var(--charcoal); margin: 0; text-transform: uppercase; letter-spacing: 1px; }

    .form-label-premium {
        font-weight: 700;
        color: #495057;
        font-size: 0.85rem;
        margin-bottom: 0.6rem;
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control-premium {
        border-radius: 12px;
        padding: 0.8rem 1.2rem;
        border: 1px solid var(--border-color);
        background: var(--gray-bg);
        font-size: 0.95rem;
        transition: all 0.3s;
    }
    .form-control-premium:focus {
        background: #fff;
        border-color: var(--premium-red);
        box-shadow: 0 0 0 4px rgba(196, 0, 0, 0.05);
    }

    .upload-preview-container {
        background: var(--gray-bg);
        border: 2px dashed var(--border-color);
        border-radius: 16px;
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s;
    }
    .upload-preview-container:hover { border-color: var(--premium-red); background: #fff; }

    .preview-img-premium {
        max-height: 120px;
        width: 100%;
        object-fit: contain;
        border-radius: 12px;
        margin-bottom: 1rem;
    }

    .btn-update-premium {
        background: var(--charcoal);
        color: #fff;
        padding: 1.2rem 2.5rem;
        border-radius: 50px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        border: none;
        transition: all 0.3s;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }
    .btn-update-premium:hover { background: var(--premium-red); transform: translateY(-2px); box-shadow: 0 8px 20px rgba(196, 0, 0, 0.3); color: #fff; }

    .switch-premium .form-check-input {
        width: 3em;
        height: 1.5em;
        cursor: pointer;
    }
    .switch-premium .form-check-input:checked { background-color: var(--premium-red); border-color: var(--premium-red); }
</style>

<div class="settings-wrapper py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-900 mb-1" style="color: var(--charcoal);">FB Campaign <span style="color: var(--premium-red);">Management</span></h2>
            <p class="text-muted mb-0 small">Configure your specialized landing page for social media traffic.</p>
        </div>
        <a href="/Landing" target="_blank" class="btn btn-outline-dark rounded-pill px-4 fw-bold">
            <i class="bi bi-eye me-2"></i> View Live Page
        </a>
    </div>

    <form asp-action="UpdateSettings" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="HeroImageUrl" />
        <input type="hidden" asp-for="HeroBgImageUrl" />
        <input type="hidden" asp-for="BannerImageUrl" />

        <div class="row">
            <div class="col-lg-8">
                <!-- Hero & Offer -->
                <div class="premium-page-card">
                    <div class="section-title-premium">
                        <i class="bi bi-lightning-charge"></i>
                        <h5>Hero Section & Primary Offer</h5>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-8">
                            <label class="form-label-premium">Eid Offer Title</label>
                            <input asp-for="EidOfferTitle" class="form-control-premium w-100" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-premium">Global Discount (%)</label>
                            <input asp-for="DiscountPercentage" type="number" class="form-control-premium w-100" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label-premium">Eid Offer Subtitle</label>
                            <input asp-for="EidOfferSubtitle" class="form-control-premium w-100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-premium">Offer End Time</label>
                            <input asp-for="EidOfferEndTime" type="datetime-local" class="form-control-premium w-100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-premium">Campaign Status</label>
                            <div class="form-check form-switch switch-premium mt-2">
                                <input asp-for="IsOfferActive" class="form-check-input" type="checkbox">
                                <label class="form-check-label ms-2 fw-bold text-muted">Is Offer Active</label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Banner Section -->
                <div class="premium-page-card">
                    <div class="section-title-premium">
                        <i class="bi bi-star"></i>
                        <h5>Middle Banner & Promo Card</h5>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label-premium">Banner Title</label>
                            <input asp-for="BannerTitle" class="form-control-premium w-100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-premium">Banner Description</label>
                            <input asp-for="BannerDescription" class="form-control-premium w-100" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-premium">Card Promo Title</label>
                            <input asp-for="OfferCardTitle" class="form-control-premium w-100" placeholder="e.g. 25%" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-premium">Card Subtitle</label>
                            <input asp-for="OfferCardSubtitle" class="form-control-premium w-100" placeholder="e.g. EXTRA OFF" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-premium">Coupon Code</label>
                            <input asp-for="OfferCardCouponCode" class="form-control-premium w-100" />
                        </div>
                    </div>
                </div>

                <!-- Branding -->
                <div class="premium-page-card">
                    <div class="section-title-premium">
                        <i class="bi bi-globe"></i>
                        <h5>Branding & Links</h5>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="form-label-premium">Company Name</label>
                            <input asp-for="CompanyName" class="form-control-premium w-100" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label-premium">Facebook Page Link</label>
                            <input asp-for="FacebookPageLink" class="form-control-premium w-100" />
                        </div>
                    </div>
                </div>

                <div class="text-end mb-5">
                    <button type="submit" class="btn-update-premium w-100 py-3">
                        <i class="bi bi-check2-circle me-2"></i> Save All Campaign Changes
                    </button>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- Image Management -->
                <div class="premium-page-card">
                    <div class="section-title-premium">
                        <i class="bi bi-images"></i>
                        <h5>Visual Assets</h5>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-premium">Hero Image (Shoe)</label>
                        <div class="upload-preview-container">
                            <img src="@ResolveUrl(Model.HeroImageUrl)" id="heroPreview" class="preview-img-premium">
                            <input type="file" name="heroImage" class="form-control form-control-sm" onchange="previewImage(this, 'heroPreview')" accept="image/*" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-premium">Hero Background</label>
                        <div class="upload-preview-container">
                            <img src="@ResolveUrl(Model.HeroBgImageUrl)" id="bgPreview" class="preview-img-premium" style="object-fit: cover;">
                            <input type="file" name="bgImage" class="form-control form-control-sm" onchange="previewImage(this, 'bgPreview')" accept="image/*" />
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label-premium">Classic Series Banner</label>
                        <div class="upload-preview-container">
                            <img src="@ResolveUrl(Model.BannerImageUrl)" id="bannerPreview" class="preview-img-premium" style="object-fit: cover;">
                            <input type="file" name="bannerImage" class="form-control form-control-sm" onchange="previewImage(this, 'bannerPreview')" accept="image/*" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    function previewImage(input, previewId) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById(previewId).setAttribute('src', e.target.result);
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

@if (TempData["SuccessMessage"] != null)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-4">
        <div class="toast show align-items-center text-white bg-dark border-0 rounded-4" role="alert">
            <div class="d-flex">
                <div class="toast-body p-3">
                    <i class="bi bi-check-circle-fill text-success me-2"></i> @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}
