@model ShoesBangladesh.API.ViewModels.SystemSettingsDTO

@{
    ViewData["Title"] = "Landing Page Settings";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card-admin">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Update Site Content</h5>
                <a href="/Landing" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                    <i class="bi bi-eye me-1"></i> View Changes
                </a>
            </div>

            <form asp-action="UpdateSettings" method="post">
                <!-- Hero Section Offer -->
                <div class="section-title mb-3 text-primary small fw-bold text-uppercase">Hero Section & Offers</div>
                <div class="row g-3 mb-4">
                    <div class="col-md-8">
                        <label class="form-label small fw-bold">Offer Title</label>
                        <input asp-for="EidOfferTitle" class="form-control rounded-3" placeholder="e.g. Eid-ul-Adha Special" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Discount (%)</label>
                        <input asp-for="DiscountPercentage" type="number" class="form-control rounded-3" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label small fw-bold">Offer Subtitle</label>
                        <input asp-for="EidOfferSubtitle" class="form-control rounded-3" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Offer End Date</label>
                        <input asp-for="EidOfferEndTime" type="datetime-local" class="form-control rounded-3" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label d-block small fw-bold">Offer Status</label>
                        <div class="form-check form-switch mt-2">
                            <input asp-for="IsOfferActive" class="form-check-input" type="checkbox">
                            <label class="form-check-label">Show Eid Offer Section</label>
                        </div>
                    </div>
                </div>

                <!-- Company & Product Descriptions -->
                <div class="section-title mb-3 text-primary small fw-bold text-uppercase">Company & Product Info</div>
                <div class="row g-3 mb-4">
                    <div class="col-md-12">
                        <label class="form-label small fw-bold">Company Name</label>
                        <input asp-for="CompanyName" class="form-control rounded-3" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label small fw-bold">Company Description (Footer)</label>
                        <textarea asp-for="CompanyDescription" class="form-control rounded-3" rows="3"></textarea>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label small fw-bold">Product Collection Description</label>
                        <textarea asp-for="ProductSectionDescription" class="form-control rounded-3" rows="3" placeholder="Describe your product collection..."></textarea>
                    </div>
                </div>

                <!-- Social Links -->
                <div class="section-title mb-3 text-primary small fw-bold text-uppercase">Social & Contact</div>
                <div class="row g-3 mb-4">
                    <div class="col-md-12">
                        <label class="form-label small fw-bold">Facebook Page Link</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-facebook text-primary"></i></span>
                            <input asp-for="FacebookPageLink" class="form-control border-start-0 rounded-end-3" />
                        </div>
                    </div>
                </div>

                <div class="border-top pt-4 mt-2">
                    <button type="submit" class="btn btn-primary px-5 py-2 fw-bold rounded-3">
                        <i class="bi bi-save me-2"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card-admin bg-light border-0">
            <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i> How it works</h6>
            <p class="small text-muted mb-3">The information you provide here is used across your landing page to attract customers.</p>
            <ul class="small text-muted ps-3 mb-0">
                <li class="mb-2"><strong>Hero Section:</strong> Changes the main banner and countdown timer.</li>
                <li class="mb-2"><strong>Descriptions:</strong> Updated in the footer and product section headers.</li>
                <li><strong>Status:</strong> Use the switch to temporarily hide the Eid campaign.</li>
            </ul>
        </div>
        
        <div class="card-admin mt-3 border-0 bg-primary bg-opacity-10">
            <h6 class="fw-bold text-primary mb-2">Need to add products?</h6>
            <p class="small text-muted mb-3">Go to the Product Management section to add products with desktop image upload.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-primary w-100 rounded-pill">Manage Products</a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show align-items-center text-white bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}
