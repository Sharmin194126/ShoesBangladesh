@model ShoesBangladeshWebApp.ViewModels.SystemSettingsDTO

@{
    ViewData["Title"] = "Manage Landing Page";
    Layout = "_Layout";
}

<div class="admin-container p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-megaphone-fill me-2"></i> Manage Landing Page</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Dashboard</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">Eid Special Offer Settings</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="UpdateSettings" method="post">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Offer Title</label>
                                <input asp-for="EidOfferTitle" class="form-control" placeholder="e.g. Eid-ul-Adha Mega Sale" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Offer Subtitle</label>
                                <textarea asp-for="EidOfferSubtitle" class="form-control" rows="2" placeholder="Describe the offer..."></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Discount Percentage (%)</label>
                                <input asp-for="DiscountPercentage" type="number" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Offer Ending Date & Time</label>
                                <input asp-for="EidOfferEndTime" type="datetime-local" class="form-control" value="@Model.EidOfferEndTime.ToString("yyyy-MM-ddTHH:mm")" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Facebook Page Link</label>
                                <input asp-for="FacebookPageLink" class="form-control" placeholder="https://facebook.com/yourpage" />
                            </div>
                            <div class="col-md-12 mt-4">
                                <div class="form-check form-switch">
                                    <input asp-for="IsOfferActive" class="form-check-input" type="checkbox" id="offerActive">
                                    <label class="form-check-label fw-bold" for="offerActive">Enable Eid Offer Section on Landing Page</label>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold">SAVE ALL SETTINGS</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 bg-light p-4">
                <h5>Tips for High Conversion</h5>
                <ul class="mt-3 text-muted">
                    <li>Use urgent words like "Limited Time Only".</li>
                    <li>Ensure your Offer Title is bold and clear.</li>
                    <li>Set the countdown timer to at least 24 hours in the future.</li>
                    <li>Sync your Facebook ads with these settings for a seamless customer experience.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        border-color: #6c5ce7;
        box-shadow: 0 0 0 0.25rem rgba(108, 92, 231, 0.1);
    }
    .btn-primary {
        background: #6c5ce7;
        border: none;
    }
    .btn-primary:hover {
        background: #5b4bc4;
    }
</style>
