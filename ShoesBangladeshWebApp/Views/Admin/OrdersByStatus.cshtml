@model List<ShoesBangladesh.API.ViewModels.RecentOrderViewModel>
@{
    ViewData["Title"] = ViewBag.Status + " Orders";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">@ViewBag.Status Orders</h2>
            <p class="text-muted mb-0">Showing all orders currently in the "@ViewBag.Status" state.</p>
        </div>
        <div class="d-flex gap-2">
            <div class="dropdown">
                <button class="btn btn-white shadow-sm border-0 rounded-3 dropdown-toggle" data-bs-toggle="dropdown">
                    Filter by Status
                </button>
                <ul class="dropdown-menu border-0 shadow-sm">
                    <li><a class="dropdown-item" asp-action="OrdersByStatus" asp-route-status="Pending">Pending</a></li>
                    <li><a class="dropdown-item" asp-action="OrdersByStatus" asp-route-status="Processing">Processing</a></li>
                    <li><a class="dropdown-item" asp-action="OrdersByStatus" asp-route-status="Shipped">Shipped</a></li>
                    <li><a class="dropdown-item" asp-action="OrdersByStatus" asp-route-status="Delivered">Delivered</a></li>
                    <li><a class="dropdown-item" asp-action="OrdersByStatus" asp-route-status="Cancelled">Cancelled</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background: #1F1F1F !important; color: #fff !important;">
                        <tr>
                            <th class="ps-4 border-0 py-3">Order ID</th>
                            <th class="border-0 py-3">Customer</th>
                            <th class="border-0 py-3">Date</th>
                            <th class="border-0 py-3">Amount</th>
                            <th class="border-0 py-3">Payment</th>
                            <th class="border-0 py-3 pe-4 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium text-primary">#@order.OrderId</td>
                                    <td>@order.CustomerName</td>
                                    <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                                    <td class="fw-bold">৳@order.Amount.ToString("N0")</td>
                                    <td>
                                        @if (order.PaymentStatus == "Paid")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">@order.PaymentStatus</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">@order.PaymentStatus</span>
                                        }
                                        <small class="text-muted ms-1">(@order.PaymentMethod)</small>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="btn-group">
                                            <button class="btn btn-light btn-sm rounded-3 me-2">Details</button>
                                            <div class="dropdown">
                                                <button class="btn btn-light btn-sm rounded-3 dropdown-toggle" data-bs-toggle="dropdown">Status</button>
                                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                                                    <li><a class="dropdown-item" href="#">Move to Processing</a></li>
                                                    <li><a class="dropdown-item" href="#">Mark as Shipped</a></li>
                                                    <li><a class="dropdown-item" href="#">Mark as Delivered</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item text-danger" href="#">Cancel Order</a></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-cart-x fs-1 d-block mb-3 opacity-50"></i>
                                    No orders found with status "@ViewBag.Status".
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
