@model List<ShoesBangladesh.Web.Models.EmployeePerformanceViewModel>
@{
    ViewData["Title"] = "Employee Performance";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Employee Sales Overview</h2>
            <p class="text-muted mb-0">Track performance metrics and sales contributions of your team members.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="EmployeeList" class="btn btn-outline-primary rounded-3 px-4">
                <i class="bi bi-people me-2"></i>View All Employees
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        @foreach (var emp in Model)
        {
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-person-badge fs-3"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-0">@emp.EmployeeName</h5>
                                <span class="badge bg-light text-muted border">Employee ID: #@emp.EmployeeId</span>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <div class="p-3 bg-light rounded-3">
                                    <small class="text-muted d-block mb-1">Total Sales</small>
                                    <h5 class="fw-bold mb-0">৳@emp.TotalSalesValue.ToString("N0")</h5>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-light rounded-3">
                                    <small class="text-muted d-block mb-1">Products Sold</small>
                                    <h5 class="fw-bold mb-0">@emp.ProductsSold Pcs</h5>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary rounded-3">View Details</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-transparent border-0 p-4">
            <h5 class="fw-bold mb-0">Performance Ranking</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 border-0 py-3">Rank</th>
                            <th class="border-0 py-3">Employee</th>
                            <th class="border-0 py-3">Revenue Contribution</th>
                            <th class="border-0 py-3">Volume</th>
                            <th class="border-0 py-3 pe-4 text-end">Progress to Goal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var emp in Model.OrderByDescending(e => e.TotalSalesValue))
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width: 30px; height: 30px; font-size: 0.8rem;">
                                        @rank
                                    </div>
                                </td>
                                <td class="fw-bold">@emp.EmployeeName</td>
                                <td class="text-success fw-bold">৳@emp.TotalSalesValue.ToString("N0")</td>
                                <td>@emp.ProductsSold Pcs</td>
                                <td class="pe-4 text-end">
                                    @{ var pct = Math.Min(100, (emp.TotalSalesValue / 100000) * 100); }
                                    <div class="d-flex align-items-center justify-content-end gap-3">
                                        <div class="progress rounded-pill" style="height: 6px; width: 100px;">
                                            <div class="progress-bar" style="width: @pct%;"></div>
                                        </div>
                                        <span class="small fw-bold">@pct.ToString("0")%</span>
                                    </div>
                                </td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
