@model List<ShoesBangladesh.API.ViewModels.ReviewViewModel>
@{
    ViewData["Title"] = "Manage Reviews";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Customer Reviews</h2>
            <p class="text-muted mb-0">Monitor and moderate product reviews left by customers.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-success rounded-3">
                <i class="bi bi-check-all me-2"></i>Approve All
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background: #1F1F1F !important; color: #fff !important;">
                        <tr>
                            <th class="ps-4 border-0 py-3">Product</th>
                            <th class="border-0 py-3">Customer</th>
                            <th class="border-0 py-3">Rating</th>
                            <th class="border-0 py-3">Comment</th>
                            <th class="border-0 py-3">Date</th>
                            <th class="border-0 py-3">Status</th>
                            <th class="border-0 py-3 pe-4 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var review in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@review.ProductName</div>
                                        <small class="text-muted">ID: #@review.ProductId</small>
                                    </td>
                                    <td>@review.CustomerName</td>
                                    <td>
                                        <div class="text-warning">
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                <i class="bi bi-star@(i < review.Rating ? "-fill" : "")"></i>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <p class="mb-0 small text-truncate" style="max-width: 250px;">@review.Comment</p>
                                    </td>
                                    <td>@review.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (review.Status == "Active")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Approved</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">Pending</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm rounded-3 dropdown-toggle" data-bs-toggle="dropdown">
                                                Manage
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                                                <li><a class="dropdown-item" href="#"><i class="bi bi-check-circle me-2 text-success"></i>Approve</a></li>
                                                <li><a class="dropdown-item" href="#"><i class="bi bi-x-circle me-2 text-danger"></i>Reject</a></li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-trash me-2"></i>Delete</a></li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-star fs-1 d-block mb-3 opacity-50"></i>
                                    No reviews to display.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
