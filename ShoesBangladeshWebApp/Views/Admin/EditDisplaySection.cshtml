@model ShoesBangladesh.API.ViewModels.DisplaySectionViewModel
@{
    ViewData["Title"] = "Edit Display Section";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .form-card { background: #fff; border-radius: 16px; border: 1px solid #ECECEC; box-shadow: 0 2px 12px rgba(0,0,0,0.07); padding: 2.5rem; max-width: 600px; margin: 0 auto; }
    .form-label-custom { font-size: 0.85rem; font-weight: 700; color: #1F1F1F; margin-bottom: 8px; display: block; }
    .form-control-custom {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1.5px solid #FECACA;
        border-radius: 10px;
        font-size: 0.9rem;
        font-family: 'Inter', sans-serif;
        color: #1F1F1F;
        outline: none;
        transition: 0.2s;
        background: #FAFAFA;
    }
    .form-control-custom:focus { border-color: #C40000; background: #fff; box-shadow: 0 0 0 3px rgba(196,0,0,0.08); }
    
    .btn-submit { background: #C40000; color: white; border: none; padding: 0.75rem 2.5rem; border-radius: 10px; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: 0.2s; box-shadow: 0 4px 12px rgba(196,0,0,0.1); }
    .btn-submit:hover { background: #8B0000; transform: translateY(-1px); color: white; text-decoration: none; }
    .btn-cancel { background: #F5F5F5; color: #616161; border: 1px solid #ECECEC; padding: 0.75rem 2rem; border-radius: 10px; font-weight: 600; font-size: 0.9rem; text-decoration: none; transition: 0.2s; }
    .btn-cancel:hover { background: #ECECEC; color: #1F1F1F; text-decoration: none; }
</style>

<div class="mb-4">
    <h1 style="font-size: 1.4rem; font-weight: 800; color: #1F1F1F; margin: 0;"><i class="bi bi-pencil-square me-2 text-danger"></i>Edit Display Section</h1>
    <nav aria-label="breadcrumb" class="mt-1">
        <ol class="breadcrumb mb-0" style="font-size: 0.78rem;">
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index" style="color:#C40000; text-decoration:none;">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="ManageDisplaySections" style="color:#C40000; text-decoration:none;">Homepage Sections</a></li>
            <li class="breadcrumb-item active" style="color:#9E9E9E;">Edit</li>
        </ol>
    </nav>
</div>

<div class="form-card">
    <form asp-action="EditDisplaySection" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        
        <div class="mb-3">
            <label class="form-label-custom">Section Name <span class="text-danger">*</span></label>
            <input asp-for="Title" class="form-control-custom" required placeholder="e.g. Featured Items" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label-custom">Select Category <span class="text-danger">*</span></label>
            <select asp-for="CategoryId" class="form-control-custom" required>
                <option value="">-- Choose Category --</option>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.GetProperty("id").GetInt32()">@cat.GetProperty("name").GetString()</option>
                    }
                }
            </select>
            <span asp-validation-for="CategoryId" class="text-danger small"></span>
            <small class="text-muted">Products from this category will show in this section.</small>
        </div>

        <div class="mb-3">
            <label class="form-label-custom">Display Order</label>
            <input asp-for="DisplayOrder" type="number" class="form-control-custom" />
            <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label class="form-label-custom">Status</label>
            <div class="form-check form-switch custom-switch-wrapper">
                <input asp-for="IsActive" class="form-check-input custom-switch" type="checkbox" id="isActiveCheck">
                <label class="form-check-label fw-bold ms-2" for="isActiveCheck" id="statusLabel">Active</label>
            </div>
        </div>

        <style>
            .custom-switch-wrapper { display: flex; align-items: center; padding: 0.5rem 0; }
            .custom-switch { width: 3rem !important; height: 1.5rem !important; cursor: pointer; }
            .custom-switch:checked { background-color: #2E7D32 !important; border-color: #2E7D32 !important; }
            .custom-switch:not(:checked) { background-color: #fff !important; border-color: #D9D9D9 !important; }
            #statusLabel { font-size: 0.95rem; transition: 0.2s; }
            .status-active { color: #2E7D32; }
            .status-inactive { color: #9E9E9E; }
        </style>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const check = document.getElementById('isActiveCheck');
                const label = document.getElementById('statusLabel');
                
                function updateLabel() {
                    if(check.checked) {
                        label.innerText = 'Active';
                        label.className = 'form-check-label fw-bold ms-2 status-active';
                    } else {
                        label.innerText = 'Inactive / Hidden';
                        label.className = 'form-check-label fw-bold ms-2 status-inactive';
                    }
                }
                
                check.addEventListener('change', updateLabel);
                updateLabel(); // Initial state
            });
        </script>

        <div class="d-flex justify-content-between align-items-center">
            <a asp-action="ManageDisplaySections" class="btn-cancel">Back to List</a>
            <button type="submit" class="btn-submit"><i class="bi bi-check2-circle me-1"></i> Update Section</button>
        </div>
    </form>
</div>
