@using System.Text.Json
@model JsonElement?
@{
    ViewData["Title"] = "Manage Homepage Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string marqueeText = Model?.TryGetProperty("marqueeText", out var mt) == true ? mt.GetString() ?? "" : "🚚 Cash on Delivery available all over Bangladesh! ⚡ Fast Delivery, Secure Shopping! 👟 Best Shoe Collection! ✨ Order Now for Exclusive Offers!";
    string heroHeadline = Model?.TryGetProperty("heroHeadline", out var hh) == true ? hh.GetString() ?? "" : "Best Shoe Collection in Bangladesh";
    string heroSubtitle = Model?.TryGetProperty("heroSubtitle", out var hs) == true ? hs.GetString() ?? "" : "Premium Quality, Best Price";
    string heroBtnText = Model?.TryGetProperty("heroBtnText", out var hbt) == true ? hbt.GetString() ?? "" : "Shop Now";
    string heroBtnLink = Model?.TryGetProperty("heroBtnLink", out var hbl) == true ? hbl.GetString() ?? "" : "#";
}

<style>
    .settings-card { background: #fff; border-radius: 16px; border: 1px solid #ECECEC; padding: 2rem; box-shadow: 0 2px 12px rgba(0,0,0,0.07); margin-bottom: 1.5rem; }
    .preview-marquee { background: linear-gradient(90deg, #D00000, #8B0000); color: white; padding: 10px 20px; border-radius: 10px; overflow: hidden; white-space: nowrap; font-size: 0.9rem; font-weight: 600; margin-top: 1rem; }
    .form-label-premium { font-size: 0.78rem; font-weight: 700; color: #616161; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.4rem; }
    .form-control-premium { border: 1.5px solid #ECECEC; border-radius: 10px; padding: 0.7rem 1rem; font-size: 0.9rem; transition: 0.2s; }
    .form-control-premium:focus { border-color: #D00000; box-shadow: 0 0 0 3px rgba(208,0,0,0.08); outline: none; }
    .btn-save-premium { background: linear-gradient(135deg, #D00000, #8B0000); color: white; border: none; border-radius: 10px; padding: 0.8rem 2.5rem; font-weight: 700; font-size: 0.95rem; transition: 0.2s; }
    .btn-save-premium:hover { box-shadow: 0 6px 20px rgba(208,0,0,0.3); transform: translateY(-1px); }
</style>

<div class="container-fluid px-4 py-4" style="max-width:900px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div style="background:#FFEBEE; color:#C40000; padding:10px; border-radius:8px;"><i class="bi bi-house-gear-fill fs-4"></i></div>
        <div>
            <h2 class="fw-bold mb-0">Manage Homepage Settings</h2>
            <p class="text-muted small mb-0">Control the animated marquee text and hero section content shown on the homepage.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3 border-0 mb-4"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
    }

    <form method="post">
        <!-- Marquee Section -->
        <div class="settings-card">
            <h5 class="fw-bold mb-1"><i class="bi bi-megaphone-fill text-danger me-2"></i>Animated Marquee Bar</h5>
            <p class="text-muted small mb-3">This scrolling text appears at the very top of every page. You can write it in Bengali or English.</p>
            <label class="form-label-premium">Marquee Text (Bengali/English)</label>
            <textarea name="marqueeText" class="form-control form-control-premium" rows="3" placeholder="Enter scrolling announcement text...">@marqueeText</textarea>
            <div class="preview-marquee mt-3">
                <marquee>@marqueeText</marquee>
            </div>
            <div class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i>Tip: Use emojis like 🚚 ⚡ 👟 ✨ to make it attractive.</div>
        </div>

        <!-- Hero Section Text -->
        <div class="settings-card">
            <h5 class="fw-bold mb-1"><i class="bi bi-type-h1 text-danger me-2"></i>Hero Section Text</h5>
            <p class="text-muted small mb-3">These appear on the homepage hero slider when a banner is active.</p>

            <div class="mb-3">
                <label class="form-label-premium">Main Headline</label>
                <input type="text" name="heroHeadline" class="form-control form-control-premium" value="@heroHeadline" placeholder="e.g. Best Shoe Collection in Bangladesh">
            </div>
            <div class="mb-3">
                <label class="form-label-premium">Subtitle</label>
                <input type="text" name="heroSubtitle" class="form-control form-control-premium" value="@heroSubtitle" placeholder="e.g. Premium Quality, Best Price">
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label-premium">Button Text</label>
                    <input type="text" name="heroBtnText" class="form-control form-control-premium" value="@heroBtnText" placeholder="e.g. Buy Now">
                </div>
                <div class="col-md-6">
                    <label class="form-label-premium">Button Link</label>
                    <input type="text" name="heroBtnLink" class="form-control form-control-premium" value="@heroBtnLink" placeholder="e.g. /products or #">
                </div>
            </div>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-save-premium">
                <i class="bi bi-floppy-fill me-2"></i>Save Changes
            </button>
            <a href="/" target="_blank" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-eye me-2"></i>Preview Homepage
            </a>
        </div>
    </form>
</div>
