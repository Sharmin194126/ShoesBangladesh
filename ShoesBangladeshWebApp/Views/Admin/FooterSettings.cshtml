@model ShoesBangladesh.API.ViewModels.FooterInfoViewModel
@{
    ViewData["Title"] = "Footer Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary rounded-3 shadow-sm">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
            <div>
                <h2 class="fw-bold mb-1">Footer & Contact Settings</h2>
                <p class="text-muted mb-0">Update your store's contact information and social media links.</p>
            </div>
        </div>
        <div>
            <span class="badge bg-light text-dark border shadow-sm px-3 py-2 rounded-3">
                <i class="bi bi-clock-history me-1 text-primary"></i> Last Updated: @Model.LastUpdated.ToString("dd MMM yyyy, hh:mm tt")
            </span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="FooterSettings" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-header bg-transparent border-0 p-4">
                        <h5 class="fw-bold mb-0">General Information</h5>
                    </div>
                    <div class="card-body p-4 pt-0">
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Store Address</label>
                            <textarea asp-for="Address" class="form-control rounded-3" rows="3" placeholder="Enter physical address..."></textarea>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Contact Number</label>
                                <input asp-for="ContactNumber" type="text" class="form-control rounded-3" placeholder="+880 1XXX-XXXXXX">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Email Address</label>
                                <input asp-for="Email" type="email" class="form-control rounded-3" placeholder="support@shoesbd.com">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-transparent border-0 p-4">
                        <h5 class="fw-bold mb-0">Social Media Links</h5>
                    </div>
                    <div class="card-body p-4 pt-0">
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Facebook URL</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-facebook text-primary"></i></span>
                                <input asp-for="FacebookUrl" type="url" class="form-control rounded-3 border-0 bg-light" placeholder="https://facebook.com/shoesbd">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Instagram URL</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-instagram text-danger"></i></span>
                                <input asp-for="InstagramUrl" type="url" class="form-control rounded-3 border-0 bg-light" placeholder="https://instagram.com/shoesbd">
                            </div>
                        </div>
                        <div class="mb-0">
                            <label class="form-label fw-bold small">Twitter URL</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-twitter text-info"></i></span>
                                <input asp-for="TwitterUrl" type="url" class="form-control rounded-3 border-0 bg-light" placeholder="https://twitter.com/shoesbd">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 2rem;">
                    <div class="card-body p-4 text-center">
                        <img src="https://illustrations.popsy.co/amber/digital-marketing.svg" alt="Settings" style="width: 150px; margin-bottom: 2rem;">
                        <h5 class="fw-bold">Ready to save?</h5>
                        <p class="text-muted small">Changes will be reflected immediately in the store footer.</p>
                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold">
                            <i class="bi bi-save me-2"></i>Save Changes
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
