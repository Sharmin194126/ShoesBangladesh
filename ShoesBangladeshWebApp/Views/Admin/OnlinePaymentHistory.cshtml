@model List<ShoesBangladesh.Web.Models.PaymentHistoryViewModel>
@{
    ViewData["Title"] = "Payment History";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Online Payment History</h2>
            <p class="text-muted mb-0">Track all digital transactions and payment statuses.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary rounded-3">
                <i class="bi bi-filter me-2"></i>Filter
            </button>
            <button class="btn btn-primary rounded-3">
                <i class="bi bi-file-earmark-excel me-2"></i>Export
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 border-0 py-3">Transaction ID</th>
                            <th class="border-0 py-3">Order ID</th>
                            <th class="border-0 py-3">Customer</th>
                            <th class="border-0 py-3">Gateway</th>
                            <th class="border-0 py-3">Amount</th>
                            <th class="border-0 py-3">Date</th>
                            <th class="border-0 py-3">Status</th>
                            <th class="border-0 py-3 pe-4 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium">@item.TransactionId</td>
                                    <td><a href="#" class="text-decoration-none">#@item.OrderId</a></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="bg-light p-2 rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-person text-secondary"></i>
                                            </div>
                                            <span>@item.CustomerName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border rounded-pill px-3">@item.GatewayName</span>
                                    </td>
                                    <td class="fw-bold">৳@item.Amount.ToString("N2")</td>
                                    <td>@item.PaymentDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td>
                                        @if (item.Status == "Success")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">@item.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">@item.Status</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <button class="btn btn-light btn-sm rounded-3">Details</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                    No payment history found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
