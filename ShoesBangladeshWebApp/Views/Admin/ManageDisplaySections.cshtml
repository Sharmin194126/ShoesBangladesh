@model List<ShoesBangladesh.API.ViewModels.DisplaySectionViewModel>
@{
    ViewData["Title"] = "Manage Homepage Sections";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-card { background: #fff; border-radius: 16px; border: 1px solid #ECECEC; box-shadow: 0 2px 12px rgba(0,0,0,0.07); padding: 1.5rem; margin-bottom: 2rem; }
    .theme-back-btn { background: #F5F5F5; color: #2B2B2B; border: 1px solid #ECECEC; padding: 0.5rem 1.25rem; border-radius: 8px; font-weight: 600; font-size: 0.85rem; text-decoration: none; transition: 0.2s; }
    .theme-back-btn:hover { background: #ECECEC; color: #1F1F1F; text-decoration: none; }
    
    .btn-custom-primary {
        background: linear-gradient(135deg, #ff2d2d 0%, #C40000 100%);
        color: white;
        border: none;
        padding: 0.5rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s;
        box-shadow: 0 3px 10px rgba(196,0,0,0.2);
        text-decoration: none;
    }
    .btn-custom-primary:hover { background: linear-gradient(135deg, #C40000 0%, #8B0000 100%); color: white; transform: translateY(-1px); text-decoration: none; }

    .table-custom { width: 100%; border-collapse: separate; border-spacing: 0; }
    .table-custom thead th { background: #C40000 !important; color: #fff !important; font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; border: none; padding: 1.1rem 1rem; white-space: nowrap; }
    .table-custom thead th:first-child { border-top-left-radius: 12px; }
    .table-custom thead th:last-child { border-top-right-radius: 12px; }
    
    .table-custom tbody td { padding: 1rem; vertical-align: middle; font-size: 0.85rem; color: #424242; border-bottom: 1px solid #ECECEC; }
    .table-custom tbody tr:hover td { background-color: #FFEBEE; }

    .action-btn { width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; transition: 0.2s; text-decoration: none; border: 1px solid #ECECEC; background: #fff; margin-right: 4px; }
    .btn-edit { color: #FBC02D; }
    .btn-edit:hover { background: #FBC02D; color: #fff; border-color: #FBC02D; }
    .btn-delete { color: #C40000; }
    .btn-delete:hover { background: #C40000; color: #fff; border-color: #C40000; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1" style="color: #1F1F1F;">Manage Homepage Display Sections</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Define which sections appear on the homepage sidebar and product grids.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Admin" asp-action="Index" class="theme-back-btn">Back</a>
        <a asp-action="CreateDisplaySection" class="btn-custom-primary">
            <i class="bi bi-plus-circle me-1"></i> Add New Section
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
        <i class="bi bi-check-circle me-1"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="page-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th style="width: 70px; text-align: center;">SL No</th>
                    <th style="width: 80px; text-align: center;">Order</th>
                    <th>Section Name</th>
                    <th>Subtitle</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th class="text-center" style="width: 150px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ var sl = 1; }
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold text-muted">@(sl++)</td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@item.DisplayOrder</span>
                            </td>
                            <td>
                                <span class="fw-bold text-dark">@item.Title</span>
                            </td>
                            <td class="text-muted small">@item.Subtitle</td>
                            <td>
                                <span class="badge bg-light text-dark border">@item.SectionType</span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hidden</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center">
                                    <a asp-action="EditDisplaySection" asp-route-id="@item.Id" class="action-btn btn-edit" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-action="DeleteDisplaySection" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this section?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-btn btn-delete" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                            No display sections found. Default sections will be used on homepage.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4">
    <div class="alert alert-info small rounded-3">
        <i class="bi bi-info-circle me-1"></i> 
        <strong>Note:</strong> These sections define the dynamic categories on the homepage sidebar and product grids. 
        Products must have their "Home Display Section" set to match these names exactly.
    </div>
</div>
