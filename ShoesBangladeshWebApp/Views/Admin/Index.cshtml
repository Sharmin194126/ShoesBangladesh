@model ShoesBangladesh.API.ViewModels.AdminStatsViewModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment _env
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .stat-card {
        padding: 20px;
        border-radius: 15px;
        color: white;
        margin-bottom: 20px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        transition: transform 0.3s ease;
        display: block;
        text-decoration: none;
        position: relative;
        overflow: hidden;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        color: white;
    }
    .bg-delivered { background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%); }
    .bg-pending { background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%); color: #333 !important; }
    .bg-processing { background: linear-gradient(135deg, #17a2b8 0%, #117a8b 100%); }
    .bg-revenue { background: linear-gradient(135deg, #532374 0%, #3a1852 100%); }
    
    .stat-card i {
        position: absolute;
        right: 15px;
        bottom: 10px;
        font-size: 3rem;
        opacity: 0.2;
    }

    .table-container {
        background: white;
        padding: 25px;
        border-radius: 20px;
        margin-top: 20px;
        border: 1px solid #eef2f7;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }
    .table-container h4 {
        color: #333;
        margin-bottom: 20px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .quick-link-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 15px;
        text-align: center;
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #475569;
    }
    .quick-link-card:hover {
        background: white;
        border-color: #6366f1;
        color: #6366f1;
        transform: translateY(-3px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.1);
    }
    .quick-link-card i {
        font-size: 1.5rem;
        margin-bottom: 8px;
    }
    .quick-link-card span {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .chart-box {
        height: 300px;
        margin-top: 20px;
    }
</style>

<div class="container-fluid p-0">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-extrabold text-dark">Welcome back, Admin! 👋</h2>
            <p class="text-muted">Here's what's happening with your store today.</p>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="stat-card bg-delivered">
                <div class="stat-label">Delivered Orders</div>
                <div class="h2 fw-bold mb-0">@Model.TotalDelivered</div>
                <i class="bi bi-check2-circle"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card bg-pending">
                <div class="stat-label">Pending Orders</div>
                <div class="h2 fw-bold mb-0">@Model.TotalPending</div>
                <i class="bi bi-clock-history"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card bg-processing">
                <div class="stat-label">In Processing</div>
                <div class="h2 fw-bold mb-0">@Model.TotalProcessing</div>
                <i class="bi bi-gear-wide-connected"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card bg-revenue">
                <div class="stat-label">Total Revenue</div>
                <div class="h2 fw-bold mb-0">৳@Model.TotalRevenue.ToString("#,##0")</div>
                <i class="bi bi-cash-stack"></i>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Quick Management -->
        <div class="col-lg-4 mb-4">
            <div class="table-container h-100">
                <h4><i class="bi bi-lightning-fill text-warning"></i> Quick Actions</h4>
                <div class="row g-3">
                    <div class="col-6">
                        <a asp-controller="Product" asp-action="Create" class="quick-link-card">
                            <i class="bi bi-plus-circle text-primary"></i>
                            <span>Add Product</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Admin" asp-action="ManageLandingPage" class="quick-link-card">
                            <i class="bi bi-window-sidebar text-success"></i>
                            <span>Landing Page</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Admin" asp-action="EmployeeList" class="quick-link-card">
                            <i class="bi bi-people text-info"></i>
                            <span>Employees</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Admin" asp-action="Reports" class="quick-link-card">
                            <i class="bi bi-file-earmark-bar-graph text-danger"></i>
                            <span>Reports</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Admin" asp-action="Messages" class="quick-link-card">
                            <i class="bi bi-chat-dots text-purple"></i>
                            <span>Messages</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Admin" asp-action="FooterSettings" class="quick-link-card">
                            <i class="bi bi-gear text-secondary"></i>
                            <span>Settings</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sales Chart -->
        <div class="col-lg-8 mb-4">
            <div class="table-container h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4><i class="bi bi-bar-chart-fill text-primary"></i> Sales Analytics</h4>
                    <select class="form-select form-select-sm w-auto" id="chartRange">
                        <option value="weekly">Weekly</option>
                        <option value="monthly">Monthly</option>
                    </select>
                </div>
                <div class="chart-box">
                    <canvas id="salesAnalyticsChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent History -->
    <div class="row">
        <div class="col-12">
            <div class="table-container">
                <h4><i class="bi bi-clock-history text-secondary"></i> Sales History (Last 6 Months)</h4>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Month</th>
                                <th>Revenue</th>
                                <th>Pieces Sold</th>
                                <th>Growth</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var month in Model.MonthlyHistory.OrderByDescending(m => m.Year).ThenByDescending(m => m.Month).Take(6))
                            {
                                <tr>
                                    <td class="fw-bold">@month.MonthName @month.Year</td>
                                    <td class="text-success fw-bold">৳@month.Amount.ToString("#,##0")</td>
                                    <td>@month.Pieces Pcs</td>
                                    <td>
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                                            <i class="bi bi-arrow-up-short"></i> Stable
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('salesAnalyticsChart').getContext('2d');
        
        const labels = @Html.Raw(Json.Serialize(Model.WeeklySales.Select(s => s.Date.ToString("MMM dd"))));
        const data = @Html.Raw(Json.Serialize(Model.WeeklySales.Select(s => s.Amount)));

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Revenue (৳)',
                    data: data,
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99, 102, 241, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#6366f1'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#f1f5f9' },
                        ticks: { callback: val => '৳' + val.toLocaleString() }
                    },
                    x: {
                        grid: { display: false }
                    }
                }
            }
        });
    </script>
}
