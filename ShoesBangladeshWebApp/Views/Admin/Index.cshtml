@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="dashboard-container">
    <div class="sidebar">
        <div class="sidebar-header">
            <h3>Admin Panel</h3>
        </div>
        <ul class="sidebar-menu">
            <li><a href="#" class="active"><i class="fas fa-chart-line"></i> Statistics</a></li>
            <li><a asp-controller="Product" asp-action="Index"><i class="fas fa-box"></i> Manage Products</a></li>
            <li><a href="#"><i class="fas fa-users"></i> Customers</a></li>
            <li><a href="#"><i class="fas fa-shopping-cart"></i> Orders</a></li>
            <li><a asp-controller="Account" asp-action="Logout" class="logout-link"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
        </ul>
    </div>
    <div class="main-content">
        <div class="top-nav">
            <h2>Dashboard Overview</h2>
            <div class="user-info">
                <span>Welcome, <strong>@User.Identity?.Name</strong></span>
            </div>
        </div>
        
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon orders"><i class="fas fa-shopping-bag"></i></div>
                <div class="stat-details">
                    <h3>150</h3>
                    <p>Total Orders</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon products"><i class="fas fa-shoe-prints"></i></div>
                <div class="stat-details">
                    <h3>85</h3>
                    <p>Active Products</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon revenue"><i class="fas fa-dollar-sign"></i></div>
                <div class="stat-details">
                    <h3>$12,450</h3>
                    <p>Total Revenue</p>
                </div>
            </div>
        </div>

        <div class="recent-orders">
            <h3>Recent Activities</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Product</th>
                        <th>Status</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>#ORD-001</td>
                        <td>John Doe</td>
                        <td>Nike Air Max</td>
                        <td><span class="badge bg-success">Completed</span></td>
                        <td>$120.00</td>
                    </tr>
                    <tr>
                        <td>#ORD-002</td>
                        <td>Jane Smith</td>
                        <td>Adidas Ultraboost</td>
                        <td><span class="badge bg-warning">Pending</span></td>
                        <td>$180.00</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .dashboard-container {
        display: flex;
        min-height: 90vh;
        background: #f8f9fa;
        margin: -24px; /* Counter container padding */
    }
    .sidebar {
        width: 250px;
        background: #2d3436;
        color: white;
        padding: 20px;
    }
    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin-top: 30px;
    }
    .sidebar-menu li a {
        display: block;
        padding: 12px 15px;
        color: #b2bec3;
        text-decoration: none;
        border-radius: 8px;
        transition: 0.3s;
    }
    .sidebar-menu li a:hover, .sidebar-menu li a.active {
        background: #0984e3;
        color: white;
    }
    .main-content {
        flex: 1;
        padding: 30px;
    }
    .top-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 40px;
    }
    .stat-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
    }
    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-right: 20px;
        font-size: 1.5rem;
        color: white;
    }
    .stat-icon.orders { background: #00b894; }
    .stat-icon.products { background: #0984e3; }
    .stat-icon.revenue { background: #6c5ce7; }
    
    .recent-orders {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }
    .logout-link { color: #ff7675 !important; }
</style>
