@{
    ViewData["Title"] = "Dashboard Overview";
    Layout = "_AdminLayout";
}

<div class="row g-4">
    <!-- Stat Cards -->
    <div class="col-md-4">
        <div class="card-admin d-flex align-items-center">
            <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-4 text-primary">
                <i class="bi bi-box-seam fs-2"></i>
            </div>
            <div>
                <h6 class="text-muted mb-1">Total Products</h6>
                <h3 class="fw-bold mb-0">Manage</h3>
                <a asp-controller="Product" asp-action="Index" class="small text-primary text-decoration-none">View all products</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-admin d-flex align-items-center">
            <div class="bg-success bg-opacity-10 p-3 rounded-3 me-4 text-success">
                <i class="bi bi-window-sidebar fs-2"></i>
            </div>
            <div>
                <h6 class="text-muted mb-1">Landing Page</h6>
                <h3 class="fw-bold mb-0">Active</h3>
                <a asp-action="ManageLandingPage" class="small text-success text-decoration-none">Update settings</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-admin d-flex align-items-center">
            <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-4 text-warning">
                <i class="bi bi-people fs-2"></i>
            </div>
            <div>
                <h6 class="text-muted mb-1">Role</h6>
                <h3 class="fw-bold mb-0">Administrator</h3>
                <span class="small text-muted">Full Access</span>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-lg-8">
        <div class="card-admin h-100">
            <h5 class="fw-bold mb-4">Quick Actions</h5>
            <div class="d-grid gap-3 d-md-flex">
                <a asp-controller="Product" asp-action="Create" class="btn btn-primary px-4 py-2 rounded-3">
                    <i class="bi bi-plus-lg me-2"></i> Add New Product
                </a>
                <a asp-action="ManageLandingPage" class="btn btn-outline-dark px-4 py-2 rounded-3">
                    <i class="bi bi-gear me-2"></i> Landing Settings
                </a>
                <a href="/Landing" target="_blank" class="btn btn-outline-primary px-4 py-2 rounded-3">
                    <i class="bi bi-eye me-2"></i> Preview Site
                </a>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card-admin h-100 bg-dark text-white">
            <h5 class="fw-bold mb-3">System Notification</h5>
            <p class="text-muted small">Welcome to the new Shoes Bangladesh Admin Panel. You can now upload product images directly from your desktop.</p>
            <hr class="border-secondary">
            <div class="d-flex align-items-center">
                <i class="bi bi-info-circle me-2"></i>
                <span class="small">All systems are operational</span>
            </div>
        </div>
    </div>
</div>
