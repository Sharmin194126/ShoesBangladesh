@model ShoesBangladesh.API.ViewModels.AdminStatsViewModel
@{
    ViewData["Title"] = "Admin Dashboard Overview";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --red: #C40000;
        --red-soft: #E53E3E;
        --red-tint: rgba(196,0,0,0.06);
        --charcoal: #1F1F1F;
        --charcoal-2: #2B2B2B;
        --off-white: #F8F8F8;
        --gray-100: #F5F5F5;
        --gray-200: #ECECEC;
        --gray-300: #D9D9D9;
        --gray-500: #9E9E9E;
        --gray-700: #616161;
        --shadow: 0 2px 12px rgba(0,0,0,0.07);
        --shadow-red: 0 4px 20px rgba(196,0,0,0.15);
    }

    .dashboard-container { max-width: 1600px; margin: 0 auto; }

    /* Stat Cards */
    .stat-card {
        background: #fff;
        border-radius: 14px;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 1px solid var(--gray-200);
        height: 100%;
        transition: all 0.25s;
        box-shadow: var(--shadow);
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); border-color: var(--red); }
    .stat-link { text-decoration: none; color: inherit; display: block; height: 100%; }
    .stat-icon-box { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.15rem; flex-shrink: 0; }
    .bg-soft-orange { background: #FFF3E0; color: #E65100; }
    .bg-soft-red    { background: #FFEBEE; color: #C62828; }
    .bg-soft-pink   { background: #FCE4EC; color: #AD1457; }
    .bg-soft-blue   { background: #E3F2FD; color: #1565C0; }
    .stat-label { font-size: 0.68rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px; display: block; }
    .stat-value { font-size: 1.5rem; font-weight: 800; color: var(--charcoal); line-height: 1; }
    .stat-meta  { font-size: 0.65rem; font-weight: 600; }
    .growth-up  { color: #2E7D32; }

    /* Revenue Card - Elegant dark gradient */
    .revenue-card {
        background: linear-gradient(135deg, #C40000 0%, #7A0000 100%);
        border-radius: 14px;
        padding: 1.25rem;
        color: white;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: var(--shadow-red);
    }
    .revenue-card .stat-icon-box { background: rgba(255,255,255,0.15); color: white; }
    .revenue-card .stat-label { color: rgba(255,255,255,0.75); }
    .revenue-card .stat-value { color: white; font-size: 1.9rem; }
    .revenue-card .stat-meta  { color: rgba(255,255,255,0.7); }

    /* Extra Stat Cards */
    .extra-stat-card {
        background: #fff;
        border-radius: 14px;
        border: 1px solid var(--gray-200);
        padding: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100%;
        box-shadow: var(--shadow);
    }
    .extra-stat-info span { font-size: 0.63rem; font-weight: 700; color: var(--gray-500); display: block; margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.4px; }
    .extra-stat-info h4   { font-size: 1.2rem; font-weight: 800; color: var(--charcoal); margin: 0; }
    .extra-stat-info p    { font-size: 0.62rem; color: var(--gray-500); margin: 2px 0 0; }

    /* Quick Management - Charcoal + red accent */
    .quick-manage-btn {
        background: #fff;
        border: 1px solid var(--gray-200);
        border-radius: 10px;
        padding: 0.7rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        text-decoration: none;
        color: var(--charcoal-2);
        font-weight: 600;
        font-size: 0.8rem;
        transition: all 0.2s;
        box-shadow: var(--shadow);
    }
    .quick-manage-btn:hover { background: #FFEBEE; border-color: #FECACA; color: #C40000; transform: translateY(-1px); }
    .quick-manage-btn .btn-icon { width: 28px; height: 28px; border-radius: 7px; background: #FFEBEE; color: var(--red); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; margin-right: 10px; flex-shrink: 0; }
    .quick-manage-btn .bi-chevron-right { font-size: 0.65rem; color: var(--gray-300); }

    /* Dashboard cards */
    .dashboard-card { background: #fff; border-radius: 16px; border: 1px solid var(--gray-200); padding: 1.5rem; height: 100%; box-shadow: var(--shadow); }
    .card-header-custom { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
    .card-title-custom { font-weight: 700; font-size: 0.9rem; color: var(--charcoal); display: flex; align-items: center; gap: 8px; }
    .card-title-custom i { color: var(--red); }

    /* Goal */
    .goal-donut-container { position: relative; width: 120px; height: 120px; margin: 0 auto; }
    .goal-donut-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 1.2rem; font-weight: 800; color: var(--charcoal); }

    /* Tables - Charcoal header */
    .table-premium thead th {
        background: #1F1F1F !important;
        color: #FFFFFF !important;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        padding: 1.1rem 1rem;
        border: none;
    }
    .table-premium tbody td {
        font-size: 0.8rem;
        padding: 11px 14px;
        border-bottom: 1px solid var(--gray-200);
        color: var(--charcoal-2);
        background: #fff;
        vertical-align: middle;
    }
    .table-premium tbody tr:hover td { background: #FAFAFA; }

    /* Status Badges */
    .badge-delivered   { background: #E8F5E9; color: #2E7D32; padding: 4px 12px; border-radius: 20px; font-size: 0.68rem; font-weight: 700; }
    .badge-processing  { background: #E3F2FD; color: #1565C0; padding: 4px 12px; border-radius: 20px; font-size: 0.68rem; font-weight: 700; }
    .badge-pending     { background: #FFF8E1; color: #E65100; padding: 4px 12px; border-radius: 20px; font-size: 0.68rem; font-weight: 700; }
    .badge-cancelled   { background: #FAFAFA; color: #757575; padding: 4px 12px; border-radius: 20px; font-size: 0.68rem; font-weight: 700; border: 1px solid var(--gray-300); }

    /* Section header */
    .section-label { font-size: 0.68rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 8px; }
    .section-label::before { content: ''; display: inline-block; width: 3px; height: 14px; background: var(--red); border-radius: 2px; }
</style>

<div class="dashboard-container py-4">
    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div style="background: #FFEBEE; color: #C40000; padding: 10px; border-radius: 8px;"><i class="bi bi-bar-chart-fill fs-4"></i></div>
        <div>
            <h1 class="fw-bold fs-3 mb-0" style="color: #1F1F1F;">Admin Dashboard Overview</h1>
            <p class="text-muted small mb-0">Welcome back, admin! Here's what's happening with your store today.</p>
        </div>
    </div>

    <!-- Top 5 Cards Row -->
    <div class="row g-4 mb-4">
        <div class="col-xl col-md-4">
            <a asp-action="DeliveredOrders" class="stat-link">
                <div class="stat-card">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon-box bg-soft-orange"><i class="bi bi-gift-fill"></i></div>
                        <div>
                            <span class="stat-label">Delivered Orders</span>
                            <div class="stat-value">@Model.TotalDelivered</div>
                        </div>
                    </div>
                    <div class="stat-meta text-end"><span class="growth-up">+20%</span><br><span class="text-muted">vs last week</span></div>
                </div>
            </a>
        </div>
        <div class="col-xl col-md-4">
            <a asp-action="PendingOrders" class="stat-link">
                <div class="stat-card">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon-box bg-soft-red"><i class="bi bi-calendar-event-fill"></i></div>
                        <div>
                            <span class="stat-label">Pending Orders</span>
                            <div class="stat-value">@Model.TotalPending</div>
                        </div>
                    </div>
                    <div class="stat-meta text-end"><span class="growth-up">+14%</span><br><span class="text-muted">vs last week</span></div>
                </div>
            </a>
        </div>
        <div class="col-xl col-md-4">
            <a asp-action="ProcessingOrders" class="stat-link">
                <div class="stat-card">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon-box bg-soft-pink"><i class="bi bi-gear-fill"></i></div>
                        <div>
                            <span class="stat-label">In Processing</span>
                            <div class="stat-value">@Model.TotalProcessing</div>
                        </div>
                    </div>
                    <div class="stat-meta text-end"><span class="growth-up">+16%</span><br><span class="text-muted">vs last week</span></div>
                </div>
            </a>
        </div>
        <div class="col-xl col-md-6">
            <a asp-action="ShippedOrders" class="stat-link">
                <div class="stat-card">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon-box bg-soft-blue"><i class="bi bi-truck"></i></div>
                        <div>
                            <span class="stat-label">Shipped Orders</span>
                            <div class="stat-value">@Model.TotalShipped</div>
                        </div>
                    </div>
                    <div class="stat-meta text-end"><span class="growth-up">+10%</span><br><span class="text-muted">vs last week</span></div>
                </div>
            </a>
        </div>
        <div class="col-xl col-md-6">
            <div class="revenue-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon-box"><i class="bi bi-wallet2"></i></div>
                    <div>
                        <span class="stat-label">Total Revenue</span>
                        <div class="stat-value">৳@Model.TotalRevenue.ToString("#,##0")</div>
                    </div>
                </div>
                <div class="stat-meta text-end"><span class="fw-bold">+18%</span><br><span class="opacity-75">vs last week</span></div>
            </div>
        </div>
    </div>

    <!-- Quick Management -->
    <div class="mb-4">
        <div class="section-label" style="font-size: 0.82rem; font-weight: 800; color: #1F1F1F; letter-spacing: 0.3px;"><span style="display:inline-block; width:3px; height:16px; background:#C40000; border-radius:2px; margin-right:8px; vertical-align:middle;"></span>Quick Management</div>
        <div class="row g-2">
            <div class="col-md-3"><a asp-controller="Admin" asp-action="ManageDisplaySections" class="quick-manage-btn"><span class="btn-icon"><i class="bi bi-house-door-fill"></i></span> Home Sections <i class="bi bi-chevron-right"></i></a></div>
            <div class="col-md-3"><a asp-controller="Admin" asp-action="ManageLandingPage" class="quick-manage-btn"><span class="btn-icon"><i class="bi bi-megaphone"></i></span> FB Campaign Page <i class="bi bi-chevron-right"></i></a></div>
            <div class="col-md-3"><a asp-controller="Product" asp-action="Index" class="quick-manage-btn"><span class="btn-icon"><i class="bi bi-box-seam-fill"></i></span> Products <i class="bi bi-chevron-right"></i></a></div>
            <div class="col-md-3"><a asp-controller="Category" asp-action="Index" class="quick-manage-btn"><span class="btn-icon"><i class="bi bi-tags-fill"></i></span> Categories <i class="bi bi-chevron-right"></i></a></div>
            <div class="col-md-3"><a href="#" class="quick-manage-btn"><span class="btn-icon"><i class="bi bi-people-fill"></i></span> Customers <i class="bi bi-chevron-right"></i></a></div>
            <div class="col-md-3"><a href="#" class="quick-manage-btn"><span class="btn-icon"><i class="bi bi-person-badge-fill"></i></span> Employees <i class="bi bi-chevron-right"></i></a></div>
            <div class="col-md-3"><a asp-controller="Admin" asp-action="FooterSettings" class="quick-manage-btn"><span class="btn-icon"><i class="bi bi-gear-fill"></i></span> Footer Settings <i class="bi bi-chevron-right"></i></a></div>
            <div class="col-md-3"><a asp-controller="Admin" asp-action="OnlinePaymentHistory" class="quick-manage-btn"><span class="btn-icon"><i class="bi bi-clock-history"></i></span> Payment History <i class="bi bi-chevron-right"></i></a></div>
        </div>
    </div>

    <!-- Main Analytics Row -->
    <div class="row g-4 mb-4">
        <div class="col-xl-5">
            <div class="dashboard-card">
                <div class="card-header-custom mb-3">
                    <div>
                        <span class="text-muted fw-bold small text-uppercase">Product Sales</span>
                        <h2 class="fw-extrabold mb-0" style="font-size: 2rem; font-weight: 900; color: #1F1F1F;">৳0</h2>
                        <div class="d-flex gap-4 mt-2 small text-muted fw-bold">
                            <div>Total Amount<br><b class="text-dark">৳0</b></div>
                            <div>Total Pieces<br><b class="text-dark">0</b></div>
                            <div>Avg / Period<br><b class="text-dark">৳0</b></div>
                        </div>
                    </div>
                    <button class="btn btn-sm rounded-pill px-3" style="background: #FEE2E2; color: #C40000; border: 1px solid #FECACA; font-weight: 700;">Weekly <i class="bi bi-chevron-down ms-1"></i></button>
                </div>
                <div style="height: 300px;"><canvas id="mainChart"></canvas></div>
            </div>
        </div>

        <div class="col-xl-3">
            <div class="dashboard-card text-center">
                <div class="card-header-custom">
                    <span class="card-title-custom" style="font-size: 1.05rem; font-weight: 800;"><i class="bi bi-award-fill"></i> Sales Goal</span>
                    <div class="d-flex gap-2">
                        <span class="small fw-bold text-muted border px-2 rounded-pill">2026</span>
                        <a href="#" class="text-danger small fw-bold text-decoration-none">History</a>
                        <a href="#" class="text-muted small fw-bold text-decoration-none">Edit</a>
                    </div>
                </div>
                <div class="row g-2 text-start mb-4">
                    <div class="col-6">
                        <span class="small text-muted fw-bold">Target</span>
                        <div class="fw-bold">৳1,523,709</div>
                        <span class="text-muted" style="font-size: 0.6rem;">Full Year Goal</span>
                    </div>
                    <div class="col-6">
                        <span class="small text-muted fw-bold">Remaining</span>
                        <div class="fw-bold text-danger">৳973,740</div>
                        <span class="text-muted" style="font-size: 0.6rem;">To reach target</span>
                    </div>
                </div>
                <div class="goal-donut-container mb-4">
                    <canvas id="goalChart"></canvas>
                    <div class="goal-donut-text">36%</div>
                </div>
                <h5 class="fw-bold mb-0">৳549,970 achieved</h5>
                <p class="small text-muted">Note: Goal for 2026</p>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="dashboard-card">
                <div class="card-header-custom">
                    <span class="card-title-custom" style="font-size: 1.05rem; font-weight: 800;"><i class="bi bi-fire text-warning"></i> Top Moving Products</span>
                    <a href="#" class="btn btn-link btn-sm text-danger text-decoration-none fw-bold p-0">View Full Report</a>
                </div>
                <div class="product-list">
                    @foreach (var item in Model.TopProducts.Take(6))
                    {
                        <div class="d-flex align-items-center gap-3 py-2 border-bottom">
                            <span class="small fw-bold text-muted">1</span>
                            <img src="https://ui-avatars.com/api/?name=@item.ProductName&background=random" width="40" height="40" class="rounded-2" alt="">
                            <div class="flex-grow-1">
                                <h6 class="m-0 small fw-bold">@item.ProductName</h6>
                                <p class="m-0 text-muted" style="font-size: 0.65rem;">@item.Category</p>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-danger px-2 py-1 mb-1" style="font-size: 0.6rem;">@item.TotalQuantity Pcs</span>
                                <div class="fw-bold small">৳@item.TotalRevenue.ToString("#,##0")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Extra Stats Cards - Perfect Red Sparklines -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="extra-stat-card">
                <div class="extra-stat-info">
                    <span>TOTAL SALES</span>
                    <h4>৳549,970</h4>
                    <p>All time revenue</p>
                </div>
                <div style="width: 100px; height: 50px;"><canvas id="spark1"></canvas></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="extra-stat-card">
                <div class="extra-stat-info">
                    <span>TOTAL PROFIT (EX. VAT)</span>
                    <h4>৳530,120</h4>
                    <p>After VAT deduction</p>
                </div>
                <div style="width: 100px; height: 50px;"><canvas id="spark2"></canvas></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="extra-stat-card">
                <div class="extra-stat-info">
                    <span>VAT COLLECTED</span>
                    <h4>৳19,850</h4>
                    <p>Total tax revenue</p>
                </div>
                <div style="width: 100px; height: 50px;"><canvas id="spark3"></canvas></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="extra-stat-card">
                <div class="extra-stat-info">
                    <span>WEEKLY SALES</span>
                    <h4>৳0</h4>
                    <p>Last 7 days</p>
                </div>
                <div style="width: 100px; height: 50px;"><canvas id="spark4"></canvas></div>
            </div>
        </div>
    </div>

    <!-- Lower Row -->
    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="dashboard-card">
                <span class="card-title-custom mb-4"><i class="bi bi-pie-chart-fill"></i> Sales by Product Type</span>
                <div class="row align-items-center">
                    <div class="col-5">
                        <div style="height: 140px;"><canvas id="typeChart"></canvas></div>
                    </div>
                    <div class="col-7">
                        <div class="row g-2 small fw-bold" style="font-size: 0.65rem;">
                            <div class="col-6 d-flex align-items-center gap-1"><span class="rounded-circle" style="width: 8px; height: 8px; background: #C40000;"></span> Men <span class="text-muted">90.5%</span></div>
                            <div class="col-6 d-flex align-items-center gap-1"><span class="rounded-circle" style="width: 8px; height: 8px; background: #FFEDD5;"></span> Women <span class="text-muted">5.0%</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="dashboard-card">
                <div class="card-header-custom">
                    <span class="card-title-custom"><i class="bi bi-archive-fill"></i> Full Sales Archives</span>
                    <div class="btn-group">
                        <button class="btn btn-danger btn-sm active px-3 rounded-pill me-2">Monthly View</button>
                        <button class="btn btn-outline-danger btn-sm px-3 rounded-pill">Yearly Summary</button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead style="background: #1F1F1F !important; color: #fff !important;">
                            <tr class="small fw-bold text-white">
                                <th>MONTH / YEAR</th>
                                <th class="text-end">REVENUE (INC. VAT)</th>
                                <th class="text-center">PIECES</th>
                                <th class="text-center">REPORT</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="small fw-bold">April 2026 | May 14, 2026 | 10:58 AM</td>
                                <td class="text-end fw-bold text-success">৳7,665</td>
                                <td class="text-center"><span class="badge bg-light text-dark border px-3">3 Pcs</span></td>
                                <td class="text-center"><button class="btn btn-sm btn-outline-dark px-3 rounded-pill">View</button></td>
                            </tr>
                            <tr>
                                <td class="small fw-bold">January 2026 | May 14, 2026 | 10:58 AM</td>
                                <td class="text-end fw-bold text-success">৳542,305</td>
                                <td class="text-center"><span class="badge bg-light text-dark border px-3">126 Pcs</span></td>
                                <td class="text-center"><button class="btn btn-sm btn-outline-dark px-3 rounded-pill">View</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Final Row -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="dashboard-card p-0 overflow-hidden">
                <div class="p-3 fw-bold"><i class="bi bi-cart-fill text-danger me-2"></i> Recent Orders Detailed View</div>
                <div class="table-responsive">
                    <table class="table table-premium m-0">
                        <thead>
                            <tr>
                                <th>SL</th><th>ORDER REF</th><th>CUSTOMER</th><th>DATE & TIME</th><th>AMOUNT</th><th>STATUS</th><th>LOCATION</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders.Take(5))
                            {
                                <tr>
                                    <td>1</td><td class="fw-bold text-danger">@order.OrderId</td><td>@order.CustomerName</td>
                                    <td>@order.OrderDate.ToString("MMM dd, yyyy | hh:mm tt")</td><td class="fw-bold">৳@order.Amount.ToString("#,##0")</td>
                                    <td><span class="@(order.Status == "Delivered" ? "badge-delivered" : order.Status == "Processing" ? "badge-processing" : "badge-pending")">@order.Status</span></td>
                                    <td>Uttara, Dhaka</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="dashboard-card p-0 overflow-hidden">
                <div class="p-3 fw-bold"><i class="bi bi-people-fill text-danger me-2"></i> Employee Stats</div>
                <div class="table-responsive">
                    <table class="table table-premium m-0">
                        <thead>
                            <tr>
                                <th>SL</th><th>NAME</th><th>PROD</th><th>SOLD</th><th>VALUE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model.EmployeePerformances.Take(3))
                            {
                                <tr>
                                    <td>1</td><td class="fw-bold">@emp.EmployeeName</td><td>@emp.TotalProductsManaged</td><td>@emp.ProductsSold</td><td class="text-success fw-bold">৳@emp.TotalSalesValue.ToString("#,##0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Main Chart
        const mainCtx = document.getElementById('mainChart').getContext('2d');
        const gradient = mainCtx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(196, 0, 0, 0.4)');
        gradient.addColorStop(1, 'rgba(196, 0, 0, 0)');

        new Chart(mainCtx, {
            type: 'line',
            data: {
                labels: ['Fri, 08 May', 'Sat, 09 May', 'Sun, 10 May', 'Mon, 11 May', 'Tue, 12 May', 'Wed, 13 May', 'Thu, 14 May'],
                datasets: [{
                    data: [10, 8, 15, 12, 25, 20, 35],
                    borderColor: '#C40000',
                    backgroundColor: gradient,
                    fill: true,
                    tension: 0.4,
                    borderWidth: 4,
                    pointRadius: 6,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#C40000',
                    pointBorderWidth: 3
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { grid: { color: '#F3F4F6' } } } }
        });

        // Goal Chart
        new Chart(document.getElementById('goalChart'), {
            type: 'doughnut',
            data: { datasets: [{ data: [36, 64], backgroundColor: ['#C40000', '#F3F4F6'], borderWidth: 0, cutout: '80%', borderRadius: 10 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { tooltip: { enabled: false } } }
        });

        // Sparklines with red gradient fill (matching main chart style)
        function spark(id) {
            const ctx = document.getElementById(id).getContext('2d');
            const sparkGrad = ctx.createLinearGradient(0, 0, 0, 50);
            sparkGrad.addColorStop(0, 'rgba(196, 0, 0, 0.35)');
            sparkGrad.addColorStop(1, 'rgba(196, 0, 0, 0)');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [1, 2, 3, 4, 5, 6, 7],
                    datasets: [{
                        data: [5, 12, 8, 15, 10, 18, 14],
                        borderColor: '#C40000',
                        backgroundColor: sparkGrad,
                        fill: true,
                        borderWidth: 2.5,
                        pointRadius: 0,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { x: { display: false }, y: { display: false } }
                }
            });
        }
        spark('spark1'); spark('spark2'); spark('spark3'); spark('spark4');

        // Type Chart
        new Chart(document.getElementById('typeChart'), {
            type: 'doughnut',
            data: { datasets: [{ data: [90.5, 9.5], backgroundColor: ['#C40000', '#F3F4F6'], borderWidth: 0, cutout: '70%' }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });
    </script>
}
