@model ShoesBangladesh.API.ViewModels.AdminStatsViewModel
@{
    ViewData["Title"] = "Premium Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --primary-red: #C40000;
        --dark-red: #7A0000;
        --accent-red: #FF1E1E;
        --soft-bg: #F8F8F8;
        --card-shadow: 0 15px 35px rgba(196, 0, 0, 0.08), 0 5px 15px rgba(0, 0, 0, 0.05);
        --glass-bg: rgba(255, 255, 255, 0.9);
    }

    /* Stat Cards Glossy Effect */
    .stat-card-glossy {
        border: none;
        border-radius: 24px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        color: white;
        height: 100%;
        box-shadow: var(--card-shadow);
    }

    .stat-card-glossy:hover {
        transform: translateY(-10px);
        box-shadow: 0 25px 50px rgba(196, 0, 0, 0.15);
    }

    .stat-card-glossy::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
        pointer-events: none;
    }

    .stat-icon-wrapper {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1.25rem;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(5px);
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
        letter-spacing: -1px;
    }

    .stat-label {
        font-size: 0.85rem;
        font-weight: 600;
        opacity: 0.9;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-growth {
        font-size: 0.75rem;
        font-weight: 700;
        margin-top: 1rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 100px;
        background: rgba(255,255,255,0.2);
    }

    /* Gradients */
    .grad-red { background: linear-gradient(135deg, #C40000 0%, #7A0000 100%); }
    .grad-dark { background: linear-gradient(135deg, #450000 0%, #1a0000 100%); }
    .grad-bright { background: linear-gradient(135deg, #FF1E1E 0%, #C40000 100%); }
    .grad-purple { background: linear-gradient(135deg, #6c5ce7 0%, #4834d4 100%); }
    .grad-orange { background: linear-gradient(135deg, #ff9f43 0%, #ee5253 100%); }

    /* Quick Management */
    .quick-manage-card {
        background: white;
        border-radius: 20px;
        padding: 1.25rem;
        text-align: center;
        border: 1px solid rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        text-decoration: none;
        color: #2d3436;
        display: block;
        height: 100%;
    }

    .quick-manage-card:hover {
        background: var(--primary-red);
        color: white !important;
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(196, 0, 0, 0.1);
    }

    .quick-manage-card i {
        font-size: 1.75rem;
        margin-bottom: 10px;
        display: block;
        color: var(--primary-red);
        transition: color 0.3s;
    }

    .quick-manage-card:hover i { color: white; }

    .quick-manage-card span {
        font-weight: 700;
        font-size: 0.85rem;
    }

    /* Premium Table & Charts */
    .premium-card {
        background: white;
        border-radius: 24px;
        border: none;
        box-shadow: var(--card-shadow);
        padding: 1.5rem;
        height: 100%;
    }

    .card-title-premium {
        font-size: 1.1rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .card-title-premium i { color: var(--primary-red); }

    /* Goal Progress */
    .goal-circular-container {
        position: relative;
        width: 150px;
        height: 150px;
        margin: 0 auto 1.5rem;
    }

    .goal-percentage {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--primary-red);
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #f1f1f1; }
    ::-webkit-scrollbar-thumb { background: #C40000; border-radius: 10px; }

    .badge-premium {
        padding: 6px 14px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
    }

    .top-product-item {
        display: flex;
        align-items: center;
        padding: 1rem 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .top-product-img {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        object-fit: cover;
        margin-right: 1rem;
        border: 2px solid #f8fafc;
    }

    .product-info h6 {
        margin: 0;
        font-weight: 700;
        font-size: 0.9rem;
    }

    .product-info p {
        margin: 0;
        font-size: 0.75rem;
        color: #64748b;
    }

    .product-stats {
        margin-left: auto;
        text-align: right;
    }

    .product-stats .revenue {
        display: block;
        font-weight: 800;
        color: var(--primary-red);
        font-size: 0.9rem;
    }

    .product-stats .qty {
        font-size: 0.7rem;
        color: #64748b;
        font-weight: 600;
    }

    .btn-action-sm {
        padding: 5px 15px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.8rem;
    }
</style>

<div class="container-fluid py-4">
    <!-- Top Statistic Cards -->
    <div class="row g-4 mb-4">
        <div class="col-xl col-md-4 col-sm-6">
            <div class="stat-card-glossy grad-red">
                <div class="stat-icon-wrapper"><i class="bi bi-cart-check"></i></div>
                <div class="stat-value">@Model.TotalDelivered</div>
                <div class="stat-label">Delivered Orders</div>
                <div class="stat-growth"><i class="bi bi-arrow-up-short"></i> +14.5%</div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="stat-card-glossy grad-dark">
                <div class="stat-icon-wrapper"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-value">@Model.TotalPending</div>
                <div class="stat-label">Pending Orders</div>
                <div class="stat-growth"><i class="bi bi-info-circle"></i> Requires Action</div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="stat-card-glossy grad-bright">
                <div class="stat-icon-wrapper"><i class="bi bi-gear-wide-connected"></i></div>
                <div class="stat-value">@Model.TotalProcessing</div>
                <div class="stat-label">In Processing</div>
                <div class="stat-growth"><i class="bi bi-arrow-repeat"></i> Live Processing</div>
            </div>
        </div>
        <div class="col-xl col-md-6 col-sm-6">
            <div class="stat-card-glossy grad-purple">
                <div class="stat-icon-wrapper"><i class="bi bi-truck"></i></div>
                <div class="stat-value">@Model.TotalShipped</div>
                <div class="stat-label">Shipped Orders</div>
                <div class="stat-growth"><i class="bi bi-geo-alt"></i> On the Way</div>
            </div>
        </div>
        <div class="col-xl col-md-6 col-sm-12">
            <div class="stat-card-glossy grad-orange">
                <div class="stat-icon-wrapper"><i class="bi bi-currency-dollar"></i></div>
                <div class="stat-value">৳@Model.TotalRevenue.ToString("#,##0")</div>
                <div class="stat-label">Total Revenue</div>
                <div class="stat-growth"><i class="bi bi-graph-up-arrow"></i> +28.4%</div>
            </div>
        </div>
    </div>

    <!-- Quick Management Section -->
    <div class="row g-3 mb-4">
        <div class="col-md-12">
            <div class="premium-card py-3">
                <div class="row g-2">
                    <div class="col-6 col-md-3 col-lg">
                        <a href="#" class="quick-manage-card">
                            <i class="bi bi-bullseye"></i>
                            <span>Goal Set</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3 col-lg">
                        <a href="#" class="quick-manage-card">
                            <i class="bi bi-people"></i>
                            <span>Customers</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3 col-lg">
                        <a href="#" class="quick-manage-card">
                            <i class="bi bi-person-badge"></i>
                            <span>Employees</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3 col-lg">
                        <a href="#" class="quick-manage-card">
                            <i class="bi bi-bicycle"></i>
                            <span>Delivery Men</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3 col-lg">
                        <a href="#" class="quick-manage-card">
                            <i class="bi bi-file-earmark-bar-graph"></i>
                            <span>Reports</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3 col-lg">
                        <a href="#" class="quick-manage-card">
                            <i class="bi bi-layout-text-window-reverse"></i>
                            <span>Footer</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3 col-lg">
                        <a href="#" class="quick-manage-card">
                            <i class="bi bi-credit-card"></i>
                            <span>Payments</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3 col-lg">
                        <a href="#" class="quick-manage-card">
                            <i class="bi bi-clock-history"></i>
                            <span>History</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Analytics Area -->
    <div class="row g-4 mb-4">
        <!-- Product Sales Line Chart -->
        <div class="col-xl-5">
            <div class="premium-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title-premium"><i class="bi bi-graph-up"></i> Product Sales Analytics</h5>
                    <div class="dropdown">
                        <button class="btn btn-light btn-sm dropdown-toggle rounded-pill px-3" type="button" data-bs-toggle="dropdown">
                            Weekly
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#">Daily</a></li>
                            <li><a class="dropdown-item" href="#">Weekly</a></li>
                            <li><a class="dropdown-item" href="#">Monthly</a></li>
                        </ul>
                    </div>
                </div>
                <div style="height: 350px;">
                    <canvas id="mainSalesChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Sales Goal Progress -->
        <div class="col-xl-3">
            <div class="premium-card text-center">
                <h5 class="card-title-premium text-start"><i class="bi bi-award"></i> Monthly Sales Goal</h5>
                <div class="goal-circular-container">
                    <canvas id="goalCircularChart"></canvas>
                    <div class="goal-percentage">@((Model.TotalRevenue / (Model.SalesGoal > 0 ? Model.SalesGoal : 1000000) * 100).ToString("0"))%</div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small fw-bold">
                        <span>Current: ৳@Model.TotalRevenue.ToString("#,##0")</span>
                        <span>Target: ৳@Model.SalesGoal.ToString("#,##0")</span>
                    </div>
                    <div class="progress" style="height: 10px; border-radius: 5px;">
                        <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" style="width: @((Model.TotalRevenue / (Model.SalesGoal > 0 ? Model.SalesGoal : 1000000) * 100).ToString("0"))%"></div>
                    </div>
                    <p class="mt-2 text-muted small">Remaining: ৳@((Model.SalesGoal - Model.TotalRevenue).ToString("#,##0"))</p>
                </div>
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-outline-danger btn-action-sm"><i class="bi bi-clock-history"></i> History</button>
                    <button class="btn btn-danger btn-action-sm"><i class="bi bi-pencil-square"></i> Edit Goal</button>
                </div>
            </div>
        </div>

        <!-- Top Moving Products -->
        <div class="col-xl-4">
            <div class="premium-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title-premium mb-0"><i class="bi bi-fire"></i> Top Moving Products</h5>
                    <a href="#" class="btn btn-link btn-sm text-danger fw-bold text-decoration-none p-0">View All</a>
                </div>
                <div class="top-products-list">
                    @foreach (var item in Model.TopProducts.Take(5))
                    {
                        <div class="top-product-item">
                            <img src="https://ui-avatars.com/api/?name=@item.ProductName&background=f8d7da&color=dc3545" class="top-product-img" alt="">
                            <div class="product-info">
                                <h6>@item.ProductName</h6>
                                <p>@item.Category</p>
                            </div>
                            <div class="product-stats">
                                <span class="revenue">৳@item.TotalRevenue.ToString("#,##0")</span>
                                <span class="qty">@item.TotalQuantity sold</span>
                            </div>
                        </div>
                    }
                </div>
                <button class="btn btn-light w-100 mt-3 fw-bold py-2 border rounded-4 text-danger">
                    View Full Report <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Extra Statistics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="premium-card p-3 d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted small fw-bold mb-1">TOTAL SALES</p>
                    <h4 class="fw-bold mb-0">@Model.TotalOrders.ToString("#,##0")</h4>
                    <span class="text-success small fw-bold"><i class="bi bi-arrow-up"></i> 12%</span>
                </div>
                <div class="text-danger" style="width: 80px; height: 40px;">
                    <canvas id="miniChart1"></canvas>
                </div>
                <div class="bg-danger-subtle p-3 rounded-4 text-danger ms-2">
                    <i class="bi bi-bag-heart"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="premium-card p-3 d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted small fw-bold mb-1">TOTAL PROFIT</p>
                    <h4 class="fw-bold mb-0">৳@Model.TotalProfit.ToString("#,##0")</h4>
                    <span class="text-danger small fw-bold"><i class="bi bi-arrow-down"></i> 3%</span>
                </div>
                <div class="text-primary" style="width: 80px; height: 40px;">
                    <canvas id="miniChart2"></canvas>
                </div>
                <div class="bg-primary-subtle p-3 rounded-4 text-primary ms-2">
                    <i class="bi bi-cash-coin"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="premium-card p-3 d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted small fw-bold mb-1">VAT COLLECTED</p>
                    <h4 class="fw-bold mb-0">৳@((Model.TotalRevenue * 0.05m).ToString("#,##0"))</h4>
                    <span class="text-success small fw-bold"><i class="bi bi-arrow-up"></i> 5%</span>
                </div>
                <div class="text-warning" style="width: 80px; height: 40px;">
                    <canvas id="miniChart3"></canvas>
                </div>
                <div class="bg-warning-subtle p-3 rounded-4 text-warning ms-2">
                    <i class="bi bi-receipt"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="premium-card p-3 d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted small fw-bold mb-1">WEEKLY SALES</p>
                    <h4 class="fw-bold mb-0">৳@Model.WeeklyRevenue.ToString("#,##0")</h4>
                    <span class="text-success small fw-bold"><i class="bi bi-arrow-up"></i> 8%</span>
                </div>
                <div class="text-success" style="width: 80px; height: 40px;">
                    <canvas id="miniChart4"></canvas>
                </div>
                <div class="bg-success-subtle p-3 rounded-4 text-success ms-2">
                    <i class="bi bi-calendar-check"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Analytics Sections -->
    <div class="row g-4">
        <!-- Sales by Product Type -->
        <div class="col-lg-4">
            <div class="premium-card h-100">
                <h5 class="card-title-premium"><i class="bi bi-pie-chart"></i> Sales by Product Type</h5>
                <div style="height: 250px;" class="mb-4">
                    <canvas id="productTypeDonutChart"></canvas>
                </div>
                <div class="product-legends">
                    @foreach (var item in Model.ProductTypeSales.Take(4))
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <span class="rounded-circle" style="width: 10px; height: 10px; background: @(item.ProductTypeName == "Men" ? "#C40000" : item.ProductTypeName == "Women" ? "#6c5ce7" : "#ff9f43")"></span>
                                <span class="small fw-bold">@item.ProductTypeName</span>
                            </div>
                            <span class="small fw-extrabold text-dark">৳@item.Amount.ToString("#,##0")</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Full Sales Archives -->
        <div class="col-lg-8">
            <div class="premium-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title-premium mb-0"><i class="bi bi-archive"></i> Full Sales Archives</h5>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-danger active rounded-start-pill px-3">Monthly View</button>
                        <button class="btn btn-outline-danger rounded-end-pill px-3">Yearly Summary</button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0 px-3 small fw-bold text-muted">MONTH/YEAR</th>
                                <th class="border-0 px-3 small fw-bold text-muted">REVENUE (INC. VAT)</th>
                                <th class="border-0 px-3 small fw-bold text-muted">PIECES</th>
                                <th class="border-0 px-3 small fw-bold text-muted">ACTION</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var month in Model.MonthlyHistory.Take(6))
                            {
                                <tr>
                                    <td class="px-3 fw-bold">@month.MonthName @month.Year</td>
                                    <td class="px-3"><span class="fw-extrabold text-dark">৳@month.Amount.ToString("#,##0")</span></td>
                                    <td class="px-3"><span class="badge bg-danger-subtle text-danger px-3 py-1 rounded-pill fw-bold">@month.Pieces Pcs</span></td>
                                    <td class="px-3"><button class="btn btn-light btn-sm rounded-pill px-3 border"><i class="bi bi-file-earmark-pdf"></i> Report</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Recent Orders Detailed View -->
        <div class="col-lg-12">
            <div class="premium-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title-premium mb-0"><i class="bi bi-receipt"></i> Recent Orders Detailed View</h5>
                    <div class="search-box" style="max-width: 300px;">
                        <input type="text" class="form-control form-control-sm rounded-pill px-3" placeholder="Search orders...">
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle" style="min-width: 1000px;">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0 px-3 small fw-bold text-muted">ORDER REF</th>
                                <th class="border-0 px-3 small fw-bold text-muted">CUSTOMER</th>
                                <th class="border-0 px-3 small fw-bold text-muted">DATE & TIME</th>
                                <th class="border-0 px-3 small fw-bold text-muted">AMOUNT</th>
                                <th class="border-0 px-3 small fw-bold text-muted">STATUS</th>
                                <th class="border-0 px-3 small fw-bold text-muted">LOCATION</th>
                                <th class="border-0 px-3 small fw-bold text-muted">ACTION</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders.Take(8))
                            {
                                <tr>
                                    <td class="px-3"><span class="fw-bold">#ORD-@order.OrderId</span></td>
                                    <td class="px-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="https://ui-avatars.com/api/?name=@order.CustomerName&size=30&background=random" class="rounded-circle" alt="">
                                            <span class="fw-bold">@order.CustomerName</span>
                                        </div>
                                    </td>
                                    <td class="px-3"><span class="small text-muted">@order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</span></td>
                                    <td class="px-3"><span class="fw-extrabold text-dark">৳@order.Amount.ToString("#,##0")</span></td>
                                    <td class="px-3">
                                        @if (order.Status == "Delivered") { <span class="badge bg-success-subtle text-success badge-premium">Delivered</span> }
                                        else if (order.Status == "Processing") { <span class="badge bg-primary-subtle text-primary badge-premium">Processing</span> }
                                        else if (order.Status == "Shipped") { <span class="badge bg-info-subtle text-info badge-premium">Shipped</span> }
                                        else { <span class="badge bg-warning-subtle text-warning badge-premium">Pending</span> }
                                    </td>
                                    <td class="px-3 small">@order.ShippingAddress</td>
                                    <td class="px-3">
                                        <button class="btn btn-light btn-sm rounded-pill px-2 border"><i class="bi bi-eye"></i></button>
                                        <button class="btn btn-light btn-sm rounded-pill px-2 border text-danger"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Employee Stats Table -->
        <div class="col-lg-12">
            <div class="premium-card">
                <h5 class="card-title-premium"><i class="bi bi-person-workspace"></i> Employee Performance Overview</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0 px-3 small fw-bold text-muted">EMPLOYEE NAME</th>
                                <th class="border-0 px-3 small fw-bold text-muted">PRODUCT COUNT</th>
                                <th class="border-0 px-3 small fw-bold text-muted">SOLD</th>
                                <th class="border-0 px-3 small fw-bold text-muted">VALUE</th>
                                <th class="border-0 px-3 small fw-bold text-muted">PERFORMANCE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model.EmployeePerformances)
                            {
                                <tr>
                                    <td class="px-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="bg-danger-subtle text-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                            <span class="fw-bold">@emp.EmployeeName</span>
                                        </div>
                                    </td>
                                    <td class="px-3">@emp.TotalProductsManaged Pcs</td>
                                    <td class="px-3"><span class="badge bg-primary-subtle text-primary px-3 py-1 rounded-pill fw-bold">@emp.ProductsSold Units</span></td>
                                    <td class="px-3 fw-extrabold text-dark">৳@emp.TotalSalesValue.ToString("#,##0")</td>
                                    <td class="px-3">
                                        <div class="progress" style="height: 6px; width: 150px;">
                                            <div class="progress-bar bg-success" style="width: @(emp.ProductsSold * 100 / (emp.TotalProductsManaged > 0 ? emp.TotalProductsManaged : 1))%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Main Sales Chart
        const mainSalesCtx = document.getElementById('mainSalesChart').getContext('2d');
        const mainGradient = mainSalesCtx.createLinearGradient(0, 0, 0, 400);
        mainGradient.addColorStop(0, 'rgba(196, 0, 0, 0.4)');
        mainGradient.addColorStop(1, 'rgba(196, 0, 0, 0)');

        new Chart(mainSalesCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.WeeklySales.Select(s => s.Date.ToString("ddd")))),
                datasets: [{
                    label: 'Sales',
                    data: @Html.Raw(Json.Serialize(Model.WeeklySales.Select(s => s.Amount))),
                    borderColor: '#C40000',
                    backgroundColor: mainGradient,
                    borderWidth: 4,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                    pointHoverRadius: 8,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#C40000',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { display: true, color: '#f1f5f9' }, ticks: { font: { size: 10 } } },
                    x: { grid: { display: false } }
                }
            }
        });

        // Goal Circular Chart
        const goalCtx = document.getElementById('goalCircularChart').getContext('2d');
        new Chart(goalCtx, {
            type: 'doughnut',
            data: {
                datasets: [{
                    data: [@Model.TotalRevenue, @(Math.Max(0, Model.SalesGoal - Model.TotalRevenue))],
                    backgroundColor: ['#C40000', '#f1f5f9'],
                    borderWidth: 0,
                    circumference: 360,
                    rotation: 0,
                    cutout: '85%',
                    borderRadius: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { tooltip: { enabled: false }, legend: { display: false } }
            }
        });

        // Product Type Donut Chart
        const donutCtx = document.getElementById('productTypeDonutChart').getContext('2d');
        new Chart(donutCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.ProductTypeSales.Select(s => s.ProductTypeName))),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.ProductTypeSales.Select(s => s.Amount))),
                    backgroundColor: ['#C40000', '#6c5ce7', '#ff9f43', '#10ac84'],
                    borderWidth: 0,
                    cutout: '70%',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } }
            }
        });

        // Mini Charts
        function createMiniChart(id, color) {
            const ctx = document.getElementById(id).getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [1, 2, 3, 4, 5, 6, 7],
                    datasets: [{
                        data: [10, 25, 15, 30, 20, 35, 25],
                        borderColor: color,
                        borderWidth: 2,
                        fill: false,
                        tension: 0.4,
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { enabled: false } },
                    scales: { x: { display: false }, y: { display: false } }
                }
            });
        }

        createMiniChart('miniChart1', '#C40000');
        createMiniChart('miniChart2', '#6366f1');
        createMiniChart('miniChart3', '#f59e0b');
        createMiniChart('miniChart4', '#10b981');
    </script>
}
