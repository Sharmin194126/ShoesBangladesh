@using System.Text.Json
@model List<JsonElement>
@{
    ViewData["Title"] = "Manage Banners";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string apiBase = "http://localhost:5190";
}

<style>
    .theme-back-btn { background: #C40000; color: white; border: none; padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 700; font-size: 0.85rem; text-decoration: none; transition: 0.2s; box-shadow: 0 4px 12px rgba(196,0,0,0.15); display: inline-flex; align-items: center; justify-content: center; }
    .theme-back-btn:hover { background: #8B0000; color: white; transform: translateY(-1px); }
</style>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">Manage Home Page Banners</h2>
        <a href="javascript:history.back()" class="theme-back-btn mb-0">Back</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-3">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-0 mb-4" style="border-radius:15px;">
        <div class="card-header bg-white py-3" style="border-radius:15px 15px 0 0;">
            <h5 class="mb-0 fw-bold">Upload New Banners</h5>
        </div>
        <div class="card-body">
            <form asp-action="CreateBanner" method="post" enctype="multipart/form-data" class="row align-items-end">
                <div class="col-md-5 mb-2 mb-md-0">
                    <label class="form-label small fw-bold text-muted text-uppercase">Banner Title (Optional)</label>
                    <input type="text" name="title" class="form-control" placeholder="e.g. Summer Collection" />
                </div>
                <div class="col-md-4 mb-2 mb-md-0">
                    <label class="form-label small fw-bold text-muted text-uppercase">Select Image</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" required />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="background:#C40000; border:none;"><i class="bi bi-cloud-upload me-2"></i> Upload</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius:15px;">
        <div class="card-header bg-white py-3" style="border-radius:15px 15px 0 0;">
            <h5 class="mb-0 fw-bold">Existing Banners</h5>
        </div>
        <div class="card-body">
            <div class="row g-4">
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var banner in Model)
                    {
                        // Robust ID extraction
                        int id = 0;
                        if (banner.TryGetProperty("id", out var idProp)) id = idProp.GetInt32();
                        else if (banner.TryGetProperty("Id", out var idProp2)) id = idProp2.GetInt32();
                        
                        var imgUrl = "";
                        if (banner.TryGetProperty("imageUrl", out var iu)) imgUrl = iu.GetString() ?? "";
                        else if (banner.TryGetProperty("ImageUrl", out var iu2)) imgUrl = iu2.GetString() ?? "";

                        var title = (banner.TryGetProperty("title", out var t) ? t.GetString() : 
                                    banner.TryGetProperty("Title", out var t2) ? t2.GetString() : "") ?? "Untitled";

                        <div class="col-md-4 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm" style="border-radius:12px; overflow:hidden;">
                                <img src="@(imgUrl.StartsWith("http") ? "" : apiBase)@imgUrl" class="card-img-top" style="height: 160px; object-fit: cover;" />
                                <div class="card-body text-center p-3">
                                    <h6 class="fw-bold mb-2 text-truncate">@title</h6>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-primary w-100 py-2 rounded-pill" data-bs-toggle="modal" data-bs-target="#bannerEditModal_@id">
                                            <i class="bi bi-pencil me-1"></i> Edit
                                        </button>
                                        <form asp-action="DeleteBanner" method="post" class="w-100">
                                            <input type="hidden" name="id" value="@id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100 py-2 rounded-pill" onclick="return confirm('Are you sure you want to delete this banner?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>

                                    <!-- Edit Modal for each banner (Unique ID ensures correct banner is edited) -->
                                    <div class="modal fade" id="bannerEditModal_@id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
                                                <div class="modal-header border-0 pb-0">
                                                    <h5 class="fw-bold">Edit Banner: @title</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form asp-action="UpdateBannerAction" method="post" enctype="multipart/form-data">
                                                    <div class="modal-body text-start">
                                                        <input type="hidden" name="id" value="@id" />
                                                        <div class="mb-3">
                                                            <label class="form-label small fw-bold text-muted text-uppercase">Banner Title</label>
                                                            <input type="text" name="title" class="form-control" value="@title" />
                                                        </div>
                                                        <div class="mb-3">
                                                            <label class="form-label small fw-bold text-muted text-uppercase">Update Image (Optional)</label>
                                                            <input type="file" name="imageFile" class="form-control" accept="image/*" />
                                                            <small class="text-muted">Leave empty to keep current image.</small>
                                                        </div>
                                                        <div class="mb-3">
                                                            <label class="form-label small fw-bold text-muted text-uppercase">Link URL (Optional)</label>
                                                            @{
                                                                string lUrl = "";
                                                                if (banner.TryGetProperty("linkUrl", out var lu)) lUrl = lu.GetString() ?? "";
                                                                else if (banner.TryGetProperty("LinkUrl", out var lu2)) lUrl = lu2.GetString() ?? "";
                                                            }
                                                            <input type="text" name="linkUrl" class="form-control" value="@lUrl" />
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer border-0 pt-0">
                                                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-primary rounded-pill px-4" style="background:#C40000; border:none;">Update Changes</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <div class="mb-3"><i class="bi bi-image fs-1 opacity-25"></i></div>
                        <p class="text-muted">No banners found. Upload some to get started.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
