<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shoes Bangladesh</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        :root {
            --primary-accent: #6366f1;
            --primary-dark: #0f172a;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --bg-light: #f8fafc;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-main);
            background-color: white;
            overflow-x: hidden;
        }

        /* Modern Navbar */
        .navbar-premium {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            padding: 1.25rem 0;
            transition: var(--transition);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: -0.02em;
        }

        .nav-link {
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-main) !important;
            padding: 0.5rem 1.25rem !important;
            transition: var(--transition);
        }

        .nav-link:hover {
            color: var(--primary-accent) !important;
            transform: translateY(-1px);
        }

        .nav-link.btn-cta {
            background: var(--primary-accent);
            color: white !important;
            border-radius: 100px;
            padding: 0.6rem 1.75rem !important;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25);
            margin-left: 1rem;
        }

        .nav-link.btn-cta:hover {
            background: #4f46e5;
            box-shadow: 0 6px 16px rgba(99, 102, 241, 0.35);
            color: white !important;
        }

        /* Footer Styling */
        .footer-premium {
            background: var(--primary-dark);
            color: white;
            padding: 5rem 0 2rem;
            margin-top: 5rem;
        }

        .footer-logo {
            font-weight: 800;
            font-size: 1.75rem;
            margin-bottom: 1.5rem;
            display: block;
        }

        .footer-link {
            color: #94a3b8;
            text-decoration: none;
            transition: var(--transition);
            display: block;
            margin-bottom: 0.75rem;
            font-weight: 500;
        }

        .footer-link:hover {
            color: white;
            padding-left: 5px;
        }

        .social-circle {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            margin-right: 0.75rem;
            transition: var(--transition);
        }

        .social-circle:hover {
            background: var(--primary-accent);
            transform: translateY(-3px);
        }

        main {
            min-height: 70vh;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-premium sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <div class="bg-primary text-white rounded-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; background: linear-gradient(135deg, #6366f1, #a855f7) !important;">S</div>
                    <span>SHOES<span class="text-primary">BD</span></span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="#">Men</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Women</a>
                        </li>
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-controller="Admin" asp-action="Index">Admin Panel</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <img src="https://ui-avatars.com/api/?name=@(User.Identity.Name)&background=6366f1&color=fff" class="rounded-circle" width="30">
                                    <span>Account</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-3 rounded-4 p-2">
                                    <li><a class="dropdown-item rounded-3 py-2" asp-controller="Customer" asp-action="Index">Dashboard</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item rounded-3 py-2 text-danger" asp-controller="Account" asp-action="Logout">Logout</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn-cta" asp-controller="Account" asp-action="Register">Join Us</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer style="
        background-color: #0a0a0a;
        background-image: linear-gradient(rgba(10,10,10,0.88), rgba(10,10,10,0.88));
        color: #fff;
        padding: 5rem 0 0;
        border-top: 2px solid #D4AF37;
        margin-top: 0;
    ">
        <div class="container pb-5">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div style="font-size:1.8rem; font-weight:900; letter-spacing:-1px; margin-bottom:1rem;">
                        SHOES<span style="color:#D4AF37">BD</span>
                    </div>
                    <p style="color:rgba(255,255,255,0.6); line-height:1.8;">Your trusted destination for premium fashion and quality footwear in Bangladesh.</p>
                    <div class="d-flex gap-3 mt-4">
                        <a href="#" class="btn btn-outline-warning btn-sm rounded-circle" style="width:38px;height:38px;display:flex;align-items:center;justify-content:center;"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-outline-warning btn-sm rounded-circle" style="width:38px;height:38px;display:flex;align-items:center;justify-content:center;"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="btn btn-outline-warning btn-sm rounded-circle" style="width:38px;height:38px;display:flex;align-items:center;justify-content:center;"><i class="bi bi-whatsapp"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 style="color:#D4AF37; font-weight:800; text-transform:uppercase; letter-spacing:2px; margin-bottom:1.8rem;">Explore</h6>
                    <a href="#" style="color:rgba(255,255,255,0.7); text-decoration:none; display:block; margin-bottom:0.8rem; transition:0.3s;" class="footer-nav-link">Latest Shoes</a>
                    <a href="#" style="color:rgba(255,255,255,0.7); text-decoration:none; display:block; margin-bottom:0.8rem; transition:0.3s;" class="footer-nav-link">New Arrivals</a>
                    <a href="#" style="color:rgba(255,255,255,0.7); text-decoration:none; display:block; margin-bottom:0.8rem; transition:0.3s;" class="footer-nav-link">Special Offers</a>
                    <a href="#" style="color:rgba(255,255,255,0.7); text-decoration:none; display:block; margin-bottom:0.8rem; transition:0.3s;" class="footer-nav-link">Track Order</a>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 style="color:#D4AF37; font-weight:800; text-transform:uppercase; letter-spacing:2px; margin-bottom:1.8rem;">Support</h6>
                    <a href="#" style="color:rgba(255,255,255,0.7); text-decoration:none; display:block; margin-bottom:0.8rem; transition:0.3s;" class="footer-nav-link">Terms of Service</a>
                    <a href="#" style="color:rgba(255,255,255,0.7); text-decoration:none; display:block; margin-bottom:0.8rem; transition:0.3s;" class="footer-nav-link">Privacy Policy</a>
                    <a href="#" style="color:rgba(255,255,255,0.7); text-decoration:none; display:block; margin-bottom:0.8rem; transition:0.3s;" class="footer-nav-link">Refund Policy</a>
                    <a href="#" style="color:rgba(255,255,255,0.7); text-decoration:none; display:block; margin-bottom:0.8rem; transition:0.3s;" class="footer-nav-link">FAQs</a>
                </div>
                <div class="col-lg-4">
                    <h6 style="color:#D4AF37; font-weight:800; text-transform:uppercase; letter-spacing:2px; margin-bottom:1.8rem;">Newsletter</h6>
                    <div style="background:rgba(255,255,255,0.05); padding:1.5rem; border-radius:16px; border:1px solid rgba(212,175,55,0.2);">
                        <p class="small mb-3" style="color:rgba(255,255,255,0.6);">Get the latest updates on new collections and exclusive offers.</p>
                        <div class="input-group">
                            <input type="email" id="footer-newsletter-email" class="form-control" placeholder="Your Email Address"
                                   style="background:rgba(255,255,255,0.08); border:1px solid rgba(212,175,55,0.4); color:#fff;">
                            <button class="btn btn-warning px-3" type="button" onclick="subscribeFooter()"><i class="bi bi-send"></i></button>
                        </div>
                        <div id="footer-newsletter-msg" class="small mt-2" style="display:none;"></div>
                    </div>
                    <div class="mt-4 ps-1">
                        <p class="mb-2" style="color:rgba(255,255,255,0.6);"><i class="bi bi-geo-alt-fill me-2" style="color:#D4AF37"></i> Dhaka, Bangladesh</p>
                        <p class="mb-2" style="color:rgba(255,255,255,0.6);"><i class="bi bi-envelope-fill me-2" style="color:#D4AF37"></i> info@shoesbangladesh.com</p>
                        <p class="mb-0" style="color:rgba(255,255,255,0.6);"><i class="bi bi-telephone-fill me-2" style="color:#D4AF37"></i> +880 1234 56789</p>
                    </div>
                </div>
            </div>
        </div>
        <div style="border-top:1px solid rgba(255,255,255,0.08); padding:1.5rem 0; text-align:center; color:rgba(255,255,255,0.4); font-size:0.85rem;">
            &copy; @DateTime.Now.Year Shoes Bangladesh. All Rights Reserved.
        </div>
    </footer>
    <style>
        .footer-nav-link:hover { color: #D4AF37 !important; padding-left: 5px; }
        input::placeholder { color: rgba(255,255,255,0.4) !important; }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        async function subscribeFooter() {
            const emailInput = document.getElementById('footer-newsletter-email');
            const msgEl = document.getElementById('footer-newsletter-msg');
            const email = emailInput.value.trim();
            if (!email) {
                msgEl.innerText = 'Please enter a valid email.';
                msgEl.style.color = '#ff4d4d';
                msgEl.style.display = 'block';
                return;
            }
            try {
                const response = await fetch('http://localhost:5190/api/Newsletter/Subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(email)
                });
                const result = await response.json();
                if (response.ok) {
                    msgEl.innerText = '✓ Thank you for subscribing!';
                    msgEl.style.color = '#4ade80';
                    emailInput.value = '';
                } else {
                    msgEl.innerText = result.message || 'Already subscribed.';
                    msgEl.style.color = '#facc15';
                }
            } catch {
                msgEl.innerText = 'Error connecting. Please try again.';
                msgEl.style.color = '#ff4d4d';
            }
            msgEl.style.display = 'block';
        }
    </script>

</body>
</html>
