<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SB Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --red-primary: #C40000;
            --red-soft: #E53E3E;
            --red-muted: #FF5A5A;
            --red-glow: rgba(196, 0, 0, 0.15);
            --red-tint: rgba(196, 0, 0, 0.06);

            --charcoal-dark: #1F1F1F;
            --charcoal: #2B2B2B;
            --charcoal-light: #3A3A3A;

            --white: #FFFFFF;
            --off-white: #F8F8F8;
            --gray-100: #F5F5F5;
            --gray-200: #ECECEC;
            --gray-300: #D9D9D9;
            --gray-400: #BDBDBD;
            --gray-500: #9E9E9E;
            --gray-600: #757575;
            --gray-700: #616161;
            --gray-800: #424242;
            --gray-900: #212121;

            --shadow-sm: 0 1px 4px rgba(0,0,0,0.06);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-lg: 0 8px 32px rgba(0,0,0,0.10);
            --shadow-red: 0 4px 20px rgba(196,0,0,0.18);

            --sidebar-width: 255px;
            --topbar-height: 62px;
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--gray-100);
            color: var(--gray-900);
            overflow-x: hidden;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--white);
            border-right: 1px solid var(--gray-200);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            z-index: 1050;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 2px 0 12px rgba(0,0,0,0.04);
        }

        .sidebar.collapsed { transform: translateX(-100%); }

        /* Brand Header */
        .sidebar-brand {
            padding: 1.25rem 1.25rem 1rem;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }

        .brand-avatar {
            width: 42px;
            height: 42px;
            border-radius: var(--radius-sm);
            background: linear-gradient(135deg, var(--red-primary), #7A0000);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 800;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .brand-info .brand-name {
            font-weight: 800;
            font-size: 0.95rem;
            color: var(--gray-900);
            line-height: 1.2;
        }

        .brand-info .brand-role {
            font-size: 0.65rem;
            color: var(--gray-500);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        /* Sidebar scroll */
        .sidebar-scroll {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 0.75rem 0 1rem;
        }

        .sidebar-scroll::-webkit-scrollbar { width: 3px; }
        .sidebar-scroll::-webkit-scrollbar-thumb { background: var(--gray-300); border-radius: 10px; }

        /* Admin profile section in sidebar */
        .sidebar-admin-profile {
            padding: 0.85rem 1.25rem;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
            background: var(--gray-100);
        }

        .sidebar-admin-profile img {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid var(--gray-300);
            flex-shrink: 0;
        }

        .sidebar-admin-profile .admin-name-text {
            font-size: 0.82rem;
            font-weight: 700;
            color: var(--gray-900);
            line-height: 1.2;
        }

        .sidebar-admin-profile .admin-role-text {
            font-size: 0.62rem;
            color: var(--gray-500);
            font-weight: 500;
        }

        .nav-group-title {
            padding: 1rem 1.25rem 0.35rem;
            font-size: 0.6rem;
            font-weight: 700;
            color: var(--gray-400);
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        .nav-list { list-style: none; padding: 0; margin: 0; }
        .nav-list li { padding: 1px 0.6rem; }

        .nav-link-item {
            display: flex;
            align-items: center;
            padding: 0.6rem 0.85rem;
            color: var(--gray-600);
            text-decoration: none;
            border-radius: var(--radius-sm);
            transition: all 0.18s ease;
            font-size: 0.82rem;
            font-weight: 500;
            gap: 10px;
            position: relative;
        }

        .nav-link-item i {
            font-size: 0.95rem;
            width: 18px;
            text-align: center;
            flex-shrink: 0;
        }

        /* Light red hover on sidebar nav */
        .nav-link-item:hover {
            background: #FFEBEE;
            color: var(--red-primary);
        }

        .nav-link-item:hover i { color: var(--red-primary); }

        .nav-link-item.active {
            background: var(--red-tint);
            color: var(--red-primary);
            font-weight: 700;
            border-left: 2.5px solid var(--red-primary);
        }

        .nav-link-item.active i { color: var(--red-primary); }

        /* Sidebar Footer */
        .sidebar-footer {
            padding: 0.75rem 0.85rem;
            border-top: 1px solid var(--gray-200);
            flex-shrink: 0;
        }

        .btn-logout-link {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 0.65rem;
            background: linear-gradient(135deg, var(--red-primary) 0%, #9A0000 100%);
            color: white;
            border: none;
            border-radius: var(--radius-sm);
            font-weight: 600;
            font-size: 0.85rem;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-logout-link:hover {
            background: linear-gradient(135deg, #E00000 0%, #7A0000 100%);
            color: white;
            box-shadow: var(--shadow-red);
        }

        /* ===== TOPBAR ===== */
        .topbar {
            margin-left: var(--sidebar-width);
            height: var(--topbar-height);
            background: var(--white);
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            gap: 1rem;
            position: sticky;
            top: 0;
            z-index: 999;
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: var(--shadow-sm);
        }

        .topbar.full-width { margin-left: 0; }

        .topbar-left { display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 0; }
        .topbar-right { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }

        /* Toggle Button */
        .btn-toggle {
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            background: var(--gray-100);
            border: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray-700);
            font-size: 1rem;
            cursor: pointer;
            transition: 0.2s;
            flex-shrink: 0;
        }

        .btn-toggle:hover { background: var(--gray-200); color: var(--gray-900); }

        /* Search - Light Red */
        .search-box {
            position: relative;
            max-width: 340px;
            width: 100%;
        }

        .search-box i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--red-primary);
            font-size: 0.85rem;
        }

        .search-input {
            width: 100%;
            padding: 0.5rem 1rem 0.5rem 2.2rem;
            border-radius: var(--radius-sm);
            border: 1.5px solid #FECACA;
            background: #FFEBEE;
            font-size: 0.82rem;
            color: var(--gray-900);
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: 0.2s;
        }

        .search-input::placeholder { color: #E57373; }
        .search-input:focus { border-color: var(--red-primary); background: #FFF5F5; box-shadow: 0 0 0 3px rgba(196,0,0,0.08); }

        /* Topbar elements */
        .lang-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--gray-700);
            cursor: pointer;
            padding: 0.4rem 0.65rem;
            border-radius: var(--radius-sm);
            border: 1px solid var(--gray-200);
            background: var(--white);
            transition: 0.2s;
        }

        .lang-btn:hover { background: var(--gray-100); }

        .notif-btn {
            position: relative;
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            background: var(--gray-100);
            border: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray-700);
            font-size: 1rem;
            cursor: pointer;
        }

        .notif-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            background: var(--red-primary);
            color: white;
            font-size: 0.55rem;
            font-weight: 700;
            padding: 2px 4px;
            border-radius: 50%;
            border: 2px solid white;
            min-width: 16px;
            text-align: center;
        }

        .admin-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0.35rem 0.75rem 0.35rem 0.35rem;
            border-radius: 100px;
            border: 1px solid var(--gray-200);
            background: var(--gray-100);
            cursor: pointer;
        }

        .admin-chip img { width: 28px; height: 28px; border-radius: 50%; }

        .admin-chip-info .name { font-size: 0.78rem; font-weight: 700; color: var(--gray-900); line-height: 1.2; }
        .admin-chip-info .role { font-size: 0.6rem; color: var(--gray-500); font-weight: 500; }

        .btn-profile {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 0.45rem 1rem;
            background: linear-gradient(135deg, var(--red-primary), #9A0000);
            color: white;
            border: none;
            border-radius: 100px;
            font-weight: 600;
            font-size: 0.78rem;
            cursor: pointer;
            text-decoration: none;
            transition: 0.2s;
            white-space: nowrap;
        }

        .btn-profile:hover { background: linear-gradient(135deg, #E00000, #7A0000); color: white; box-shadow: var(--shadow-red); }

        /* ===== MAIN ===== */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 1.5rem;
            min-height: calc(100vh - var(--topbar-height));
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .main-content.full-width { margin-left: 0; }

        /* Overlay */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.3);
            z-index: 1040;
            backdrop-filter: blur(2px);
        }

        .sidebar-overlay.show { display: block; }

        @@media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.mobile-open { transform: translateX(0); }
            .topbar, .main-content { margin-left: 0 !important; }
        }

        @@media (max-width: 768px) {
            .admin-chip-info, .btn-profile span { display: none; }
        }
    </style>
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Sidebar -->
    <aside class="sidebar" id="mainSidebar">

        <div class="sidebar-brand">
            <div class="brand-avatar">SB</div>
            <div class="brand-info">
                <div class="brand-name">Shoes Bangladesh</div>
                <div class="brand-role">Admin Panel</div>
            </div>
        </div>

        <!-- Admin Profile Section -->
        <div class="sidebar-admin-profile">
            <img src="https://ui-avatars.com/api/?name=Admin&background=C40000&color=fff" alt="Admin">
            <div>
                <div class="admin-name-text">@User.Identity?.Name?.Split('@')[0] ?? "Admin"</div>
                <div class="admin-role-text">System Administrator</div>
            </div>
        </div>

        <div class="sidebar-scroll">
            <ul class="nav-list">
                <li><a href="/" class="nav-link-item"><i class="bi bi-arrow-left-circle"></i> Back to Website</a></li>
                <li><a asp-controller="Admin" asp-action="Index" class="nav-link-item active"><i class="bi bi-grid"></i> Dashboard</a></li>
            </ul>

            <div class="nav-group-title">Catalogue</div>
            <ul class="nav-list">
                <li><a href="#" class="nav-link-item"><i class="bi bi-tags"></i> Categories</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-box-seam"></i> Products</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-collection"></i> Product Types</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-house-door"></i> Homepage Sections</a></li>
            </ul>

            <div class="nav-group-title">Operations</div>
            <ul class="nav-list">
                <li><a href="#" class="nav-link-item"><i class="bi bi-people"></i> Manage Customers</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-person-badge"></i> Manage Employees</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-bicycle"></i> Manage Deliveryman</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-cart"></i> Manage Carts</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-person-check"></i> Delivery Personnel</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-file-earmark-bar-graph"></i> Reports</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-star"></i> Manage Reviews</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-chat-dots"></i> Messages</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-envelope"></i> Emails</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-graph-up"></i> Employee Products-Sales</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-person-circle"></i> My Profile</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-credit-card"></i> Payment History</a></li>
                <li><a href="#" class="nav-link-item"><i class="bi bi-window-sidebar"></i> Manage Banners</a></li>
            </ul>

            <div class="nav-group-title">Tracking</div>
            <ul class="nav-list">
                <li><a href="#" class="nav-link-item"><i class="bi bi-geo-alt"></i> Track Customer Order</a></li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <a asp-controller="Account" asp-action="Logout" class="btn-logout-link">
                <i class="bi bi-power"></i> Logout
            </a>
        </div>
    </aside>

    <!-- Topbar -->
    <header class="topbar" id="mainTopbar">
        <div class="topbar-left">
            <button class="btn-toggle" id="sidebarToggle" title="Toggle Sidebar">
                <i class="bi bi-list" id="toggleIcon"></i>
            </button>
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" class="search-input" placeholder="Search products, orders, customers...">
            </div>
        </div>

        <div class="topbar-right">
            <div class="lang-btn">
                <img src="https://flagcdn.com/w20/gb.png" width="16" alt="">
                <span class="d-none d-md-inline">English</span>
                <i class="bi bi-chevron-down" style="font-size: 0.65rem;"></i>
            </div>
            <div class="notif-btn">
                <i class="bi bi-bell"></i>
                <span class="notif-badge">3</span>
            </div>
            <div class="admin-chip d-none d-md-flex">
                <img src="https://ui-avatars.com/api/?name=Admin&background=C40000&color=fff" alt="">
                <div class="admin-chip-info">
                    <div class="name">Admin</div>
                    <div class="role">System Admin</div>
                </div>
            </div>
            <a href="#" class="btn-profile">
                <i class="bi bi-person-vcard"></i>
                <span>Account Profile</span>
            </a>
        </div>
    </header>

    <!-- Content -->
    <main class="main-content" id="mainContent">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sidebar = document.getElementById('mainSidebar');
        const topbar = document.getElementById('mainTopbar');
        const content = document.getElementById('mainContent');
        const overlay = document.getElementById('sidebarOverlay');
        const icon = document.getElementById('toggleIcon');
        let isOpen = true;
        const mobile = () => window.innerWidth <= 992;

        document.getElementById('sidebarToggle').addEventListener('click', () => {
            if (mobile()) {
                const open = sidebar.classList.toggle('mobile-open');
                overlay.classList.toggle('show', open);
                icon.className = open ? 'bi bi-x-lg' : 'bi bi-list';
            } else {
                isOpen = !isOpen;
                sidebar.classList.toggle('collapsed', !isOpen);
                topbar.classList.toggle('full-width', !isOpen);
                content.classList.toggle('full-width', !isOpen);
                icon.className = isOpen ? 'bi bi-list' : 'bi bi-layout-sidebar';
            }
        });

        overlay.addEventListener('click', () => {
            sidebar.classList.remove('mobile-open');
            overlay.classList.remove('show');
            icon.className = 'bi bi-list';
        });

        window.addEventListener('resize', () => {
            if (!mobile()) {
                sidebar.classList.remove('mobile-open');
                overlay.classList.remove('show');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
