<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shoes BD Premium Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-red: #C40000;
            --dark-red: #7A0000;
            --bright-red: #FF1E1E;
            --soft-white: #F8F8F8;
            --bg-light: #F3F4F6;
            --sidebar-width: 280px;
            --sidebar-collapsed-width: 85px;
            --sidebar-gradient: linear-gradient(180deg, #7A0000 0%, #300000 100%);
            --glass-bg: rgba(255, 255, 255, 0.85);
            --card-shadow: 0 10px 30px rgba(196, 0, 0, 0.08);
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            --border-soft: rgba(196, 0, 0, 0.1);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-light);
            color: #1e293b;
            overflow-x: hidden;
            margin: 0;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(122, 0, 0, 0.2); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(122, 0, 0, 0.4); }

        /* Sidebar Styles */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: var(--sidebar-gradient);
            color: white;
            transition: var(--transition);
            z-index: 1050;
            display: flex;
            flex-direction: column;
            box-shadow: 15px 0 40px rgba(0,0,0,0.15);
        }

        .sidebar.collapsed {
            width: var(--sidebar-collapsed-width);
        }

        .sidebar-header {
            padding: 2rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: white;
        }

        .logo-circle {
            width: 45px;
            height: 45px;
            background: white;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-red);
            font-size: 1.5rem;
            font-weight: 800;
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        }

        .brand-name {
            font-size: 1.25rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            white-space: nowrap;
            opacity: 1;
            transition: var(--transition);
        }

        .sidebar.collapsed .brand-name {
            opacity: 0;
            width: 0;
            overflow: hidden;
        }

        .nav-section {
            padding: 1.5rem 0.8rem;
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
        }

        .nav-label {
            padding: 1rem 1.2rem 0.5rem;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.4);
            font-weight: 700;
        }

        .sidebar.collapsed .nav-label {
            display: none;
        }

        .nav-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .nav-item-premium {
            margin-bottom: 0.4rem;
        }

        .nav-link-premium {
            display: flex;
            align-items: center;
            padding: 0.85rem 1.2rem;
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            border-radius: 12px;
            transition: var(--transition);
            font-weight: 500;
            gap: 15px;
            position: relative;
        }

        .nav-link-premium i {
            font-size: 1.3rem;
            min-width: 24px;
            text-align: center;
            transition: var(--transition);
        }

        .nav-link-premium:hover {
            color: white;
            background: rgba(255,255,255,0.1);
            transform: translateX(5px);
        }

        .nav-link-premium.active {
            color: white;
            background: linear-gradient(90deg, var(--bright-red) 0%, var(--primary-red) 100%);
            box-shadow: 0 4px 15px rgba(255, 30, 30, 0.3);
            font-weight: 600;
        }

        .sidebar.collapsed .nav-text {
            display: none;
        }

        .sidebar.collapsed .nav-link-premium {
            justify-content: center;
            padding: 1rem;
        }

        .sidebar.collapsed .nav-link-premium:hover {
            transform: none;
        }

        .sidebar-footer {
            padding: 1.2rem;
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            transition: var(--transition);
            min-height: 100vh;
            padding: 1.5rem 2rem;
        }

        .main-content.expanded {
            margin-left: var(--sidebar-collapsed-width);
        }

        /* Top Navbar */
        .premium-navbar {
            background: var(--glass-bg);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 0.8rem 1.5rem;
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: var(--card-shadow);
            position: sticky;
            top: 1.5rem;
            z-index: 1000;
        }

        .nav-search {
            position: relative;
            max-width: 450px;
            width: 100%;
        }

        .nav-search input {
            background: #fff;
            border: 1px solid #eef2f7;
            padding: 0.7rem 1rem 0.7rem 3rem;
            border-radius: 14px;
            width: 100%;
            font-size: 0.95rem;
            transition: var(--transition);
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
        }

        .nav-search input:focus {
            border-color: var(--primary-red);
            box-shadow: 0 0 0 4px rgba(196, 0, 0, 0.05);
            outline: none;
        }

        .nav-search i {
            position: absolute;
            left: 1.2rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
        }

        .navbar-actions {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .action-icon {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #64748b;
            transition: var(--transition);
            position: relative;
            border: 1px solid #eef2f7;
        }

        .action-icon:hover {
            background: #f8fafc;
            color: var(--primary-red);
            transform: translateY(-2px);
        }

        .notification-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--bright-red);
            color: white;
            font-size: 0.7rem;
            padding: 2px 6px;
            border-radius: 20px;
            border: 2px solid white;
            font-weight: 700;
        }

        .lang-selector {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            padding: 6px 12px;
            border-radius: 10px;
            border: 1px solid #eef2f7;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .admin-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding-left: 1rem;
            border-left: 1px solid #eef2f7;
        }

        .admin-avatar {
            width: 45px;
            height: 45px;
            border-radius: 14px;
            object-fit: cover;
            border: 2px solid white;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .btn-account-profile {
            background: linear-gradient(135deg, var(--primary-red) 0%, var(--dark-red) 100%);
            color: white;
            border: none;
            padding: 0.6rem 1.2rem;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: var(--transition);
            box-shadow: 0 4px 12px rgba(196, 0, 0, 0.2);
        }

        .btn-account-profile:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(196, 0, 0, 0.3);
            color: white;
        }

        /* Section Title Style */
        .dashboard-header {
            margin-bottom: 2rem;
        }

        .dashboard-header h1 {
            font-size: 2rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 0.25rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .dashboard-header h1 i {
            color: var(--primary-red);
            font-size: 2.2rem;
        }

        .dashboard-header p {
            color: #64748b;
            font-size: 1rem;
            margin-bottom: 0;
        }

        /* Mobile Adjustments */
        @@media (max-width: 991.98px) {
            .sidebar { left: calc(-1 * var(--sidebar-width)); }
            .sidebar.show { left: 0; }
            .main-content { margin-left: 0 !important; padding: 1rem; }
            .premium-navbar { margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem; position: static; }
            .nav-search { order: 3; max-width: 100%; }
        }

        /* Animations */
        @@keyframes slideIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .content-body {
            animation: slideIn 0.6s ease-out forwards;
        }

        /* Utility */
        .glass-card {
            background: white;
            border-radius: 20px;
            border: 1px solid var(--border-soft);
            box-shadow: var(--card-shadow);
            transition: var(--transition);
        }

        .glass-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(196, 0, 0, 0.12);
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="/" class="brand-logo">
                <div class="logo-circle">SB</div>
                <div class="brand-name">SHOES BANGLADESH</div>
            </a>
        </div>

        <div class="nav-section">
            <div class="nav-label">Main Control</div>
            <ul class="nav-links">
                <li class="nav-item-premium">
                    <a href="/" class="nav-link-premium">
                        <i class="bi bi-globe"></i>
                        <span class="nav-text">Back to Website</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a asp-controller="Admin" asp-action="Index" class="nav-link-premium @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                        <i class="bi bi-speedometer2"></i>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-tags-fill"></i>
                        <span class="nav-text">Categories</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a asp-controller="Product" asp-action="Index" class="nav-link-premium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="bi bi-box-seam"></i>
                        <span class="nav-text">Products</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-ui-checks"></i>
                        <span class="nav-text">Product Types</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a asp-controller="Admin" asp-action="ManageDisplaySections" class="nav-link-premium @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageDisplaySections" ? "active" : "")">
                        <i class="bi bi-layout-text-sidebar"></i>
                        <span class="nav-text">Homepage Sections</span>
                    </a>
                </li>
            </ul>

            <div class="nav-label">Management</div>
            <ul class="nav-links">
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-person-badge"></i>
                        <span class="nav-text">Manage Customer</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a asp-controller="Admin" asp-action="EmployeeList" class="nav-link-premium @(ViewContext.RouteData.Values["action"]?.ToString() == "EmployeeList" ? "active" : "")">
                        <i class="bi bi-people"></i>
                        <span class="nav-text">Manage Employees</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-truck"></i>
                        <span class="nav-text">Manage Deliveryman</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-cart4"></i>
                        <span class="nav-text">Manage Carts</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-person-walking"></i>
                        <span class="nav-text">Delivery Personnel</span>
                    </a>
                </li>
            </ul>

            <div class="nav-label">Analytics & Communication</div>
            <ul class="nav-links">
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-bar-chart-line"></i>
                        <span class="nav-text">Reports</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a asp-controller="Admin" asp-action="ManageReviews" class="nav-link-premium @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageReviews" ? "active" : "")">
                        <i class="bi bi-star"></i>
                        <span class="nav-text">Manage Reviews</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a asp-controller="Admin" asp-action="Messages" class="nav-link-premium @(ViewContext.RouteData.Values["action"]?.ToString() == "Messages" ? "active" : "")">
                        <i class="bi bi-chat-left-text"></i>
                        <span class="nav-text">Messages</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-envelope"></i>
                        <span class="nav-text">Emails</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a asp-controller="Admin" asp-action="EmployeeSalesOverview" class="nav-link-premium @(ViewContext.RouteData.Values["action"]?.ToString() == "EmployeeSalesOverview" ? "active" : "")">
                        <i class="bi bi-graph-up-arrow"></i>
                        <span class="nav-text">Employee Products-Sales</span>
                    </a>
                </li>
            </ul>

            <div class="nav-label">Configuration</div>
            <ul class="nav-links">
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-person-circle"></i>
                        <span class="nav-text">My Profile</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a asp-controller="Admin" asp-action="OnlinePaymentHistory" class="nav-link-premium @(ViewContext.RouteData.Values["action"]?.ToString() == "OnlinePaymentHistory" ? "active" : "")">
                        <i class="bi bi-credit-card"></i>
                        <span class="nav-text">Payment History</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a asp-controller="Admin" asp-action="ManageLandingPage" class="nav-link-premium @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageLandingPage" ? "active" : "")">
                        <i class="bi bi-image"></i>
                        <span class="nav-text">Manage Banners</span>
                    </a>
                </li>
                <li class="nav-item-premium">
                    <a href="#" class="nav-link-premium">
                        <i class="bi bi-geo-alt"></i>
                        <span class="nav-text">Track Customer Order</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <a asp-controller="Account" asp-action="Logout" class="nav-link-premium text-white" style="background: rgba(255,255,255,0.1);">
                <i class="bi bi-box-arrow-right"></i>
                <span class="nav-text">Logout System</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content" id="main-content">
        <header class="premium-navbar">
            <div class="d-flex align-items-center gap-3">
                <div class="action-icon" id="toggle-sidebar">
                    <i class="bi bi-text-indent-left fs-5"></i>
                </div>
                <div class="nav-search d-none d-md-block">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Search products, orders, customers...">
                </div>
            </div>

            <div class="navbar-actions">
                <div class="lang-selector">
                    <img src="https://flagcdn.com/w20/us.png" alt="English" width="20">
                    <span>EN</span>
                    <i class="bi bi-chevron-down small"></i>
                </div>
                
                <div class="action-icon">
                    <i class="bi bi-bell"></i>
                    <span class="notification-badge">5</span>
                </div>

                <div class="admin-profile">
                    <img src="https://ui-avatars.com/api/?name=Admin&background=C40000&color=fff&bold=true" class="admin-avatar" alt="Admin">
                    <a href="#" class="btn btn-account-profile d-none d-lg-block">Account Profile</a>
                </div>
            </div>
        </header>

        <div class="content-body">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#toggle-sidebar').click(function() {
                if ($(window).width() > 991.98) {
                    $('#sidebar').toggleClass('collapsed');
                    $('#main-content').toggleClass('expanded');
                    $(this).find('i').toggleClass('bi-text-indent-left bi-text-indent-right');
                } else {
                    $('#sidebar').toggleClass('show');
                }
            });

            // Close sidebar on mobile when clicking outside
            $(document).click(function(event) {
                if (!$(event.target).closest('#sidebar, #toggle-sidebar').length) {
                    if ($(window).width() <= 991.98) {
                        $('#sidebar').removeClass('show');
                    }
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
