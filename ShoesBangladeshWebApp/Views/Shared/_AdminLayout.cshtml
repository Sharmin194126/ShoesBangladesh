<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shoes BD Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --sidebar-width: 280px;
            --sidebar-collapsed-width: 80px;
            --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            --sidebar-bg: #0f172a;
            --sidebar-hover: #1e293b;
            --accent-color: #6366f1;
            --text-muted: #94a3b8;
            --body-bg: #f8fafc;
            --card-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04), 0 4px 6px -2px rgba(0, 0, 0, 0.02);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--body-bg);
            color: #1e293b;
            overflow-x: hidden;
        }

        /* Sidebar Styles */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background-color: var(--sidebar-bg);
            color: white;
            transition: var(--transition);
            z-index: 1050;
            display: flex;
            flex-direction: column;
            box-shadow: 10px 0 30px rgba(0,0,0,0.1);
        }

        .sidebar.collapsed {
            width: var(--sidebar-collapsed-width);
        }

        .sidebar-header {
            padding: 2rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: white;
            transition: var(--transition);
        }

        .sidebar.collapsed .brand-name {
            display: none;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: var(--primary-gradient);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            font-weight: 800;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        }

        .nav-section {
            padding: 1.5rem 0.75rem;
            flex: 1;
            overflow-y: auto;
        }

        .nav-label {
            padding: 0 1rem 0.75rem;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            font-weight: 700;
        }

        .sidebar.collapsed .nav-label {
            display: none;
        }

        .nav-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .nav-item-admin {
            margin-bottom: 0.5rem;
        }

        .nav-link-admin {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 12px;
            transition: var(--transition);
            font-weight: 500;
            gap: 12px;
        }

        .nav-link-admin i {
            font-size: 1.25rem;
            min-width: 24px;
            text-align: center;
        }

        .nav-link-admin:hover {
            color: white;
            background: var(--sidebar-hover);
        }

        .nav-link-admin.active {
            color: white;
            background: var(--accent-color);
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        }

        .sidebar.collapsed .nav-text {
            display: none;
        }

        .sidebar-footer {
            padding: 1.5rem;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            transition: var(--transition);
            min-height: 100vh;
            padding: 2rem;
        }

        .main-content.expanded {
            margin-left: var(--sidebar-collapsed-width);
        }

        /* Top Navbar */
        .top-navbar {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border-radius: 20px;
            padding: 1rem 1.5rem;
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: var(--card-shadow);
        }

        .toggle-btn {
            background: #f1f5f9;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--sidebar-bg);
            transition: var(--transition);
        }

        .toggle-btn:hover {
            background: #e2e8f0;
        }

        .search-box {
            position: relative;
            max-width: 300px;
            width: 100%;
            display: none; /* Hidden for now */
        }

        @@media (min-width: 768px) {
            .search-box { display: block; }
        }

        .search-box input {
            background: #f1f5f9;
            border: none;
            padding: 0.6rem 1rem 0.6rem 2.5rem;
            border-radius: 10px;
            width: 100%;
            font-size: 0.9rem;
        }

        .search-box i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

        .user-menu {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .user-info {
            text-align: right;
            display: none;
        }

        @@media (min-width: 576px) {
            .user-info { display: block; }
        }

        .user-name {
            display: block;
            font-weight: 700;
            font-size: 0.9rem;
            line-height: 1;
        }

        .user-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .user-avatar {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            object-fit: cover;
            border: 2px solid white;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        /* Mobile Adjustments */
        @@media (max-width: 991.98px) {
            .sidebar {
                left: calc(-1 * var(--sidebar-width));
            }
            .sidebar.show {
                left: 0;
            }
            .main-content {
                margin-left: 0 !important;
                padding: 1.5rem;
            }
        }
        /* Premium Stat Cards */
        .stat-card-premium {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.5rem;
            border-radius: 20px;
            text-decoration: none;
            color: white;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
            border: none;
            box-shadow: var(--card-shadow);
        }

        .stat-card-premium:hover {
            transform: translateY(-5px);
            color: white;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        .card-variant-green { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
        .card-variant-orange { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
        .card-variant-blue { background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); }
        .card-variant-cyan { background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%); }
        .card-variant-purple { background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%); }

        .stat-card-label {
            font-size: 0.8rem;
            font-weight: 600;
            opacity: 0.9;
            margin-bottom: 0.25rem;
        }

        .stat-card-value {
            font-size: 1.5rem;
            font-weight: 800;
        }

        .stat-card-icon {
            font-size: 2.5rem;
            opacity: 0.3;
            position: absolute;
            right: 1rem;
            bottom: -0.5rem;
            transition: var(--transition);
        }

        .stat-card-premium:hover .stat-card-icon {
            opacity: 0.5;
            transform: scale(1.1) rotate(-10deg);
        }

        .dashboard-table-card {
            background: white;
            padding: 1.5rem;
            border-radius: 20px;
            box-shadow: var(--card-shadow);
            border: 1px solid rgba(0,0,0,0.05);
            height: 100%;
        }

        .dashboard-table-card h4 {
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 10px;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="/" class="brand-logo">
                <div class="logo-icon">S</div>
                <div class="brand-name">
                    <h5 class="mb-0 fw-bold">SHOES <span style="color: var(--accent-color)">BD</span></h5>
                </div>
            </a>
        </div>

        <div class="nav-section">
            <div class="nav-label">Main Menu</div>
            <ul class="nav-links">
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="Index" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Product" asp-action="Index" class="nav-link-admin @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                        <i class="bi bi-box-seam-fill"></i>
                        <span class="nav-text">Inventory</span>
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="OrdersByStatus" asp-route-status="All" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "OrdersByStatus" ? "active" : "")">
                        <i class="bi bi-cart-check-fill"></i>
                        <span class="nav-text">Orders</span>
                    </a>
                </li>
            </ul>

            <div class="nav-label mt-4">Settings</div>
            <ul class="nav-links">
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="ManageLandingPage" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageLandingPage" && ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                        <i class="bi bi-window-sidebar"></i>
                        <span class="nav-text">Landing Page</span>
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="OnlinePaymentHistory" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "OnlinePaymentHistory" && ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                        <i class="bi bi-credit-card-2-front-fill"></i>
                        <span class="nav-text">Payments</span>
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="ManageReviews" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageReviews" ? "active" : "")">
                        <i class="bi bi-star-fill"></i>
                        <span class="nav-text">Reviews</span>
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="Messages" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "Messages" ? "active" : "")">
                        <i class="bi bi-chat-dots-fill"></i>
                        <span class="nav-text">Messages</span>
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="ManageDisplaySections" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageDisplaySections" ? "active" : "")">
                        <i class="bi bi-layout-sidebar-inset"></i>
                        <span class="nav-text">Display Sections</span>
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="EmployeeSalesOverview" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "EmployeeSalesOverview" ? "active" : "")">
                        <i class="bi bi-graph-up-arrow"></i>
                        <span class="nav-text">Staff Performance</span>
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="EmployeeList" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "EmployeeList" ? "active" : "")">
                        <i class="bi bi-people-fill"></i>
                        <span class="nav-text">Staff Directory</span>
                    </a>
                </li>
                <li class="nav-item-admin">
                    <a asp-controller="Admin" asp-action="FooterSettings" class="nav-link-admin @(ViewContext.RouteData.Values["action"]?.ToString() == "FooterSettings" ? "active" : "")">
                        <i class="bi bi-layout-text-window-reverse"></i>
                        <span class="nav-text">Footer</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <a asp-controller="Account" asp-action="Logout" class="nav-link-admin text-danger">
                <i class="bi bi-box-arrow-left"></i>
                <span class="nav-text">Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content" id="main-content">
        <header class="top-navbar">
            <div class="d-flex align-items-center gap-3">
                <button class="toggle-btn" id="toggle-sidebar">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <h5 class="mb-0 fw-bold d-none d-sm-block">@ViewData["Title"]</h5>
            </div>

            <div class="user-menu">
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Search anything...">
                </div>
                <div class="user-info">
                    <span class="user-name">Administrator</span>
                    <span class="user-role">Super Admin</span>
                </div>
                <img src="https://ui-avatars.com/api/?name=Admin&background=6366f1&color=fff&bold=true" class="user-avatar" alt="Admin">
            </div>
        </header>

        <div class="content-body">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#toggle-sidebar').click(function() {
                if ($(window).width() > 991.98) {
                    $('#sidebar').toggleClass('collapsed');
                    $('#main-content').toggleClass('expanded');
                } else {
                    $('#sidebar').toggleClass('show');
                }
            });

            // Close sidebar on mobile when clicking outside
            $(document).click(function(event) {
                if (!$(event.target).closest('#sidebar, #toggle-sidebar').length) {
                    if ($(window).width() <= 991.98) {
                        $('#sidebar').removeClass('show');
                    }
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
