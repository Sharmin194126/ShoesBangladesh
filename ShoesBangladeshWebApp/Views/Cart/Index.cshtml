@model ShoesBangladeshWebApp.Models.CartViewModel
@{
    ViewData["Title"] = "My Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    bool hasItems = Model != null && Model.Items.Any();
}

<style>
    .page-card {
        background: #fdfdfd;
        box-shadow: none;
        color: #333;
    }
    .theme-back-btn { background: #F5F5F5; color: #1F1F1F; border: 1px solid #ECECEC; padding: 0.5rem 1.2rem; border-radius: 8px; font-weight: 600; font-size: 0.82rem; text-decoration: none; transition: 0.2s; }
    .theme-back-btn:hover { background: #ECECEC; color: #000; text-decoration: none; }
</style>

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0 fw-bold">My Cart</h2>
        <a href="javascript:history.back()" class="theme-back-btn mb-0">Back</a>
    </div>

    <div class="page-card p-4" style="background: #f2efe9; border-radius: 12px; border: 1px solid #ddd;">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (!hasItems)
        {
            <div class="text-center py-5">
                <i class="bi bi-cart-x text-muted" style="font-size: 5rem;"></i>
                <h3 class="fw-bold mt-4">Your cart is empty.</h3>
                <p class="text-muted" style="color: #666 !important;">Looks like you haven't added any shoes to your cart yet.</p>
                <a href="/Product/Index" class="btn btn-danger mt-3 px-4 py-2 fw-bold" style="background: #D00000; border: none; border-radius: 8px;">Continue Shopping</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="background: #f2efe9; border-radius: 8px; overflow: hidden;">
                    <thead style="background:#121212; color:#fff;">
                        <tr>
                            <th style="width: 70px;">SL</th>
                            <th>Image</th>
                            <th>Product</th>
                            <th style="width:120px;">Price</th>
                            <th style="width:150px;">Size</th>
                            <th style="width:150px;">Quantity</th>
                            <th style="width:120px;">Total</th>
                            <th style="width:120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var sl = 1; }
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@(sl++)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@(item.ImageUrl.StartsWith("http") ? item.ImageUrl : "http://localhost:5190" + item.ImageUrl)" style="width:60px;height:60px;object-fit:cover;border-radius:4px; border: 1px solid #eee;" />
                                    }
                                </td>
                                <td>
                                    <div style="font-weight: 600; color: #333;">@item.ProductName</div>
                                </td>
                                <td style="color: #333;">
                                    <div class="fw-bold">৳@item.UnitPrice.ToString("#,##0")</div>
                                    @if(item.VatAmount > 0) {
                                        <div class="text-success small" style="font-size: 11px; font-weight: 500;">+ ৳@item.VatAmount.ToString("#,##0") VAT (@item.VatPercentage.ToString("0")%)</div>
                                    }
                                    <div class="text-danger fw-bold" style="font-size: 0.9rem; border-top: 1px solid #ddd; margin-top: 2px; padding-top: 2px;">
                                        Inc. VAT: ৳@item.PriceWithVat.ToString("#,##0")
                                    </div>
                                </td>
                                <td>
                                    <form asp-action="UpdateQuantity" method="post">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="size" value="@item.Size" />
                                        <input type="hidden" name="quantity" value="@item.Quantity" />
                                        <select name="newSize" class="form-select form-select-sm" disabled style="background: #f2efe9; color: #333; border: 1px solid #ccc;">
                                            <option value="@item.Size" selected>@item.Size</option>
                                        </select>
                                    </form>
                                </td>
                                <td>
                                    <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="size" value="@item.Size" />
                                        <div class="d-flex align-items-center" style="border: 1px solid #999; border-radius: 5px; overflow: hidden; width: fit-content;">
                                            <style>
                                                input[type=number]::-webkit-inner-spin-button, 
                                                input[type=number]::-webkit-outer-spin-button { 
                                                    -webkit-appearance: none; 
                                                    margin: 0; 
                                                }
                                                input[type=number] { -moz-appearance: textfield; }
                                            </style>
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" 
                                                   class="form-control text-center fw-bold border-0" 
                                                   style="background: #f2efe9; color: #000 !important; font-size: 1.2rem; width: 100px; padding: 5px;" 
                                                   onchange="this.form.submit()" />
                                            <div class="d-flex flex-column bg-light border-start">
                                                <button type="button" onclick="this.parentNode.previousElementSibling.stepUp(); this.parentNode.previousElementSibling.dispatchEvent(new Event('change'));" class="btn btn-sm btn-light border-bottom py-0 px-2" style="font-size: 0.8rem; line-height: 1;">▲</button>
                                                <button type="button" onclick="this.parentNode.previousElementSibling.stepDown(); this.parentNode.previousElementSibling.dispatchEvent(new Event('change'));" class="btn btn-sm btn-light py-0 px-2" style="font-size: 0.8rem; line-height: 1;">▼</button>
                                            </div>
                                        </div>
                                    </form>
                                </td>
                                <td style="font-weight: bold; color: #2c3e50;">৳@item.LineTotal.ToString("#,##0")</td>
                                <td>
                                    <form asp-action="Remove" method="post">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="size" value="@item.Size" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4 p-3" style="background: #f2efe9; border-radius: 8px;">
                <div>
                    <form asp-action="Clear" method="post">
                        <button type="submit" class="btn btn-danger btn-sm">Clear Cart</button>
                    </form>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <span class="fs-4" style="color: #333;"><strong>Total (Inc. VAT): </strong> <span style="color: #d9534f; font-weight: 800;">৳@Model.GrandTotal.ToString("#,##0")</span></span>
                    <a href="/Order/Checkout" class="btn btn-success px-4 py-2" style="font-weight: bold;">Checkout Now</a>
                </div>
            </div>
        }
    </div>
</div>
